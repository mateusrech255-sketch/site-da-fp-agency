---
// src/layouts/Layout.astro
import WhatsAppFab from '../components/WhatsAppFab.astro';
---
<!doctype html>
<html lang="pt-BR">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/fpagency.svg" />
        <meta name="generator" content={Astro.generator} />
        <title>FP Agency</title>
    </head>
    <body>
        <slot />
        <WhatsAppFab />
    </body>
</html>

<style is:global>
  /* Variáveis e Fontes Globais para TODO o site */
  :root {
    --bg: #0f1117;
    --bg-2: #181c27;
    --text: #e2e8f0;
    --muted: #64748b;
    --orange: #ff6b2b;
    --orange2: #ff9a5c;
    --gold: #f59e0b;
    --shadow: 0 30px 80px rgba(0, 0, 0, 0.35);
    --container: 1220px;
    
    /* Novas Variáveis Essenciais para o Sistema do Recrutador e Monetização */
    --primary: #ff6b2b;
    --primary-dark: #e8591c;
    --gray: #94a3b8;
    --mono: 'JetBrains Mono', monospace;
  }

  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html, body {
    width: 100%;
    min-height: 100%;
    background-color: var(--bg);
    color: var(--text);
    /* Retorna a fonte moderna para o site inteiro! */
    font-family: "Inter", system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    scroll-behavior: smooth;
  }

  /* O Wrapper com o fundo gradiente bonito */
  .fp-agency-wrapper {
    background:
      radial-gradient(circle at top left, rgba(255, 107, 43, 0.16), transparent 28%),
      radial-gradient(circle at 85% 10%, rgba(255, 154, 92, 0.1), transparent 22%),
      linear-gradient(180deg, #0f1117 0%, #13161e 40%, #181c27 100%);
    overflow-x: hidden;
    line-height: 1.6;
    min-height: 100vh;
    position: relative;
  }

  .fp-agency-wrapper::before,
  .fp-agency-wrapper::after {
    content: "";
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: -1;
    will-change: transform;
    transform: translateZ(0);
  }

  .fp-agency-wrapper::before {
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.02) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.02) 1px, transparent 1px);
    background-size: 42px 42px;
    mask-image: linear-gradient(to bottom, rgba(0, 0, 0, 0.45), transparent 85%);
    -webkit-mask-image: linear-gradient(to bottom, rgba(0, 0, 0, 0.45), transparent 85%);
  }

  .fp-agency-wrapper::after {
    background: radial-gradient(circle at center, transparent 45%, rgba(0, 0, 0, 0.28) 100%);
  }

  a {
    color: inherit;
    text-decoration: none;
  }
</style>