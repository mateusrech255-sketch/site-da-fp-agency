---
import { Image } from 'astro:assets';
import logo from '../assets/logo.svg';

const base = import.meta.env.BASE_URL;
const baseUrl = base === '/' ? '' : base;
---

<footer class="site-footer">
  <div class="container footer-grid">
    <div>
      <a href={`${baseUrl}/`} class="brand">
        <Image src={logo} alt="FP Agency Logo" class="brand-logo" />
        <span>FP Agency</span>
      </a>
      <p class="subtle">
        Conectando criadores, recrutadores e marcas com tecnologia, treinamento e foco em resultados massivos. Direcionamento estratégico liderado por Mateus.
      </p>
    </div>

    <div>
      <h3>Navegação</h3>
      <div class="footer-links">
        <a href={`${baseUrl}/#jornadas`}>Jornadas</a>
        <a href={`${baseUrl}/#programas`}>Programas</a>
        <a href={`${baseUrl}/#estrutura`}>Estrutura</a>
        <a href={`${baseUrl}/#resultados`}>Resultados</a>
        <a href={`${baseUrl}/#faq`}>FAQ</a>
      </div>
    </div>

    <div>
      <h3>Institucional</h3>
      <div class="footer-links">
        <a href={`${baseUrl}/politica-de-privacidade`}>Política de Privacidade</a>
        <a href={`${baseUrl}/termos-de-servico`}>Termos de Serviço</a>
        <a href={`${baseUrl}/aviso-legal`}>Aviso Legal</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    padding: 44px 0 54px;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    background: #0b0c10;
    color: #e2e8f0;
    font-family: system-ui, -apple-system, sans-serif;
    position: relative;
    z-index: 10;
  }
  
  .container {
    width: min(calc(100% - 32px), 1220px);
    margin: 0 auto;
  }
  
  .footer-grid {
    display: grid;
    grid-template-columns: 1.3fr 1fr 1fr;
    gap: 32px;
  }
  
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    font-weight: 900;
    font-size: 1.04rem;
    color: #fff;
    text-decoration: none;
    margin-bottom: 14px;
  }
  
  .brand-logo {
    width: 46px;
    height: 46px;
    object-fit: contain;
  }
  
  .subtle {
    font-size: 0.92rem;
    color: #64748b;
    line-height: 1.6;
  }
  
  .site-footer h3 {
    font-size: 1.1rem;
    font-weight: 800;
    margin-bottom: 16px;
    color: #fff;
  }
  
  .footer-links {
    display: grid;
    gap: 12px;
    color: #64748b;
  }
  
  .footer-links a {
    text-decoration: none;
    color: inherit;
    transition: color 0.2s;
    font-weight: 500;
  }
  
  .footer-links a:hover {
    color: #fff;
  }

  @media (max-width: 1120px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }
</style>