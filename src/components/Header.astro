---
import { Image } from 'astro:assets';
import logo from '../assets/fpagency.svg';
import { publicApiUrls } from '../config/public-api';

const base = import.meta.env.BASE_URL;
const baseUrl = base === '/' ? '' : base.replace(/\/$/, '');
const searchApiUrl = publicApiUrls.search;
---

<header class="site-header" id="fp-header" data-base={baseUrl} data-search-api-url={searchApiUrl}>
  <div class="fp-header-container fp-header-nav">
    <a href={`${baseUrl}/`} class="fp-header-brand" aria-label="FP Agency">
      <Image
        src={logo}
        alt="FP Agency Logo"
        class="fp-header-logo"
        width={46}
        height={46}
        loading="eager"
        fetchpriority="high"
      />
      <span>FP Agency</span>
    </a>

    <nav class="fp-header-links" id="navLinks" aria-label="Navegação principal">
      <a href={`${baseUrl}/#jornadas`}>Jornadas</a>
      <a href={`${baseUrl}/#programas`}>Programas</a>
      <a href={`${baseUrl}/#estrutura`}>Estrutura</a>
      <a href={`${baseUrl}/#resultados`}>Resultados</a>
      <a href={`${baseUrl}/#faq`}>FAQ</a>
      <a href={`${baseUrl}/#contato`}>Contato</a>

      <button class="fp-mobile-search-btn" id="btn-mobile-search" type="button" aria-haspopup="dialog">
        <i class="fas fa-magnifying-glass" aria-hidden="true"></i>
        Buscar
      </button>
    </nav>

    <div class="fp-header-actions">
      <button class="fp-search-trigger" id="btn-desktop-search" type="button" aria-haspopup="dialog">
        <i class="fas fa-magnifying-glass" aria-hidden="true"></i>
        <span>Buscar...</span>
        <kbd>/</kbd>
      </button>

      <a href={`${baseUrl}/#contato`} class="fp-header-cta">Falar com a FP</a>

      <button class="fp-menu-toggle" id="menuToggle" type="button" aria-label="Abrir menu" aria-expanded="false">
        <span class="bar"></span>
        <span class="bar"></span>
        <span class="bar"></span>
      </button>
    </div>
  </div>

  <div
    id="global-search-modal"
    class="global-search-overlay"
    role="dialog"
    aria-modal="true"
    aria-hidden="true"
    aria-labelledby="global-search-title"
  >
    <div class="global-search-panel" role="document">
      <div class="global-search-inputbar">
        <i class="fas fa-magnifying-glass global-search-main-icon" aria-hidden="true"></i>
        <label id="global-search-title" class="sr-only" for="global-search-input">Busca global</label>
        <input
          type="search"
          id="global-search-input"
          placeholder="Busque páginas, relatórios ou @editores"
          autocomplete="off"
          spellcheck="false"
          role="combobox"
          aria-expanded="false"
          aria-controls="global-search-results"
          aria-autocomplete="list"
        />
        <button class="global-search-close" id="btn-close-search" type="button" aria-label="Fechar busca">
          <i class="fas fa-xmark" aria-hidden="true"></i>
        </button>
      </div>

      <div class="global-search-results" id="global-search-results" role="listbox" aria-live="polite"></div>

      <div class="global-search-footer" aria-hidden="true">
        <span><kbd>↑</kbd><kbd>↓</kbd> navegar</span>
        <span><kbd>Enter</kbd> abrir</span>
        <span><kbd>Esc</kbd> fechar</span>
      </div>
    </div>
  </div>
</header>

<div class="header-spacer"></div>

<script>
  import Fuse from 'fuse.js';
  import { searchIndex } from '../data/search-index';
  import type { SearchIndexItem, SearchItemType } from '../data/search-index';

  interface EditorSearchResult {
    nomeCompleto?: string;
    nome?: string;
    nomeUsuario?: string;
    statusResultado?: string;
    status?: string;
    fonte?: string;
    categoria?: string;
  }

  interface EditorApiResponse {
    success?: boolean;
    status?: string;
    message?: string;
    data?: EditorSearchResult[];
  }

  const API_DEBOUNCE_MS = 500;
  const API_LIMIT = 4;
  const MIN_LOCAL_CHARS = 2;
  const MIN_API_CHARS = 2;

  const initGlobalSearchHeader = (): void => {
      const headerEl = document.getElementById('fp-header') as HTMLElement | null;
      if (!headerEl || headerEl.dataset.globalSearchReady === 'true') return;

      const basePath = headerEl.getAttribute('data-base') || '';
      const apiUrl = headerEl.dataset.searchApiUrl || '';
      const searchModal = document.getElementById('global-search-modal') as HTMLElement | null;
      const searchInput = document.getElementById('global-search-input') as HTMLInputElement | null;
      const resultsContainer = document.getElementById('global-search-results') as HTMLElement | null;
      const closeButton = document.getElementById('btn-close-search') as HTMLButtonElement | null;
      const desktopSearchButton = document.getElementById('btn-desktop-search') as HTMLButtonElement | null;
      const mobileSearchButton = document.getElementById('btn-mobile-search') as HTMLButtonElement | null;
      const menuToggle = document.getElementById('menuToggle') as HTMLButtonElement | null;
      const navLinks = document.getElementById('navLinks') as HTMLElement | null;

      if (!searchModal || !searchInput || !resultsContainer) return;
      headerEl.dataset.globalSearchReady = 'true';

      const apiCache = new Map<string, EditorSearchResult[]>();
      let apiAbortController: AbortController | null = null;
      let apiDebounceTimer: number | undefined;
      let apiRequestVersion = 0;
      let activeIndex = -1;
      let lastFocusedElement: Element | null = null;

      const normalizeText = (value: unknown): string =>
        String(value || '')
          .normalize('NFD')
          .replace(/[\u0300-\u036f]/g, '')
          .toLowerCase()
          .trim();

      const escapeHtml = (value: unknown): string =>
        String(value == null ? '' : value)
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;')
          .replace(/'/g, '&#x27;');

      const escapeRegex = (value: unknown): string => String(value || '').replace(/[.*+?^${}()|[\]\\]/g, '\\$&');

      const routeWithBase = (url: string): string => {
        const rawUrl = String(url || '/');
        if (/^https?:\/\//i.test(rawUrl)) return rawUrl;
        const path = rawUrl.startsWith('/') ? rawUrl : `/${rawUrl}`;
        if (!basePath) return path;
        return path === '/' ? `${basePath}/` : `${basePath}${path}`;
      };

      const buildSearchUrl = (tab: string, query: unknown): string => {
        const safeTab = encodeURIComponent(tab || 'site');
        const safeQuery = encodeURIComponent(String(query || '').trim());
        return `${routeWithBase('/busca')}?tab=${safeTab}${safeQuery ? `&q=${safeQuery}` : ''}`;
      };

      const getDisplayTerm = (query: unknown): string => String(query || '').replace(/^@+/, '').trim();

      const highlightText = (text: unknown, query: unknown): string => {
        const safeText = escapeHtml(text);
        const term = getDisplayTerm(query);
        if (normalizeText(term).length < 3) return safeText;

        const regex = new RegExp(`([\\p{L}\\p{N}_-]*${escapeRegex(term)}[\\p{L}\\p{N}_-]*)`, 'giu');
        return safeText.replace(regex, '<mark>$1</mark>');
      };

      const setChildren = (parent: HTMLElement | null, children: Node[]): void => {
        if (!parent) return;
        parent.replaceChildren(...children);
      };

      const createIcon = (iconClass?: string): HTMLElement => {
        const icon = document.createElement('i');
        icon.className = `fas ${iconClass || 'fa-circle-dot'}`;
        icon.setAttribute('aria-hidden', 'true');
        return icon;
      };

      const createSectionTitle = (label: string): HTMLElement => {
        const title = document.createElement('div');
        title.className = 'global-search-section-title';
        title.textContent = label;
        return title;
      };

      const createHint = () => {
        const hint = document.createElement('div');
        hint.className = 'global-search-empty';

        const icon = createIcon('fa-keyboard');
        const title = document.createElement('strong');
        title.textContent = 'Comece digitando para buscar no site.';
        const text = document.createElement('span');
        text.textContent = 'Use @ antes do nome para consultar editores aprovados. Exemplo: @mateus';

        hint.append(icon, title, text);
        return hint;
      };

      const createEmptyState = (message: string): HTMLElement => {
        const empty = document.createElement('div');
        empty.className = 'global-search-empty compact';
        empty.append(createIcon('fa-circle-info'));

        const text = document.createElement('span');
        text.textContent = message;
        empty.append(text);
        return empty;
      };

      const createSkeleton = () => {
        const wrap = document.createElement('div');
        wrap.className = 'global-search-api-loading';
        wrap.dataset.apiSkeleton = 'true';
        wrap.append(createSectionTitle('Editores'));

        for (let index = 0; index < 3; index += 1) {
          const skeleton = document.createElement('div');
          skeleton.className = 'global-search-skeleton';
          wrap.append(skeleton);
        }

        return wrap;
      };

      const getCategoryLabel = (type: SearchItemType): string => {
        if (type === 'feature') return 'Recurso';
        if (type === 'section') return 'Secao';
        return 'Pagina';
      };

      const createLocalItem = (item: SearchIndexItem, query: string): HTMLAnchorElement => {
        const link = document.createElement('a');
        link.className = 'global-search-item global-search-focusable';
        link.href = routeWithBase(item.url);
        link.setAttribute('role', 'option');
        link.tabIndex = -1;

        const iconWrap = document.createElement('span');
        iconWrap.className = 'global-search-item-icon';
        iconWrap.append(createIcon(item.icon));

        const content = document.createElement('span');
        content.className = 'global-search-item-content';

        const title = document.createElement('span');
        title.className = 'global-search-item-title';
        title.innerHTML = highlightText(item.title, query);

        const desc = document.createElement('span');
        desc.className = 'global-search-item-desc';
        desc.textContent = item.description;

        content.append(title, desc);

        const meta = document.createElement('span');
        meta.className = 'global-search-item-meta';
        meta.textContent = item.category || getCategoryLabel(item.type);

        const arrow = createIcon('fa-chevron-right');
        arrow.classList.add('global-search-arrow');

        link.append(iconWrap, content, meta, arrow);
        return link;
      };

      const getStatusClass = (status: unknown): string => {
        const normalized = normalizeText(status);
        if (normalized.includes('aprov')) return 'success';
        if (normalized.includes('reprov')) return 'danger';
        if (normalized.includes('pend') || normalized.includes('analis')) return 'warning';
        return 'neutral';
      };

      const createEditorItem = (item: EditorSearchResult, query: string): HTMLAnchorElement => {
        const name = String(item?.nomeCompleto || item?.nome || item?.nomeUsuario || 'Editor sem nome').trim();
        const status = String(item?.statusResultado || item?.status || 'Em analise').trim();
        const source = String(item?.fonte || item?.categoria || 'Base FP').trim();

        const link = document.createElement('a');
        link.className = 'global-search-item global-search-focusable editor-result';
        link.href = buildSearchUrl('aprovacao', name);
        link.setAttribute('role', 'option');
        link.tabIndex = -1;

        const iconWrap = document.createElement('span');
        iconWrap.className = 'global-search-item-icon editor';
        iconWrap.append(createIcon('fa-user-astronaut'));

        const content = document.createElement('span');
        content.className = 'global-search-item-content';

        const title = document.createElement('span');
        title.className = 'global-search-item-title';
        title.innerHTML = highlightText(name, query);

        const desc = document.createElement('span');
        desc.className = 'global-search-item-desc';
        desc.textContent = `Fonte: ${source}`;

        const badge = document.createElement('span');
        badge.className = `global-search-status ${getStatusClass(status)}`;
        badge.textContent = status;

        content.append(title, desc);
        link.append(iconWrap, content, badge);
        return link;
      };

      const createCommandItem = (label: string, description: string, iconClass: string, url: string): HTMLAnchorElement => {
        const link = document.createElement('a');
        link.className = 'global-search-item global-search-focusable command';
        link.href = url;
        link.setAttribute('role', 'option');
        link.tabIndex = -1;

        const iconWrap = document.createElement('span');
        iconWrap.className = 'global-search-item-icon command';
        iconWrap.append(createIcon(iconClass));

        const content = document.createElement('span');
        content.className = 'global-search-item-content';

        const title = document.createElement('span');
        title.className = 'global-search-item-title';
        title.textContent = label;

        const desc = document.createElement('span');
        desc.className = 'global-search-item-desc';
        desc.textContent = description;

        const key = document.createElement('kbd');
        key.textContent = 'Enter';

        content.append(title, desc);
        link.append(iconWrap, content, key);
        return link;
      };

      const fuse = new Fuse<SearchIndexItem>(searchIndex, {
        keys: [
          { name: 'title', weight: 0.42 },
          { name: 'description', weight: 0.22 },
          { name: 'keywords', weight: 0.28 },
          { name: 'category', weight: 0.08 },
        ],
        threshold: 0.34,
        ignoreLocation: true,
        includeScore: true,
        minMatchCharLength: 2,
      });

      const searchLocal = (query: string): SearchIndexItem[] => {
        const cleanQuery = getDisplayTerm(query);
        if (normalizeText(cleanQuery).length < MIN_LOCAL_CHARS) {
          return searchIndex
            .slice()
            .sort((a, b) => b.priority - a.priority)
            .slice(0, 5);
        }

        return fuse
          .search(cleanQuery)
          .map(({ item, score = 1 }) => ({ item, score }))
          .sort((a, b) => (a.score - b.score) || (b.item.priority - a.item.priority))
          .map(({ item }) => item)
          .slice(0, 7);
      };

      const getFocusableItems = (): HTMLElement[] =>
        Array.from(resultsContainer?.querySelectorAll<HTMLElement>('.global-search-focusable') || []);

      const setActiveItem = (nextIndex: number): void => {
        const items = getFocusableItems();
        if (!items.length || !searchInput) {
          activeIndex = -1;
          return;
        }

        items.forEach((item) => item.classList.remove('active'));
        activeIndex = (nextIndex + items.length) % items.length;

        const activeItem = items[activeIndex];
        if (!activeItem.id) activeItem.id = `global-search-option-${activeIndex}`;
        activeItem.classList.add('active');
        searchInput.setAttribute('aria-activedescendant', activeItem.id);
        activeItem.scrollIntoView({ block: 'nearest', behavior: 'smooth' });
      };

      const resetActiveItem = () => {
        activeIndex = -1;
        searchInput?.removeAttribute('aria-activedescendant');
      };

      const appendApiResults = (items: EditorSearchResult[], query: string): void => {
        resultsContainer?.querySelector('[data-api-skeleton="true"]')?.remove();
        if (!resultsContainer) return;

        if (!items.length) {
          resultsContainer.append(createSectionTitle('Editores'));
          resultsContainer.append(createEmptyState('Nenhum editor encontrado para este @termo.'));
          resetActiveItem();
          return;
        }

        const section = document.createElement('div');
        section.className = 'global-search-group';
        section.dataset.apiResults = 'true';
        section.append(createSectionTitle('Editores'));
        items.slice(0, API_LIMIT).forEach((item) => section.append(createEditorItem(item, query)));
        resultsContainer.append(section);
        resetActiveItem();
      };

      const abortApiSearch = () => {
        apiRequestVersion += 1;
        if (apiAbortController) apiAbortController.abort();
        apiAbortController = null;
        window.clearTimeout(apiDebounceTimer);
        resultsContainer?.querySelector('[data-api-skeleton="true"]')?.remove();
      };

      const fetchEditors = async (rawQuery: string): Promise<void> => {
        const editorTerm = getDisplayTerm(rawQuery);
        const cacheKey = normalizeText(editorTerm);
        const requestVersion = ++apiRequestVersion;

        if (!cacheKey || cacheKey.length < MIN_API_CHARS) return;

        if (!apiUrl) {
          resultsContainer?.querySelector('[data-api-skeleton="true"]')?.remove();
          const group = document.createElement('div');
          group.className = 'global-search-group';
          group.dataset.apiResults = 'true';
          group.append(createSectionTitle('Editores'));
          group.append(createEmptyState('Busca de editores indisponivel: configure PUBLIC_SEARCH_API_URL.'));
          resultsContainer?.append(group);
          resetActiveItem();
          return;
        }

        const cachedResults = apiCache.get(cacheKey);
        if (cachedResults) {
          appendApiResults(cachedResults, rawQuery);
          return;
        }

        if (apiAbortController) apiAbortController.abort();
        apiAbortController = new AbortController();
        resultsContainer?.querySelector('[data-api-skeleton="true"]')?.remove();
        resultsContainer?.append(createSkeleton());

        try {
          const response = await fetch(apiUrl, {
            method: 'POST',
            body: JSON.stringify({
              action: 'buscarAprovacao',
              data: { termo: editorTerm, filtro: 'all', page: 1, limit: API_LIMIT },
            }),
            signal: apiAbortController.signal,
          });

          const text = await response.text();
          const payload = JSON.parse(text) as EditorApiResponse;
          const data = Array.isArray(payload?.data) ? payload.data : [];

          if (requestVersion !== apiRequestVersion) return;
          if (payload?.success === false || payload?.status === 'error') {
            throw new Error(payload?.message || 'Nao foi possivel buscar editores.');
          }

          apiCache.set(cacheKey, data);
          appendApiResults(data, rawQuery);
        } catch (error) {
          if ((error instanceof Error && error.name === 'AbortError') || requestVersion !== apiRequestVersion) return;
          resultsContainer?.querySelector('[data-api-skeleton="true"]')?.remove();
          resultsContainer?.append(createEmptyState('A base de editores nao respondeu agora. Tente novamente em instantes.'));
        }
      };

      const scheduleApiSearch = (query: string): void => {
        window.clearTimeout(apiDebounceTimer);
        const normalized = normalizeText(query);
        const editorTerm = getDisplayTerm(query);

        if (!normalized.startsWith('@') || normalizeText(editorTerm).length < MIN_API_CHARS) {
          abortApiSearch();
          return;
        }

        apiDebounceTimer = window.setTimeout(() => fetchEditors(query), API_DEBOUNCE_MS);
      };

      const renderSearch = (query = ''): void => {
        if (!resultsContainer) return;

        const normalizedQuery = normalizeText(query);
        if (!normalizedQuery) {
          setChildren(resultsContainer, [createHint()]);
          resetActiveItem();
          abortApiSearch();
          return;
        }

        const items: Node[] = [];
        const localResults = searchLocal(query);
        const pageResults = localResults.filter((item) => item.category !== 'Relatorios');
        const reportResults = localResults.filter((item) => item.category === 'Relatorios');

        if (pageResults.length) {
          const pageGroup = document.createElement('div');
          pageGroup.className = 'global-search-group';
          pageGroup.append(createSectionTitle('Paginas'));
          pageResults.slice(0, 5).forEach((item) => pageGroup.append(createLocalItem(item, query)));
          items.push(pageGroup);
        }

        const reportGroup = document.createElement('div');
        reportGroup.className = 'global-search-group';
        reportGroup.append(createSectionTitle('Relatorios'));
        if (reportResults.length) {
          reportResults.slice(0, 3).forEach((item) => reportGroup.append(createLocalItem(item, query)));
        }
        reportGroup.append(createCommandItem(
          `Pesquisar "${getDisplayTerm(query)}" em relatorios`,
          'Abre a central de busca diretamente na aba de relatorios.',
          'fa-chart-line',
          buildSearchUrl('relatorio', getDisplayTerm(query)),
        ));
        items.push(reportGroup);

        if (!pageResults.length && !reportResults.length) {
          items.unshift(createEmptyState('Nenhuma pagina encontrada. Tente outro termo ou use @ para buscar editores.'));
        }

        setChildren(resultsContainer, items);
        resetActiveItem();
        scheduleApiSearch(query);
      };

      const openGlobalSearch = () => {
        if (!searchModal || !searchInput) return;

        lastFocusedElement = document.activeElement;
        searchModal.classList.add('active');
        searchModal.setAttribute('aria-hidden', 'false');
        searchInput.setAttribute('aria-expanded', 'true');
        document.body.classList.add('global-search-open');
        renderSearch('');

        window.setTimeout(() => {
          searchInput.value = '';
          searchInput.focus({ preventScroll: true });
        }, 40);
      };

      const closeGlobalSearch = () => {
        if (!searchModal || !searchInput) return;

        searchModal.classList.remove('active');
        searchModal.setAttribute('aria-hidden', 'true');
        searchInput.setAttribute('aria-expanded', 'false');
        document.body.classList.remove('global-search-open');
        abortApiSearch();
        resetActiveItem();

        if (lastFocusedElement instanceof HTMLElement) {
          lastFocusedElement.focus({ preventScroll: true });
        }
      };

      const isTypingTarget = (target: EventTarget | null): boolean => {
        if (!(target instanceof HTMLElement)) return false;
        const tag = target.tagName;
        return tag === 'INPUT' || tag === 'TEXTAREA' || tag === 'SELECT' || target.isContentEditable;
      };

      desktopSearchButton?.addEventListener('click', openGlobalSearch);
      mobileSearchButton?.addEventListener('click', openGlobalSearch);
      closeButton?.addEventListener('click', closeGlobalSearch);

      searchModal?.addEventListener('mousedown', (event) => {
        if (event.target === searchModal) closeGlobalSearch();
      });

      searchInput?.addEventListener('input', (event) => {
        const target = event.currentTarget;
        if (target instanceof HTMLInputElement) renderSearch(target.value.trim());
      });

      searchInput?.addEventListener('keydown', (event) => {
        const items = getFocusableItems();

        if (event.key === 'ArrowDown') {
          event.preventDefault();
          setActiveItem(activeIndex + 1);
          return;
        }

        if (event.key === 'ArrowUp') {
          event.preventDefault();
          setActiveItem(activeIndex - 1);
          return;
        }

        if (event.key === 'Enter') {
          event.preventDefault();
          if (activeIndex > -1 && items[activeIndex]) {
            items[activeIndex].click();
            return;
          }

          const query = searchInput.value.trim();
          if (query.length >= MIN_LOCAL_CHARS) {
            const tab = normalizeText(query).startsWith('@') ? 'aprovacao' : 'site';
            window.location.href = buildSearchUrl(tab, getDisplayTerm(query));
          }
        }
      });

      document.addEventListener('keydown', (event) => {
        if (event.key === '/' && !isTypingTarget(event.target)) {
          event.preventDefault();
          openGlobalSearch();
        }

        if (event.key === 'Escape' && searchModal?.classList.contains('active')) {
          closeGlobalSearch();
        }
      });

      if (menuToggle && navLinks) {
        menuToggle.addEventListener('click', () => {
          const isOpen = navLinks.classList.toggle('open');
          menuToggle.classList.toggle('open', isOpen);
          menuToggle.setAttribute('aria-expanded', String(isOpen));
          menuToggle.setAttribute('aria-label', isOpen ? 'Fechar menu' : 'Abrir menu');
        });

        navLinks.querySelectorAll('a').forEach((link) => {
          link.addEventListener('click', () => {
            navLinks.classList.remove('open');
            menuToggle.classList.remove('open');
            menuToggle.setAttribute('aria-expanded', 'false');
            menuToggle.setAttribute('aria-label', 'Abrir menu');
          });
        });
      }

      renderSearch('');
  };

  const bootGlobalSearchHeader = (): void => {
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initGlobalSearchHeader, { once: true });
      return;
    }

    initGlobalSearchHeader();
  };

  bootGlobalSearchHeader();
</script>

<style is:global>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  body.global-search-open {
    overflow: hidden;
  }

  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 1000;
    padding: 16px 0;
    backdrop-filter: blur(16px);
    background: rgba(15, 17, 23, 0.86);
    border-bottom: 1px solid rgba(255, 255, 255, 0.07);
    font-family: "Sora", system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  .header-spacer {
    display: block;
    width: 100%;
    height: 79px;
  }

  .fp-header-container {
    width: min(calc(100% - 32px), 1220px);
    margin: 0 auto;
  }

  .fp-header-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
  }

  .fp-header-brand {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    color: #fff;
    text-decoration: none;
    font-size: 1.04rem;
    font-weight: 900;
