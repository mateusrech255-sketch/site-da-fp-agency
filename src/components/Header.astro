---
import logo from '../assets/fpagency.svg';
const base = import.meta.env.BASE_URL;
const baseUrl = base === '/' ? '' : base;
---

<header class="site-header">
  <div class="container nav">
    <a href={`${baseUrl}/`} class="brand" aria-label="FP Agency">
      <img src={logo.src} alt="FP Agency Logo" class="brand-logo" />
      <span>FP Agency</span>
    </a>

    <nav class="nav-links" id="navLinks">
      <a href={`${baseUrl}/#jornadas`}>Jornadas</a>
      <a href={`${baseUrl}/#programas`}>Programas</a>
      <a href={`${baseUrl}/#estrutura`}>Estrutura</a>
      <a href={`${baseUrl}/#resultados`}>Resultados</a>
      <a href={`${baseUrl}/#faq`}>FAQ</a>
      <a href={`${baseUrl}/#contato`}>Contato</a>
    </nav>

    <a href={`${baseUrl}/#contato`} class="btn-secondary nav-btn">Falar com a FP</a>
    <button class="menu-toggle" id="menuToggle" aria-label="Abrir menu">☰</button>
  </div>
</header>

<script>
  const menuToggle = document.getElementById("menuToggle");
  const navLinks = document.getElementById("navLinks");
  
  if (menuToggle && navLinks) {
    menuToggle.addEventListener("click", () => {
      navLinks.classList.toggle("open");
    });
  }
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 90;
    padding: 16px 0;
    backdrop-filter: blur(16px);
    background: rgba(15, 17, 23, 0.85);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    font-family: system-ui, -apple-system, sans-serif;
  }
  
  .container {
    width: min(calc(100% - 32px), 1220px);
    margin: 0 auto;
  }
  
  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
  }
  
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    font-weight: 900;
    letter-spacing: -0.03em;
    font-size: 1.04rem;
    color: #fff;
    text-decoration: none;
  }
  
  .brand-logo {
    width: 46px;
    height: 46px;
    object-fit: contain;
  }
  
  .nav-links {
    display: flex;
    align-items: center;
    gap: 24px;
    color: #dbe7f0;
    font-weight: 650;
  }
  
  .nav-links a {
    text-decoration: none;
    color: inherit;
    position: relative;
    opacity: 0.92;
  }
  
  .nav-links a::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: -8px;
    width: 0;
    height: 2px;
    background: linear-gradient(90deg, #ff6b2b, #ff9a5c);
    transition: width 0.2s ease;
  }
  
  .nav-links a:hover::after {
    width: 100%;
  }
  
  .btn-secondary {
    background: rgba(255, 255, 255, 0.045);
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.12);
    backdrop-filter: blur(12px);
    min-height: 50px;
    padding: 0 22px;
    border-radius: 999px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-weight: 800;
    text-decoration: none;
    transition: transform 0.18s ease;
  }
  
  .btn-secondary:hover {
    transform: translateY(-2px);
  }
  
  .menu-toggle {
    display: none;
    background: transparent;
    border: 0;
    color: #fff;
    font-size: 1.8rem;
    cursor: pointer;
  }

  @media (max-width: 860px) {
    .nav-links {
      position: absolute;
      top: calc(100% + 12px);
      left: 16px;
      right: 16px;
      display: none;
      flex-direction: column;
      align-items: flex-start;
      gap: 14px;
      padding: 18px;
      border-radius: 22px;
      background: rgba(8, 16, 24, 0.96);
      border: 1px solid rgba(255, 255, 255, 0.08);
      box-shadow: 0 30px 80px rgba(0, 0, 0, 0.35);
    }
    .nav-links.open { display: flex; }
    .menu-toggle { display: inline-flex; }
    .nav-btn { display: none; }
  }
</style>