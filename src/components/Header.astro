---
import { Image } from 'astro:assets';
import logo from '../assets/fpagency.svg';
const base = import.meta.env.BASE_URL;
const baseUrl = base === '/' ? '' : base;
---

<header class="site-header" id="fp-header" data-base={baseUrl}>
  <div class="container nav">
    <a href={`${baseUrl}/`} class="brand" aria-label="FP Agency">
      <Image 
        src={logo} 
        alt="FP Agency Logo" 
        class="brand-logo" 
        width={46} 
        height={46} 
        loading="eager" 
        fetchpriority="high" 
      />
      <span>FP Agency</span>
    </a>

    <nav class="nav-links" id="navLinks">
      <a href={`${baseUrl}/#jornadas`}>Jornadas</a>
      <a href={`${baseUrl}/#programas`}>Programas</a>
      <a href={`${baseUrl}/#estrutura`}>Estrutura</a>
      <a href={`${baseUrl}/#resultados`}>Resultados</a>
      <a href={`${baseUrl}/#faq`}>FAQ</a>
      <a href={`${baseUrl}/#contato`}>Contato</a>
      
      <button class="mobile-search-btn" id="btn-mobile-search">
        <i class="fas fa-magnifying-glass"></i> Buscar
      </button>
    </nav>

    <div class="header-actions">
      <div class="search-trigger" id="btn-desktop-search">
        <i class="fas fa-magnifying-glass"></i>
        <span>Buscar...</span>
        <kbd>/</kbd>
      </div>
      <a href={`${baseUrl}/#contato`} class="btn-secondary nav-btn">Falar com a FP</a>
      
      <button class="menu-toggle" id="menuToggle" aria-label="Abrir menu">
        <span class="bar"></span>
        <span class="bar"></span>
        <span class="bar"></span>
      </button>
    </div>
  </div>

  <div id="global-search-modal" class="search-overlay">
    <div class="search-container">
      <div class="search-input-field">
        <i class="fas fa-magnifying-glass main-icon"></i>
        <input type="text" id="global-search-input" placeholder="O que você está procurando?" autocomplete="off" spellcheck="false">
        <button class="close-search" id="btn-close-search" aria-label="Fechar busca">
          <i class="fas fa-xmark"></i>
        </button>
      </div>
      
      <div class="search-results-flow" id="global-search-results">
        <div class="search-hint">
          <i class="fas fa-keyboard"></i>
          <p>Busque por páginas, editores, diretrizes ou pressione <strong>ENTER</strong> para busca avançada.</p>
        </div>
      </div>
    </div>
  </div>
</header>

<div class="header-spacer"></div>

<script is:inline type="module">
  import Fuse from 'https://esm.sh/fuse.js@7.0.0';

  const API_URL = 'https://script.google.com/macros/s/AKfycbwGdUL3p5qf1GozVaGkE0Xx9epH4Pf5pJe59eennDsD34hX0P85HekUl_9p4HqzBzLS/exec';
  const headerEl = document.getElementById('fp-header');
  const basePath = headerEl ? headerEl.getAttribute('data-base') : '';

  const searchModal = document.getElementById('global-search-modal');
  const searchInput = document.getElementById('global-search-input');
  const resultsContainer = document.getElementById('global-search-results');
  
  const searchCache = new Map();
  let fetchController = null;
  let typingTimer = null;
  let currentFocus = -1;

  const paginasSite = [
    { tipo: 'pagina', titulo: "Página Inicial (Home)", url: `${basePath}/`, tags: "home inicio fp agency", icon: "fa-home" },
    { tipo: 'pagina', titulo: "Sobre a FP Agency", url: `${basePath}/sobre`, tags: "sobre historia missao visao valores ecossistema", icon: "fa-rocket" },
    { tipo: 'pagina', titulo: "Kwai Cut", url: `${basePath}/monetize/kwaicut`, tags: "kwai cut monetize monetização edição", icon: "fa-video" },
    { tipo: 'pagina', titulo: "NarraStars", url: `${basePath}/monetize/kwainarrastars`, tags: "narrastars narração kwai locução", icon: "fa-microphone" },
    { tipo: 'pagina', titulo: "Área do Recrutador", url: `${basePath}/recrutador`, tags: "recrutador equipe gerenciar convites painel", icon: "fa-users" },
    { tipo: 'pagina', titulo: "Política de Privacidade", url: `${basePath}/politica-de-privacidade`, tags: "politica privacidade dados lgpd segurança legal", icon: "fa-shield-halved" },
    { tipo: 'pagina', titulo: "Termos de Serviço", url: `${basePath}/termos-de-servico`, tags: "termos serviço regras contrato legal uso", icon: "fa-file-signature" },
    { tipo: 'pagina', titulo: "Aviso Legal", url: `${basePath}/aviso-legal`, tags: "aviso legal juridico direitos isenção responsabilidade", icon: "fa-gavel" },
    { tipo: 'pagina', titulo: "Central de Busca Avançada", url: `${basePath}/busca`, tags: "busca pesquisar editores planilha status", icon: "fa-magnifying-glass" }
  ];

  const fuse = new Fuse(paginasSite, {
    keys: ['titulo', 'tags'],
    threshold: 0.4,
    ignoreLocation: true,
    minMatchCharLength: 2,
    includeScore: true
  });

  const highlight = (texto, termo) => {
    if (!termo) return texto;
    const regex = new RegExp(`(${termo.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')})`, 'gi');
    return texto.replace(regex, '<mark>$1</mark>');
  };

  const renderSkeleton = () => `
    <div class="search-section-title">Buscando na base global...</div>
    <div class="search-skeleton"></div>
    <div class="search-skeleton" style="width: 85%"></div>
    <div class="search-skeleton" style="width: 90%"></div>
  `;

  const renderItem = (item, termo, isApi = false) => {
    const titleHighlighted = highlight(item.titulo, termo);
    
    if (isApi) {
      let statusColor = item.status === 'Aprovado' ? '#10b981' : (item.status === 'Reprovado' ? '#ef4444' : '#f59e0b');
      return `
        <div class="site-search-item search-focusable api-result" data-url="#" tabindex="0">
          <div class="api-item-left">
            <i class="fas fa-user-astronaut api-icon"></i>
            <div>
              <div class="api-title">${titleHighlighted}</div>
              <div class="api-sub">Fonte: ${item.fonte || 'Desconhecida'}</div>
            </div>
          </div>
          <div class="api-status" style="color: ${statusColor}; background: ${statusColor}15; border-color: ${statusColor}30;">
            ${item.status}
          </div>
        </div>
      `;
    }

    return `
      <a href="${item.url}" class="site-search-item search-focusable" tabindex="0">
        <i class="fas ${item.icon}"></i>
        <span>${titleHighlighted}</span>
        <i class="fas fa-chevron-right arrow-icon"></i>
      </a>
    `;
  };

  const executarBusca = async (termo) => {
    const resultadosLocais = fuse.search(termo).slice(0, 4); 
    let html = '';
    
    if (resultadosLocais.length > 0) {
      html += `<div class="search-section-title">Páginas Sugeridas</div>`;
      html += resultadosLocais.map(res => renderItem(res.item, termo, false)).join('');
    }

    html += `
      <a href="${basePath}/busca?q=${encodeURIComponent(termo)}" class="site-search-item highlight-enter search-focusable" tabindex="0">
        <i class="fas fa-level-down-alt fa-rotate-90"></i>
        <span>Pesquisar "<strong>${termo}</strong>" na base de editores</span>
        <kbd>↵</kbd>
      </a>
    `;

    resultsContainer.innerHTML = html;
    currentFocus = -1; 

    if (searchCache.has(termo)) {
      renderApiResults(searchCache.get(termo), termo);
      return;
    }

    if (fetchController) fetchController.abort();
    fetchController = new AbortController();

    const skeletonDiv = document.createElement('div');
    skeletonDiv.id = 'api-skeleton-wrap';
    skeletonDiv.innerHTML = renderSkeleton();
    resultsContainer.appendChild(skeletonDiv);

    try {
      const payload = { action: 'buscarAprovacao', data: { termo: termo, filtro: 'all', page: 1, limit: 3 } };
      const response = await fetch(API_URL, {
        method: 'POST',
        body: JSON.stringify(payload),
        signal: fetchController.signal 
      });
      
      const resJson = await response.json();
      
      if (resJson.success !== false) {
        searchCache.set(termo, resJson.data || []);
        renderApiResults(resJson.data || [], termo);
      }
    } catch (e) {
      if (e.name === 'AbortError') {
        console.log('Busca cancelada por nova digitação.');
      } else {
        document.getElementById('api-skeleton-wrap')?.remove();
      }
    }
  };

  const renderApiResults = (data, termo) => {
    document.getElementById('api-skeleton-wrap')?.remove();
    if (!data || data.length === 0) return;

    const div = document.createElement('div');
    div.innerHTML = `<div class="search-section-title" style="margin-top: 15px;">Editores na Base (Top 3)</div>` + 
                    data.map(item => renderItem({ titulo: item.nomeCompleto, fonte: item.fonte, status: item.statusResultado }, termo, true)).join('');
    
    resultsContainer.appendChild(div);
  };
  
  searchInput?.addEventListener('input', (e) => {
    clearTimeout(typingTimer);
    const termo = e.target.value.trim();
    
    if (termo.length < 2) {
      resultsContainer.innerHTML = `
        <div class="search-hint">
          <i class="fas fa-keyboard"></i>
          <p>Busque por páginas, editores, diretrizes ou pressione <strong>ENTER</strong> para busca avançada.</p>
        </div>`;
      if (fetchController) fetchController.abort(); 
      return;
    }

    typingTimer = setTimeout(() => executarBusca(termo), 250); 
  });

  searchInput?.addEventListener('keydown', (e) => {
    const items = document.querySelectorAll('.search-focusable');
    
    if (e.key === 'ArrowDown') {
      e.preventDefault();
      currentFocus++;
      addActive(items);
    } else if (e.key === 'ArrowUp') {
      e.preventDefault();
      currentFocus--;
      addActive(items);
    } else if (e.key === 'Enter') {
      e.preventDefault();
      if (currentFocus > -1 && items[currentFocus]) {
        items[currentFocus].click();
      } else {
        const termo = searchInput.value.trim();
        if (termo.length >= 2) window.location.href = `${basePath}/busca?q=${encodeURIComponent(termo)}`;
      }
    }
  });

  const addActive = (items) => {
    if (!items || items.length === 0) return;
    removeActive(items);
    if (currentFocus >= items.length) currentFocus = 0;
    if (currentFocus < 0) currentFocus = (items.length - 1);
    
    items[currentFocus].classList.add("active");
    items[currentFocus].scrollIntoView({ block: 'nearest', behavior: 'smooth' });
  };

  const removeActive = (items) => {
    items.forEach(item => item.classList.remove("active"));
  };

  const openGlobalSearch = () => {
    searchModal?.classList.add('active');
    setTimeout(() => { searchInput.value = ''; searchInput?.focus(); }, 50);
    document.body.style.overflow = 'hidden'; 
  };

  const closeGlobalSearch = () => {
    searchModal?.classList.remove('active');
    document.body.style.overflow = '';
  };

  document.getElementById('btn-mobile-search')?.addEventListener('click', openGlobalSearch);
  document.getElementById('btn-desktop-search')?.addEventListener('click', openGlobalSearch);
  document.getElementById('btn-close-search')?.addEventListener('click', closeGlobalSearch);

  document.addEventListener('keydown', (e) => {
    if (e.key === '/' && document.activeElement?.tagName !== 'INPUT') {
      e.preventDefault();
      openGlobalSearch();
    }
    if (e.key === 'Escape' && searchModal?.classList.contains('active')) {
      closeGlobalSearch();
    }
  });

  const menuToggle = document.getElementById("menuToggle");
  const navLinks = document.getElementById("navLinks");
  if (menuToggle && navLinks) {
    menuToggle.addEventListener("click", () => {
      navLinks.classList.toggle("open");
      menuToggle.classList.toggle("open");
    });
  }
</script>

<style>
  /* 1. CONFIGURAÇÃO GLOBAL DO HEADER (Fixo no topo e transparente blur) */
  .site-header { 
    position: fixed; 
    top: 0; 
    left: 0;
    width: 100%;
    z-index: 1000; 
    padding: 16px 0; 
    backdrop-filter: blur(16px); 
    background: rgba(15, 17, 23, 0.85); 
    border-bottom: 1px solid rgba(255, 255, 255, 0.06); 
    font-family: system-ui, sans-serif; 
  }
  
  /* 2. ESPAÇADOR FANTASMA: Garante que o texto da página não suma embaixo do header */
  .header-spacer {
    display: block;
    width: 100%;
    height: 79px; 
  }

  /* 3. ESTRUTURA E LINKS */
  .container { width: min(calc(100% - 32px), 1220px); margin: 0 auto; }
  .nav { display: flex; align-items: center; justify-content: space-between; gap: 20px; }
  .brand { display: inline-flex; align-items: center; gap: 14px; font-weight: 900; color: #fff; text-decoration: none; font-size: 1.04rem;}
  .brand-logo { width: 46px; height: 46px; object-fit: contain; }
  
  .nav-links { display: flex; align-items: center; gap: 24px; color: #dbe7f0; font-weight: 600; font-size: 0.95rem; }
  .nav-links a { text-decoration: none; color: inherit; position: relative; }
  .nav-links a:hover { color: #ff6b2b; }
  
  /* 4. BOTÕES E AÇÕES */
  .header-actions { display: flex; align-items: center; gap: 15px; }
  
  .search-trigger { display: flex; align-items: center; gap: 10px; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); padding: 8px 16px; border-radius: 99px; color: #94a3b8; font-size: 0.9rem; cursor: pointer; transition: 0.2s; }
  .search-trigger:hover { background: rgba(255,255,255,0.1); color: #fff; border-color: rgba(255,255,255,0.2); }
  .search-trigger kbd { background: rgba(255,255,255,0.1); padding: 2px 6px; border-radius: 4px; font-size: 0.75rem; font-family: monospace; color: #fff; }

  .btn-secondary { background: rgba(255,255,255,0.05); color: #fff; border: 1px solid rgba(255,255,255,0.1); padding: 10px 22px; border-radius: 99px; font-weight: 700; text-decoration: none; transition: 0.2s; }
  .btn-secondary:hover { background: #fff; color: #000; }
  
  /* 5. ANIMAÇÃO DO MENU MOBILE (HAMBURGUER -> X) */
  .menu-toggle { display: none; flex-direction: column; justify-content: space-between; width: 28px; height: 20px; background: transparent; border: 0; cursor: pointer; padding: 0; z-index: 1001; }
  .menu-toggle .bar { width: 100%; height: 3px; background-color: #fff; border-radius: 3px; transition: all 0.3s ease-in-out; transform-origin: center; }
  
  .menu-toggle.open .bar:nth-child(1) { transform: translateY(8.5px) rotate(45deg); }
  .menu-toggle.open .bar:nth-child(2) { opacity: 0; transform: scale(0); }
  .menu-toggle.open .bar:nth-child(3) { transform: translateY(-8.5px) rotate(-45deg); }

  /* 6. MODAL DE BUSCA GLOAL (COMMAND PALETTE) */
  .search-overlay { position: fixed; inset: 0; background: rgba(8, 10, 15, 0.6); backdrop-filter: blur(12px); z-index: 9999; display: flex; justify-content: center; align-items: flex-start; padding-top: 12vh; opacity: 0; pointer-events: none; transition: 0.2s ease; }
  .search-overlay.active { opacity: 1; pointer-events: all; }
  
  .search-container { width: 90%; max-width: 650px; background: var(--bg-2, #181c27); border: 1px solid rgba(255,255,255,0.1); border-radius: 16px; box-shadow: 0 25px 50px -12px rgba(0,0,0,0.6); overflow: hidden; transform: scale(0.96) translateY(-10px); transition: 0.2s cubic-bezier(0.16, 1, 0.3, 1); }
  .search-overlay.active .search-container { transform: scale(1) translateY(0); }
  
  .search-input-field { display: flex; align-items: center; padding: 18px 25px; border-bottom: 1px solid rgba(255,255,255,0.05); background: rgba(255,255,255,0.02); }
  .main-icon { font-size: 1.2rem; color: var(--primary, #ff6b2b); margin-right: 15px; }
  .search-input-field input { flex: 1; background: transparent; border: none; outline: none; color: #fff; font-size: 1.15rem; font-family: 'Sora', sans-serif; }
  .search-input-field input::placeholder { color: #64748b; }
  
  .close-search { background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); color: #94a3b8; width: 28px; height: 28px; display: flex; align-items: center; justify-content: center; border-radius: 6px; font-size: 1rem; cursor: pointer; transition: 0.2s; }
  .close-search:hover { background: rgba(255,255,255,0.1); color: #fff; }

  /* 7. ESTILOS DA LISTA DE RESULTADOS */
  .search-results-flow { padding: 15px 15px; max-height: 55vh; overflow-y: auto; scroll-behavior: smooth; }
  .search-results-flow::-webkit-scrollbar { width: 6px; }
  .search-results-flow::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 10px; }
  
  .search-hint { text-align: center; color: #64748b; font-size: 0.9rem; padding: 40px 20px; display: flex; flex-direction: column; align-items: center; gap: 15px; }
  .search-hint i { font-size: 2rem; opacity: 0.5; color: var(--primary); }
  .search-hint p { margin: 0; line-height: 1.5; }
  
  .search-section-title { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 1px; color: #64748b; margin: 15px 10px 8px; font-weight: 700; }
  
  .site-search-item { display: flex; align-items: center; padding: 12px 15px; background: transparent; border-radius: 10px; color: #dbe7f0; text-decoration: none; margin-bottom: 4px; transition: 0.1s ease; font-size: 0.95rem; border: 1px solid transparent; cursor: pointer; }
  .site-search-item > i:first-child { width: 24px; text-align: center; margin-right: 12px; color: #64748b; font-size: 1.1rem; }
  .site-search-item > span { flex: 1; }
  .arrow-icon { color: #64748b; opacity: 0; transform: translateX(-5px); transition: 0.2s; }
  
  .site-search-item:hover, .site-search-item.active { background: rgba(255,255,255,0.03); color: #fff; border-color: rgba(255,255,255,0.05); }
  .site-search-item:hover > i:first-child, .site-search-item.active > i:first-child { color: var(--primary, #ff6b2b); }
  .site-search-item:hover .arrow-icon, .site-search-item.active .arrow-icon { opacity: 1; transform: translateX(0); }

  mark { background: rgba(255, 107, 43, 0.15); color: #ff9a5c; border-radius: 3px; padding: 0 2px; font-weight: 700; }

  .highlight-enter { background: rgba(59, 130, 246, 0.05); margin-top: 10px; }
  .highlight-enter > i:first-child { color: #3b82f6 !important; }
  .highlight-enter kbd { background: rgba(255,255,255,0.1); padding: 2px 6px; border-radius: 4px; font-size: 0.75rem; font-family: monospace; color: #fff; }
  .highlight-enter:hover, .highlight-enter.active { background: rgba(59, 130, 246, 0.15); border-color: rgba(59, 130, 246, 0.2); }

  .api-result { justify-content: space-between; align-items: center; }
  .api-item-left { display: flex; align-items: center; }
  .api-icon { width: 24px; text-align: center; margin-right: 12px; font-size: 1.1rem; color: #94a3b8; }
  .api-title { font-weight: 600; color: #fff; }
  .api-sub { font-size: 0.75rem; color: #64748b; margin-top: 2px; }
  .api-status { font-size: 0.7rem; font-weight: 700; padding: 4px 10px; border-radius: 99px; border: 1px solid transparent; text-transform: uppercase; letter-spacing: 0.5px; }

  /* 8. SKELETON LOADING */
  .search-skeleton {
    height: 52px;
    margin: 8px 10px;
    border-radius: 10px;
    background: linear-gradient(90deg, rgba(255,255,255,0.02) 25%, rgba(255,255,255,0.06) 50%, rgba(255,255,255,0.02) 75%);
    background-size: 400% 100%;
    animation: shimmer 1.5s infinite ease-in-out;
  }
  @keyframes shimmer {
    0% { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }

  /* 9. RESPONSIVO (MOBILE) */
  .mobile-search-btn { display: none; background: rgba(255,107,43,0.1); color: #ff6b2b; border: 1px solid rgba(255,107,43,0.3); padding: 10px 15px; border-radius: 8px; width: 100%; text-align: left; cursor: pointer; font-weight: bold; }
  
  @media (max-width: 860px) {
    .nav-links { position: absolute; top: 100%; left: 0; right: 0; display: none; flex-direction: column; background: #0f1117; padding: 20px; border-bottom: 1px solid rgba(255,255,255,0.05); gap: 20px; }
    .nav-links.open { display: flex; }
    .menu-toggle { display: flex; }
    .nav-btn, .search-trigger { display: none; }
    .mobile-search-btn { display: block; }
    .search-overlay { padding-top: 5vh; }
    .search-input-field input { font-size: 1rem; }
  }
</style>
