---
import { Image } from 'astro:assets';
import logo from '../assets/fpagency.svg';
const base = import.meta.env.BASE_URL;
const baseUrl = base === '/' ? '' : base;
---

<header class="site-header" id="fp-header" data-base={baseUrl}>
  <div class="container nav">
    <a href={`${baseUrl}/`} class="brand" aria-label="FP Agency">
      <Image 
        src={logo} 
        alt="FP Agency Logo" 
        class="brand-logo" 
        width={46} 
        height={46} 
        loading="eager" 
        fetchpriority="high" 
      />
      <span>FP Agency</span>
    </a>

    <nav class="nav-links" id="navLinks">
      <a href={`${baseUrl}/#jornadas`}>Jornadas</a>
      <a href={`${baseUrl}/#programas`}>Programas</a>
      <a href={`${baseUrl}/#estrutura`}>Estrutura</a>
      <a href={`${baseUrl}/#resultados`}>Resultados</a>
      <a href={`${baseUrl}/#faq`}>FAQ</a>
      <a href={`${baseUrl}/#contato`}>Contato</a>
      
      <button class="mobile-search-btn" id="btn-mobile-search">
        <i class="fas fa-magnifying-glass"></i> Buscar
      </button>
    </nav>

    <div class="header-actions">
      <div class="search-trigger" id="btn-desktop-search">
        <i class="fas fa-magnifying-glass"></i>
        <span>Buscar...</span>
        <kbd>/</kbd>
      </div>
      <a href={`${baseUrl}/#contato`} class="btn-secondary nav-btn">Falar com a FP</a>
      <button class="menu-toggle" id="menuToggle" aria-label="Abrir menu">☰</button>
    </div>
  </div>

  <div id="global-search-modal" class="search-overlay">
    <div class="search-container">
      <div class="search-input-field">
        <i class="fas fa-magnifying-glass main-icon"></i>
        <input type="text" id="global-search-input" placeholder="Digite o nome, ID ou assunto e pressione ENTER..." autocomplete="off">
        <button class="close-search" id="btn-close-search">ESC</button>
      </div>
      
      <div class="search-results-flow" id="global-search-results">
        <div class="search-hint">
          Comece a digitar para ver resultados rápidos.<br>
          <strong>Pressione ENTER</strong> para ir à Central de Busca avançada.
        </div>
      </div>
    </div>
  </div>
</header>

<script>
  const API_URL = 'https://script.google.com/macros/s/AKfycbwGdUL3p5qf1GozVaGkE0Xx9epH4Pf5pJe59eennDsD34hX0P85HekUl_9p4HqzBzLS/exec';
  
  const headerEl = document.getElementById('fp-header');
  const basePath = headerEl ? headerEl.getAttribute('data-base') : '';

  const menuToggle = document.getElementById("menuToggle");
  const navLinks = document.getElementById("navLinks");
  
  if (menuToggle && navLinks) {
    menuToggle.addEventListener("click", () => {
      navLinks.classList.toggle("open");
    });
  }

  const searchModal = document.getElementById('global-search-modal');
  const searchInput = document.getElementById('global-search-input') as HTMLInputElement;

  const openGlobalSearch = () => {
    searchModal?.classList.add('active');
    setTimeout(() => searchInput?.focus(), 100);
    document.body.style.overflow = 'hidden'; 
  };

  const closeGlobalSearch = () => {
    searchModal?.classList.remove('active');
    document.body.style.overflow = '';
  };

  document.getElementById('btn-mobile-search')?.addEventListener('click', openGlobalSearch);
  document.getElementById('btn-desktop-search')?.addEventListener('click', openGlobalSearch);
  document.getElementById('btn-close-search')?.addEventListener('click', closeGlobalSearch);

  document.addEventListener('keydown', (e: KeyboardEvent) => {
    if (e.key === '/' && document.activeElement?.tagName !== 'INPUT') {
      e.preventDefault();
      openGlobalSearch();
    }
    if (e.key === 'Escape') closeGlobalSearch();
  });

  searchInput?.addEventListener('keydown', function(e: KeyboardEvent) {
    if (e.key === 'Enter') {
      const termo = searchInput.value.trim();
      if (termo.length >= 2) {
        window.location.href = `${basePath}/busca?q=${encodeURIComponent(termo)}`;
      }
    }
  });

  // Função para limpar acentos na busca
  function removeAcentos(str: string) {
    return str.normalize('NFD').replace(/[\u0300-\u036f]/g, '').toLowerCase();
  }

  let typingTimer: number | ReturnType<typeof setTimeout>;
  searchInput?.addEventListener('input', function() {
    clearTimeout(typingTimer);
    const termo = searchInput.value.trim();
    const termoFiltro = removeAcentos(termo);
    const container = document.getElementById('global-search-results');
    
    if (termo.length < 2) {
      if (container) container.innerHTML = '<div class="search-hint">Continue digitando ou pressione ENTER para busca profunda.</div>';
      return;
    }

    typingTimer = setTimeout(async () => {
      if (container) container.innerHTML = '<div class="searching-status"><i class="fas fa-spinner fa-spin"></i> Procurando rapidamente...</div>';
      
      // Base de páginas atualizada e completa
      const paginasSite = [
        { nome: "Regras e Níveis de Gamificação", url: `${basePath}/diretrizes`, tags: "regras niveis ouro prata bronze bônus metas diretrizes" },
        { nome: "Portal do Parceiro", url: `${basePath}/login`, tags: "login cadastro entrar conta cpf acesso" },
        { nome: "Carteira e Financeiro", url: `${basePath}/financeiro`, tags: "saque saldo dinheiro carteira extrato financeiro" },
        { nome: "Política de Privacidade", url: `${basePath}/politica-de-privacidade`, tags: "politica privacidade dados lgpd segurança legal" },
        { nome: "Termos de Serviço", url: `${basePath}/termos-de-servico`, tags: "termos serviço regras contrato legal uso" },
        { nome: "Aviso Legal", url: `${basePath}/aviso-legal`, tags: "aviso legal juridico direitos" },
        { nome: "Área do Recrutador", url: `${basePath}/recrutador`, tags: "recrutador equipe gerenciar convites painel" }
      ];

      let htmlResultados = '';
      
      // Filtro inteligente (ignora maiúsculas e acentos)
      const paginasFiltradas = paginasSite.filter(p => 
        removeAcentos(p.tags).includes(termoFiltro) || 
        removeAcentos(p.nome).includes(termoFiltro)
      );
      
      if(paginasFiltradas.length > 0) {
        htmlResultados += `<div class="search-section-title">Sugestões do Site</div>`;
        paginasFiltradas.forEach(p => {
          htmlResultados += `<a href="${p.url}" class="site-search-item"><i class="fas fa-link"></i> ${p.nome}</a>`;
        });
      }

      htmlResultados += `
        <a href="${basePath}/busca?q=${encodeURIComponent(termo)}" class="site-search-item highlight-enter">
          <i class="fas fa-level-down-alt fa-rotate-90"></i> Pesquisar "<strong>${termo}</strong>" na base de editores (Enter)
        </a>
      `;

      try {
        const payload = {
          action: 'buscarAprovacao',
          data: { termo: termo, filtro: 'all', page: 1, limit: 5 }
        };
        const response = await fetch(API_URL, {
          method: 'POST',
          body: JSON.stringify(payload)
        });
        
        const text = await response.text();
        const resJson = JSON.parse(text);

        if (resJson.success !== false && resJson.data && resJson.data.length > 0) {
          htmlResultados += `<div class="search-section-title" style="margin-top:15px">Status de Editores (Planilha)</div>`;
          resJson.data.forEach((item: any) => {
            htmlResultados += `
              <div class="site-search-item" style="display:flex; justify-content:space-between; cursor:default; pointer-events:none;">
                <span><i class="fas fa-user"></i> ${item.nomeCompleto} (${item.fonte})</span>
                <span style="color:#ff6b2b; font-size:0.8rem; font-weight:bold">${item.statusResultado}</span>
              </div>`;
          });
        }
      } catch (e) {
        console.log("Busca rápida na planilha não retornou resultados ou falhou.", e);
      }

      if (container) container.innerHTML = htmlResultados;
    }, 400); 
  });
</script>

<style>
  .site-header { position: sticky; top: 0; z-index: 1000; padding: 16px 0; backdrop-filter: blur(16px); background: rgba(15, 17, 23, 0.85); border-bottom: 1px solid rgba(255, 255, 255, 0.06); font-family: system-ui, sans-serif; }
  .container { width: min(calc(100% - 32px), 1220px); margin: 0 auto; }
  .nav { display: flex; align-items: center; justify-content: space-between; gap: 20px; }
  .brand { display: inline-flex; align-items: center; gap: 14px; font-weight: 900; color: #fff; text-decoration: none; font-size: 1.04rem;}
  .brand-logo { width: 46px; height: 46px; object-fit: contain; }
  
  .nav-links { display: flex; align-items: center; gap: 24px; color: #dbe7f0; font-weight: 600; font-size: 0.95rem; }
  .nav-links a { text-decoration: none; color: inherit; position: relative; }
  .nav-links a:hover { color: #ff6b2b; }
  .mobile-search-btn { display: none; background: rgba(255,107,43,0.1); color: #ff6b2b; border: 1px solid rgba(255,107,43,0.3); padding: 10px 15px; border-radius: 8px; width: 100%; text-align: left; cursor: pointer; font-weight: bold; }

  .header-actions { display: flex; align-items: center; gap: 15px; }
  
  .search-trigger { display: flex; align-items: center; gap: 10px; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); padding: 8px 16px; border-radius: 99px; color: #94a3b8; font-size: 0.9rem; cursor: pointer; transition: 0.2s; }
  .search-trigger:hover { background: rgba(255,255,255,0.1); color: #fff; }
  .search-trigger kbd { background: rgba(255,255,255,0.1); padding: 2px 6px; border-radius: 4px; font-size: 0.75rem; font-family: monospace; }

  .btn-secondary { background: rgba(255,255,255,0.05); color: #fff; border: 1px solid rgba(255,255,255,0.1); padding: 10px 22px; border-radius: 99px; font-weight: 700; text-decoration: none; transition: 0.2s; }
  .btn-secondary:hover { background: #fff; color: #000; }
  
  .menu-toggle { display: none; background: transparent; border: 0; color: #fff; font-size: 1.8rem; cursor: pointer; }

  .search-overlay { position: fixed; inset: 0; background: rgba(8, 10, 15, 0.85); backdrop-filter: blur(8px); z-index: 9999; display: flex; justify-content: center; align-items: flex-start; padding-top: 10vh; opacity: 0; pointer-events: none; transition: 0.3s ease; }
  .search-overlay.active { opacity: 1; pointer-events: all; }
  .search-container { width: 90%; max-width: 650px; background: #181c27; border: 1px solid #2a3048; border-radius: 20px; box-shadow: 0 20px 50px rgba(0,0,0,0.5); overflow: hidden; transform: translateY(-20px); transition: 0.3s ease; }
  .search-overlay.active .search-container { transform: translateY(0); }
  
  .search-input-field { display: flex; align-items: center; padding: 20px 25px; border-bottom: 1px solid #2a3048; background: #1e2332; }
  .main-icon { font-size: 1.3rem; color: #ff6b2b; margin-right: 15px; }
  .search-input-field input { flex: 1; background: transparent; border: none; outline: none; color: #fff; font-size: 1.2rem; font-family: 'Sora', sans-serif; }
  .search-input-field input::placeholder { color: #64748b; }
  .close-search { background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); color: #94a3b8; padding: 5px 10px; border-radius: 6px; font-size: 0.7rem; cursor: pointer; transition: 0.2s; }
  .close-search:hover { background: #ef4444; color: white; border-color: #ef4444; }

  .search-results-flow { padding: 20px 25px; max-height: 60vh; overflow-y: auto; }
  .search-hint { text-align: center; color: #64748b; font-size: 0.9rem; padding: 20px 0; }
  .searching-status { color: #ff6b2b; font-weight: bold; font-size: 0.9rem; display: flex; align-items: center; gap: 10px; }
  
  .search-section-title { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 1px; color: #64748b; margin-bottom: 10px; font-weight: bold; }
  .site-search-item { display: block; padding: 12px 15px; background: rgba(255,255,255,0.03); border-radius: 10px; color: #dbe7f0; text-decoration: none; margin-bottom: 8px; transition: 0.2s; font-size: 0.95rem; border: 1px solid transparent; }
  .site-search-item i { margin-right: 8px; color: #ff6b2b; }
  .site-search-item:hover { background: rgba(255,107,43,0.1); border-color: rgba(255,107,43,0.3); color: #fff; transform: translateX(5px); }
  .highlight-enter { margin-top: 15px; background: rgba(59, 130, 246, 0.1); border: 1px solid rgba(59, 130, 246, 0.3); color: #60a5fa; }
  .highlight-enter i { color: #60a5fa; }
  .highlight-enter:hover { background: #3b82f6; color: #fff; border-color: #3b82f6; }
  .highlight-enter:hover i { color: #fff; }

  @media (max-width: 860px) {
    .nav-links { position: absolute; top: 100%; left: 0; right: 0; display: none; flex-direction: column; background: #0f1117; padding: 20px; border-bottom: 1px solid #2a3048; gap: 20px; }
    .nav-links.open { display: flex; }
    .menu-toggle { display: block; }
    .nav-btn, .search-trigger { display: none; }
    .mobile-search-btn { display: block; }
    .search-input-field input { font-size: 1rem; }
  }
</style>