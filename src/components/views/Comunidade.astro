---
// src/components/views/Comunidade.astro
---

<div class="custom-modal-overlay" id="modalPostFeed">
  <div class="custom-modal-card">
    <div class="modal-icon-wrapper" style="background:#fff7ed;color:#ea580c">
      <i class="fas fa-share-square"></i>
    </div>
    <h3 class="custom-modal-title">Nova Publicação</h3>
    <p class="custom-modal-text" style="margin-bottom:15px">Compartilhe seu vídeo ou live do Kwai com a comunidade.</p>
    
    <form id="formPostFeed" style="text-align:left">
      <label>URL do Kwai</label>
      <input type="url" id="postUrl" placeholder="Cole o link do vídeo ou live" required>
      
      <label>Categoria</label>
      <select id="postCategoria" required>
        <option value="Notícias">📰 Notícias / FTV</option>
        <option value="Games">🎮 Games</option>
        <option value="Humor">😂 Humor</option>
        <option value="Daily">📱 Daily / Vlog</option>
        <option value="Live">🔴 Live (Ao Vivo)</option>
      </select>
      
      <div class="modal-btn-group modal-stack" style="margin-top:10px">
        <button type="submit" class="btn-confirm" id="btnSubmitPost">Publicar</button>
        <button type="button" class="btn-cancel" onclick="fecharModalPost()">Cancelar</button>
      </div>
    </form>
  </div>
</div>

<div id="view-Comunidade" class="view view-container view-public" data-view="Comunidade" data-public="true">
  <div class="feed-view">
    
    <div class="feed-header">
      <div class="feed-header-inner">
        <h1 class="feed-title">Comunidade <span>FP</span></h1>
        <p class="feed-subtitle">Inspire-se, compartilhe seus vídeos e acompanhe as lives dos parceiros da agência.</p>
        <button class="btn-publicar" onclick="abrirModalPost()">
          <i class="fas fa-plus"></i> Publicar Vídeo
        </button>
      </div>
    </div>

    <div class="feed-top10-wrapper">
      <div class="feed-section-title"><i class="fas fa-fire" style="color:#ef4444"></i> Em Alta (Top 10)</div>
      <div class="top10-scroll" id="feedTop10List">
        <div style="padding:20px;color:#94a3b8;font-size:0.85rem;">
          <i class="fas fa-circle-notch fa-spin"></i> Carregando Top 10...
        </div>
      </div>
    </div>

    <div class="feed-filters-wrapper">
      <div class="feed-filters" id="feedFilterButtons">
        <button class="feed-filter active" onclick="filtrarFeed('Todos', this)">Tudo</button>
        <button class="feed-filter" onclick="filtrarFeed('Live', this)">🔴 Lives</button>
        <button class="feed-filter" onclick="filtrarFeed('Notícias', this)">Notícias</button>
        <button class="feed-filter" onclick="filtrarFeed('Games', this)">Games</button>
        <button class="feed-filter" onclick="filtrarFeed('Humor', this)">Humor</button>
        <button class="feed-filter" onclick="filtrarFeed('Daily', this)">Daily</button>
      </div>
    </div>

    <div class="feed-grid" id="feedGrid">
      <div style="text-align:center;padding:50px;color:#94a3b8;grid-column:1/-1;">
        <i class="fas fa-circle-notch fa-spin fa-2x"></i>
        <p style="margin-top:10px">Carregando comunidade...</p>
      </div>
    </div>

  </div>
</div>

<script is:inline>
  let feedDataRaw = [];

  function abrirModalPost() {
    if (!hasValidSessionToken()) {
      globalAlert('Acesso Restrito', 'Você precisa fazer login para publicar na comunidade.', 'warning');
      nav('Login');
      return;
    }
    document.getElementById('modalPostFeed').classList.add('active');
    document.getElementById('postUrl').value = '';
  }

  function fecharModalPost() {
    document.getElementById('modalPostFeed').classList.remove('active');
  }

  async function enviarPost() {
    const token = sessionStorage.getItem('idToken');
    const urlKwai = document.getElementById('postUrl').value;
    const categoria = document.getElementById('postCategoria').value;
    
    if (!urlKwai || !urlKwai.includes('kwai')) {
      globalAlert('Erro', 'Por favor, cole um link válido do Kwai.', 'error');
      return;
    }

    const btn = document.getElementById('btnSubmitPost');
    btn.disabled = true;
    btn.innerText = 'Enviando...';
    showLoader();

    try {
      const res = await gsRun('salvarPostFeed', { idToken: token, url: urlKwai, categoria: categoria });
      if (res.success) {
        fecharModalPost();
        globalAlert('Publicado!', 'Seu vídeo foi enviado para a comunidade.', 'success');
        loadComunidade(); 
      } else {
        globalAlert('Ops!', res.msg, 'error');
      }
    } catch(e) {
      globalAlert('Erro', 'Ocorreu um erro ao publicar.', 'error');
    } finally {
      hideLoader();
      btn.disabled = false;
      btn.innerText = 'Publicar';
    }
  }

  async function loadComunidade() {
    const feedGrid = document.getElementById('feedGrid');
    const top10Container = document.getElementById('feedTop10List');
    
    if (feedGrid.innerHTML.includes('fa-circle-notch')) showLoader();
    
    try {
      const resFeed = await gsRun('getFeedData', {});
      if (resFeed.success) {
        feedDataRaw = resFeed.data || [];
        renderFeedCards(feedDataRaw);
      } else {
        feedGrid.innerHTML = `<p style="text-align:center;width:100%;color:#94a3b8">Não foi possível carregar a comunidade.</p>`;
      }

      const resRank = await gsRun('getRankingData', {});
      if (resRank.success && resRank.data && resRank.data.length > 0) {
        const top10 = resRank.data.slice(0, 10);
        top10Container.innerHTML = top10.map((u, i) => {
          const nome = (u.nome || 'Usuário').split(' ')[0];
          const avatar = (u.avatar && u.avatar.indexOf('http') === 0) 
              ? u.avatar 
              : `https://ui-avatars.com/api/?name=${encodeURIComponent(nome)}&background=fed7aa&color=c2410c&bold=true&size=256`;
          
          return `
            <div class="top10-item">
              <div class="top10-avatar">
                <img src="${escapeHtml(avatar)}" alt="${escapeHtml(nome)}" loading="lazy">
                <div class="top10-badge">${i+1}</div>
              </div>
              <div class="top10-name">${escapeHtml(nome)}</div>
            </div>
          `;
        }).join('');
      } else {
        top10Container.innerHTML = `<p style="padding:20px;color:#94a3b8;font-size:0.85rem;">Ranking ainda em apuração.</p>`;
      }
    } catch (error) {
      console.error(error);
    } finally {
      hideLoader();
    }
  }

  function renderFeedCards(dataArray) {
    const grid = document.getElementById('feedGrid');
    if (!dataArray || dataArray.length === 0) {
      grid.innerHTML = `
        <div style="text-align:center;grid-column:1/-1;padding:40px 20px;">
          <i class="fas fa-video fa-3x" style="color:#3d4d7a;margin-bottom:15px;opacity:0.5"></i>
          <h3 style="color:#e2e8f0;font-size:1.2rem;margin-bottom:10px">Nenhuma publicação ainda</h3>
          <p style="color:#64748b;font-size:0.9rem">Seja o primeiro a compartilhar seu conteúdo com a agência!</p>
        </div>`;
      return;
    }

    grid.innerHTML = dataArray.map(post => {
      let embedHtml = '';
      const videoIdMatch = post.url.match(/video\/([a-zA-Z0-9_]+)/);
      
      if (videoIdMatch && videoIdMatch[1]) {
        const videoId = videoIdMatch[1];
        embedHtml = `<iframe src="https://k.kwai.com/video/${videoId}" frameborder="0" allowfullscreen class="kwai-iframe"></iframe>`;
      } else {
        embedHtml = `
          <a href="${post.url}" target="_blank" rel="noopener noreferrer" class="feed-link-card">
            <div class="play-btn"><i class="fas fa-play"></i></div>
            <span>Assistir no Kwai</span>
          </a>
        `;
      }

      const avatar = (post.avatar && post.avatar.indexOf('http') === 0) 
            ? post.avatar 
            : `https://ui-avatars.com/api/?name=${encodeURIComponent(post.nome)}&background=fed7aa&color=c2410c&bold=true&size=256`;

      return `
        <div class="feed-card">
          <div class="feed-card-header">
            <img src="${escapeHtml(avatar)}" alt="Avatar">
            <div class="feed-card-info">
              <strong>${escapeHtml(post.nome.split(' ')[0])}</strong>
              <span>${escapeHtml(post.dataHora || 'Recentemente')}</span>
            </div>
            <div class="feed-card-tag">${escapeHtml(post.categoria)}</div>
          </div>
          <div class="feed-card-media">
            ${embedHtml}
          </div>
        </div>
      `;
    }).join('');
  }

  function filtrarFeed(categoria, btnElement) {
    document.querySelectorAll('.feed-filter').forEach(btn => btn.classList.remove('active'));
    btnElement.classList.add('active');
    
    if (categoria === 'Todos') {
      renderFeedCards(feedDataRaw);
    } else {
      const filtrado = feedDataRaw.filter(p => p.categoria === categoria);
      renderFeedCards(filtrado);
    }
  }

  document.getElementById('formPostFeed')?.addEventListener('submit', (event) => {
    event.preventDefault();
    enviarPost();
  });
</script>

<style>
  .feed-view {
    font-family: 'Sora', sans-serif;
    background: transparent;
    color: #e2e8f0;
    overflow-x: hidden;
    position: relative;
    padding-bottom: 80px;
    min-height: 100dvh;
  }

  .feed-header {
    position: relative;
    padding: 40px 20px 30px;
    text-align: center;
    overflow: hidden;
  }
  .feed-header::before {
    content: '';
    position: absolute;
    top: -40px;
    left: 50%;
    transform: translateX(-50%);
    width: 600px;
    height: 300px;
    background: radial-gradient(ellipse, rgba(255,107,43,.15) 0%, transparent 65%);
    pointer-events: none;
  }
  .feed-header-inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .feed-title {
    font-size: clamp(1.8rem, 5vw, 2.8rem);
    font-weight: 900;
    line-height: 1.1;
    margin-bottom: 10px;
    color: #fff;
  }
  .feed-title span {
    background: linear-gradient(135deg, #ff6b2b, #ff9a5c);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .feed-subtitle {
    font-size: .95rem;
    color: #64748b;
    max-width: 480px;
    margin: 0 auto 24px;
    line-height: 1.6;
  }
  .btn-publicar {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #ff6b2b;
    color: #fff;
    font-family: 'Sora', sans-serif;
    font-weight: 700;
    font-size: .9rem;
    padding: 12px 24px;
    border-radius: 99px;
    border: none;
    cursor: pointer;
    box-shadow: 0 6px 20px rgba(255,107,43,.25);
    transition: transform .2s;
  }
  .btn-publicar:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(255,107,43,.35);
  }

  .feed-top10-wrapper {
    padding: 0 20px;
    margin-bottom: 30px;
    max-width: 960px;
    margin-left: auto;
    margin-right: auto;
  }
  .feed-section-title {
    font-size: 1.1rem;
    font-weight: 800;
    color: #fff;
    margin-bottom: 15px;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .top10-scroll {
    display: flex;
    gap: 16px;
    overflow-x: auto;
    padding-bottom: 10px;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }
  .top10-scroll::-webkit-scrollbar { display: none; }
  
  .top10-item {
    scroll-snap-align: start;
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 72px;
    flex-shrink: 0;
  }
  .top10-avatar {
    position: relative;
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: #1e2332;
    padding: 3px;
    background-clip: content-box;
    border: 2px solid #ff6b2b;
    box-shadow: 0 4px 12px rgba(255,107,43,.2);
  }
  .top10-badge {
    position: absolute;
    bottom: -6px;
    left: 50%;
    transform: translateX(-50%);
    background: #ff6b2b;
    color: #fff;
    font-size: 0.65rem;
    font-weight: 800;
    padding: 2px 8px;
    border-radius: 10px;
    border: 2px solid #0f1117;
  }
  .top10-item:nth-child(1) .top10-avatar { border-color: #fbbf24; box-shadow: 0 4px 12px rgba(251,191,36,.3); }
  .top10-item:nth-child(1) .top10-badge { background: #fbbf24; color: #78350f; }
  .top10-item:nth-child(2) .top10-avatar { border-color: #94a3b8; }
  .top10-item:nth-child(2) .top10-badge { background: #94a3b8; color: #1e293b; }
  .top10-item:nth-child(3) .top10-avatar { border-color: #b45309; }
  .top10-item:nth-child(3) .top10-badge { background: #b45309; color: #fff; }
  .top10-name {
    margin-top: 12px;
    font-size: 0.75rem;
    color: #cbd5e1;
    font-weight: 600;
    width: 100%;
    text-align: center;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .feed-filters-wrapper {
    position: sticky;
    top: 0;
    z-index: 10;
    background: rgba(15, 17, 23, .9);
    backdrop-filter: blur(10px);
    padding: 15px 20px;
    border-bottom: 1px solid rgba(255,255,255,.05);
    margin-bottom: 20px;
  }
  .feed-filters {
    display: flex;
    gap: 10px;
    overflow-x: auto;
    scrollbar-width: none;
    max-width: 960px;
    margin: 0 auto;
  }
  .feed-filters::-webkit-scrollbar { display: none; }
  .feed-filter {
    background: rgba(255,255,255,.05);
    border: 1px solid rgba(255,255,255,.1);
    color: #94a3b8;
    padding: 8px 18px;
    border-radius: 99px;
    font-size: 0.8rem;
    font-weight: 600;
    cursor: pointer;
    white-space: nowrap;
    transition: 0.2s;
  }
  .feed-filter.active {
    background: rgba(255,107,43,.15);
    border-color: #ff6b2b;
    color: #ff6b2b;
  }

  .feed-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 20px;
    padding: 0 20px 40px;
    max-width: 960px;
    margin: 0 auto;
  }
  .feed-card {
    background: #181c27;
    border: 1px solid #2a3048;
    border-radius: 16px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .feed-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 30px rgba(0,0,0,0.4);
    border-color: #3d4d7a;
  }
  .feed-card-header {
    display: flex;
    align-items: center;
    padding: 15px;
    border-bottom: 1px solid rgba(255,255,255,.03);
  }
  .feed-card-header img {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    object-fit: cover;
    margin-right: 12px;
    border: 2px solid #3d4d7a;
  }
  .feed-card-info {
    flex: 1;
    display: flex;
    flex-direction: column;
  }
  .feed-card-info strong {
    color: #e2e8f0;
    font-size: 0.9rem;
    font-weight: 700;
  }
  .feed-card-info span {
    color: #64748b;
    font-size: 0.7rem;
    margin-top: 2px;
    font-family: var(--mono);
  }
  .feed-card-tag {
    background: rgba(255,107,43,.15);
    color: #ff9a5c;
    padding: 4px 10px;
    border-radius: 8px;
    font-size: 0.7rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .feed-card-media {
    position: relative;
    width: 100%;
    aspect-ratio: 9/16;
    background: #0f1117;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .kwai-iframe {
    width: 100%;
    height: 100%;
    border: none;
  }
  .feed-link-card {
    text-decoration: none;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #1e2332, #0f1117);
  }
  .play-btn {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    background: rgba(255,107,43,0.2);
    border: 2px solid #ff6b2b;
    color: #ff6b2b;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    margin-bottom: 15px;
    transition: transform 0.2s;
  }
  .feed-link-card:hover .play-btn {
    transform: scale(1.1);
    background: #ff6b2b;
    color: #fff;
  }
  .feed-link-card span {
    color: #cbd5e1;
    font-weight: 600;
    font-size: 0.9rem;
  }
</style>
