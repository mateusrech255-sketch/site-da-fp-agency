---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import videoList from '../../data/videos.json';

// Definimos o formato do vídeo para o TypeScript não reclamar do tipo 'any'
interface Video {
  id: string;
  slug: string;
  title: string;
  description: string;
  thumbnail: string;
}
---

<Layout title="Treinamento Kwai Cut | FP Agency">
  <Header />

  <main class="page-wrapper">
    <header class="page-header">
      <h1>Portal de Treinamento</h1>
      <p>Desenvolva suas habilidades de edição com o método FP Agency.</p>
    </header>

    <section class="video-grid">
      {/* Indicamos ao TypeScript que cada item da lista segue a interface Video */}
      {(videoList as Video[]).map((video) => (
        <a href={`${import.meta.env.BASE_URL}/treinamento/${video.slug}`} class="video-card">
          <div class="thumbnail-container">
            <img src={video.thumbnail} alt={video.title} loading="lazy" />
            <div class="play-overlay">
              <div class="play-button">▶</div>
            </div>
          </div>
          <div class="video-info">
            <h2>{video.title}</h2>
            <p>{video.description}</p>
          </div>
        </a>
      ))}
    </section>
  </main>

  <Footer />
</Layout>

<style>
  .page-wrapper { max-width: 1200px; margin: 0 auto; padding: 3rem 1.5rem; font-family: system-ui, sans-serif; }
  .page-header { text-align: center; margin-bottom: 3rem; }
  .page-header h1 { font-size: 2.5rem; color: #fff; margin-bottom: 0.5rem; }
  .page-header p { color: #a1a1aa; }
  
  .video-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 2rem; }
  
  .video-card { background-color: #18181b; border: 1px solid #27272a; border-radius: 12px; overflow: hidden; text-decoration: none; transition: all 0.2s ease; display: flex; flex-direction: column; }
  .video-card:hover { transform: translateY(-5px); border-color: #ff4500; box-shadow: 0 10px 25px rgba(255, 69, 0, 0.15); }
  
  .thumbnail-container { position: relative; aspect-ratio: 16 / 9; overflow: hidden; background: #000; }
  .thumbnail-container img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.3s; }
  .video-card:hover .thumbnail-container img { transform: scale(1.05); }
  
  .play-overlay { position: absolute; inset: 0; background: rgba(0,0,0,0.4); display: flex; align-items: center; justify-content: center; opacity: 0; transition: opacity 0.2s; }
  .video-card:hover .play-overlay { opacity: 1; }
  .play-button { background: #ff4500; color: #fff; width: 50px; height: 50px; border-radius: 50%; display: flex; align-items: center; justify-content: center; padding-left: 4px; }
  
  .video-info { padding: 1.5rem; flex-grow: 1; }
  .video-info h2 { font-size: 1.2rem; color: #fff; margin: 0 0 0.5rem 0; }
  .video-info p { font-size: 0.9rem; color: #a1a1aa; margin: 0; line-height: 1.4; }
</style>