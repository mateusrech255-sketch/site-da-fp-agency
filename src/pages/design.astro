---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Serviços de Design - FP Agency">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/remixicon@3.5.0/fonts/remixicon.css" rel="stylesheet">

  <div class="fp-agency-wrapper">
    <Header />

    <main class="sw">
      <div class="sw-hero">
        <div class="sw-eyebrow"><i class="ri-sparkling-line"></i> Design Profissional</div>
        <h1 class="sw-hero-title">Seu negócio merece<br>um visual <span>incrível</span></h1>
        <p class="sw-hero-sub">Criamos peças visuais que vendem, encantam e geram resultados reais para o seu negócio.</p>
        <a href="https://wa.me/message/3YJWHJM7UOR6C1" target="_blank" rel="noopener noreferrer" class="sw-hero-cta">
          <i class="ri-whatsapp-line"></i> Solicitar Orçamento Grátis
        </a>
      </div>

      <div class="sw-trust" aria-label="Diferenciais">
        <div class="sw-trust-band">
          <div class="sw-trust-track">
            <div class="sw-trust-group">
              <span class="sw-trust-chip"><i class="ri-time-line"></i> Entrega no prazo</span>
              <span class="sw-trust-chip"><i class="ri-refresh-line"></i> Revisões incluídas</span>
              <span class="sw-trust-chip"><i class="ri-file-download-line"></i> Arquivo editável</span>
              <span class="sw-trust-chip"><i class="ri-whatsapp-line"></i> Suporte via WhatsApp</span>
              <span class="sw-trust-chip"><i class="ri-magic-line"></i> 100% personalizado</span>
              <span class="sw-trust-chip"><i class="ri-shield-check-line"></i> Qualidade garantida</span>
              <span class="sw-trust-chip"><i class="ri-palette-line"></i> Design exclusivo</span>
            </div>
            <div class="sw-trust-group" aria-hidden="true">
              <span class="sw-trust-chip"><i class="ri-time-line"></i> Entrega no prazo</span>
              <span class="sw-trust-chip"><i class="ri-refresh-line"></i> Revisões incluídas</span>
              <span class="sw-trust-chip"><i class="ri-file-download-line"></i> Arquivo editável</span>
              <span class="sw-trust-chip"><i class="ri-whatsapp-line"></i> Suporte via WhatsApp</span>
              <span class="sw-trust-chip"><i class="ri-magic-line"></i> 100% personalizado</span>
              <span class="sw-trust-chip"><i class="ri-shield-check-line"></i> Qualidade garantida</span>
              <span class="sw-trust-chip"><i class="ri-palette-line"></i> Design exclusivo</span>
            </div>
          </div>
        </div>
      </div>

      <div class="sw-grid">

        <div class="sw-card featured">
          <span class="sw-featured-tag">⚡ Mais Pedido</span>
          <div class="sw-card-icon"><i class="ri-slideshow-line"></i></div>
          <div class="sw-cat"><span class="sw-cat-dot"></span> Design Corporativo</div>
          <h3 class="sw-title">Apresentação em Slides</h3>
          <p class="sw-desc">Layouts profissionais e impactantes para conquistar clientes, investidores ou avaliadores.</p>
          <div class="sw-price-box">
            <div class="sw-price-row">
              <span class="sw-price-label">Básico</span>
              <span class="sw-price-val">R$ 60,00</span>
            </div>
            <div class="sw-price-row">
              <span class="sw-price-label">Plus</span>
              <span class="sw-price-val">R$ 120,00</span>
            </div>
            <div class="sw-price-row">
              <span class="sw-price-label">Pro</span>
              <span class="sw-price-val">R$ 180,00</span>
            </div>
          </div>
          <a href="https://wa.me/message/3YJWHJM7UOR6C1" target="_blank" rel="noopener noreferrer" class="sw-card-btn">
            <i class="ri-whatsapp-line"></i> Pedir Agora
          </a>
        </div>

        <div class="sw-card">
          <div class="sw-card-icon"><i class="ri-megaphone-line"></i></div>
          <div class="sw-cat"><span class="sw-cat-dot"></span> Marketing</div>
          <h3 class="sw-title">Panfleto</h3>
          <p class="sw-desc">Ideal para promoções, lançamentos de produtos ou divulgação escolar. Chama atenção na hora certa.</p>
          <div class="sw-price-box">
            <div class="sw-price-single">R$ 25,00</div>
          </div>
          <a href="https://wa.me/message/3YJWHJM7UOR6C1" target="_blank" rel="noopener noreferrer" class="sw-card-btn">
            <i class="ri-whatsapp-line"></i> Pedir Agora
          </a>
        </div>

        <div class="sw-card">
          <div class="sw-card-icon"><i class="ri-gift-line"></i></div>
          <div class="sw-cat"><span class="sw-cat-dot"></span> Eventos</div>
          <h3 class="sw-title">Convite Digital</h3>
          <p class="sw-desc">Casamentos, aniversários e chás de fraldas. Envie direto pelo WhatsApp e surpreenda seus convidados.</p>
          <div class="sw-price-box">
            <div class="sw-price-single">R$ 35,00</div>
          </div>
          <a href="https://wa.me/message/3YJWHJM7UOR6C1" target="_blank" rel="noopener noreferrer" class="sw-card-btn">
            <i class="ri-whatsapp-line"></i> Pedir Agora
          </a>
        </div>

        <div class="sw-card">
          <div class="sw-card-icon"><i class="ri-briefcase-line"></i></div>
          <div class="sw-cat"><span class="sw-cat-dot"></span> Carreira</div>
          <h3 class="sw-title">Currículo Digital</h3>
          <p class="sw-desc">Se destaque no mercado de trabalho com um currículo moderno. Primeiro emprego ou recolocação profissional.</p>
          <div class="sw-price-box">
            <div class="sw-price-single">R$ 120,00</div>
          </div>
          <a href="https://wa.me/message/3YJWHJM7UOR6C1" target="_blank" rel="noopener noreferrer" class="sw-card-btn">
            <i class="ri-whatsapp-line"></i> Pedir Agora
          </a>
        </div>

        <div class="sw-card">
          <div class="sw-card-icon"><i class="ri-book-open-line"></i></div>
          <div class="sw-cat"><span class="sw-cat-dot"></span> Vendas</div>
          <h3 class="sw-title">Catálogo Digital</h3>
          <p class="sw-desc">Divulgue seus produtos com estilo. Roupas, calçados, joias e muito mais — tudo organizado e bonito.</p>
          <div class="sw-price-box">
            <div class="sw-price-row">
              <span class="sw-price-label">Até 20 páginas</span>
              <span class="sw-price-val">R$ 150,00</span>
            </div>
            <div class="sw-price-row">
              <span class="sw-price-label">Até 40 páginas</span>
              <span class="sw-price-val">R$ 280,00</span>
            </div>
            <div class="sw-price-row">
              <span class="sw-price-label">Até 60 páginas</span>
              <span class="sw-price-val">R$ 400,00</span>
            </div>
            <div class="sw-price-row">
              <span class="sw-price-label">Até 100 páginas</span>
              <span class="sw-price-val">R$ 550,00</span>
            </div>
          </div>
          <a href="https://wa.me/message/3YJWHJM7UOR6C1" target="_blank" rel="noopener noreferrer" class="sw-card-btn">
            <i class="ri-whatsapp-line"></i> Pedir Agora
          </a>
        </div>

        <div class="sw-card">
          <div class="sw-card-icon"><i class="ri-restaurant-line"></i></div>
          <div class="sw-cat"><span class="sw-cat-dot"></span> Gastronomia</div>
          <h3 class="sw-title">Cardápio</h3>
          <p class="sw-desc">Restaurantes, padarias, lanchonetes e bares. Um cardápio bonito vende mais — deixe a gente provar.</p>
          <div class="sw-price-box">
            <div class="sw-price-single">R$ 50,00</div>
            <span class="sw-price-note">por página — você escolhe a quantidade</span>
          </div>
          <a href="https://wa.me/message/3YJWHJM7UOR6C1" target="_blank" rel="noopener noreferrer" class="sw-card-btn">
            <i class="ri-whatsapp-line"></i> Pedir Agora
          </a>
        </div>

      </div>

      <div class="sw-bottom-cta">
        <p>Não encontrou o que precisa? <strong>Fale com a gente pelo WhatsApp</strong> e criamos uma solução personalizada para você.</p>
        <a href="https://wa.me/message/3YJWHJM7UOR6C1" target="_blank" rel="noopener noreferrer" class="sw-hero-cta">
          <i class="ri-whatsapp-line"></i> Falar com um Designer
        </a>
      </div>

    </main>

    <Footer />
  </div>
</Layout>

<style>
  :root {
    --bg:           #0f1117;
    --bg-card:      #181c27;
    --bg-input:     #1e2332;
    --border:       #2a3048;
    --border-hover: #3d4d7a;
    --orange:       #ff6b2b;
    --orange-dim:   #ff6b2b1a;
    --orange-glow:  rgba(255,107,43,.2);
    --green:        #22c55e;
    --green-dim:    #22c55e1a;
    --text:         #e2e8f0;
    --text-muted:   #64748b;
    --text-faint:   #2a3048;
    --mono:         'JetBrains Mono', monospace;
    --radius:       14px;
    --radius-lg:    20px;
  }

  .fp-agency-wrapper {
    display: flex;
    flex-direction: column;
    min-height: 100dvh;
    width: 100%;
    background: var(--bg);
  }

  .sw {
    flex: 1;
    font-family: 'Sora', sans-serif;
    background: transparent;
    color: var(--text);
    padding: 0 0 80px;
    position: relative;
    overflow-x: hidden;
  }

  /* ── HERO ── */
  .sw-hero {
    text-align: center;
    padding: 52px 20px 48px;
    position: relative;
  }
  .sw-hero::before {
    content: '';
    position: absolute;
    top: 0; left: 50%; transform: translateX(-50%);
    width: 600px; height: 280px;
    background: radial-gradient(ellipse, var(--orange-glow) 0%, transparent 68%);
    pointer-events: none;
  }
  .sw-eyebrow {
    display: inline-flex; align-items: center; gap: 7px;
    font-family: var(--mono); font-size: .72rem;
    color: var(--orange); letter-spacing: .1em; text-transform: uppercase;
    background: var(--orange-dim); padding: 5px 14px;
    border-radius: 99px; border: 1px solid var(--orange-glow);
    margin-bottom: 20px;
  }
  .sw-hero-title {
    font-size: clamp(1.7rem, 4.5vw, 2.8rem);
    font-weight: 800; line-height: 1.1;
    letter-spacing: -.025em; margin-bottom: 14px;
  }
  .sw-hero-title span { color: var(--orange); }
  .sw-hero-sub {
    font-size: .95rem; color: var(--text-muted);
    max-width: 460px; margin: 0 auto 30px;
    line-height: 1.65;
  }
  .sw-hero-cta {
    display: inline-flex; align-items: center; gap: 9px;
    background: #25D366; color: #fff;
    padding: 14px 28px; border-radius: 99px;
    font-weight: 700; font-size: .95rem;
    text-decoration: none;
    box-shadow: 0 6px 24px rgba(37,211,102,.25);
    transition: transform .18s, box-shadow .18s;
  }
  .sw-hero-cta:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 30px rgba(37,211,102,.35);
    color: #fff;
  }
  .sw-hero-cta i { font-size: 1.2rem; }

  /* ── TRUST MARQUEE ── */
  .sw-trust {
    width: 100%;
    overflow: hidden;
    margin-bottom: 48px;
  }
  .sw-trust-band {
    padding: 18px 0;
    border-top: 1px solid rgba(255,255,255,.07);
    border-bottom: 1px solid rgba(255,255,255,.07);
    display: flex;
    overflow: hidden;
    -webkit-mask-image: linear-gradient(to right, transparent, black 12%, black 88%, transparent);
    mask-image: linear-gradient(to right, transparent, black 12%, black 88%, transparent);
  }
  .sw-trust-track {
    display: flex;
    width: max-content;
    animation: sw-marquee 22s linear infinite;
    will-change: transform;
  }
  .sw-trust-track:hover { animation-play-state: paused; }
  .sw-trust-group {
    display: flex;
    gap: 12px;
    padding-right: 12px;
  }
  .sw-trust-chip {
    min-height: 42px;
    padding: 0 20px;
    border-radius: 99px;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border: 1px solid rgba(255,255,255,.09);
    background: rgba(255,255,255,.04);
    color: #e2e8f0;
    font-family: 'Sora', sans-serif;
    font-size: .82rem;
    font-weight: 500;
    white-space: nowrap;
    backdrop-filter: blur(6px);
  }
  .sw-trust-chip i {
    font-size: 1rem;
    background: linear-gradient(135deg, var(--orange) 0%, #ff9a5c 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  @keyframes sw-marquee {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }
  @media (max-width: 768px) {
    .sw-trust-track { animation-duration: 28s; }
    .sw-trust-band {
      -webkit-mask-image: linear-gradient(to right, transparent, black 5%, black 95%, transparent);
      mask-image: linear-gradient(to right, transparent, black 5%, black 95%, transparent);
    }
  }

  /* ── GRID ── */
  .sw-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 18px;
    padding: 0 20px;
    max-width: 1100px;
    margin: 0 auto;
  }

  /* ── CARD ── */
  .sw-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 26px;
    display: flex; flex-direction: column;
    position: relative; overflow: hidden;
    transition: border-color .22s, transform .22s, box-shadow .22s;
  }
  .sw-card::before {
    content: '';
    position: absolute; top: 0; left: 0; right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--orange), #ff9a5c);
    opacity: 0;
    transition: opacity .22s;
  }
  .sw-card:hover {
    border-color: var(--border-hover);
    transform: translateY(-4px);
    box-shadow: 0 16px 40px rgba(0,0,0,.3), 0 0 0 1px var(--border-hover);
  }
  .sw-card:hover::before { opacity: 1; }

  /* Card destaque */
  .sw-card.featured {
    border-color: var(--orange);
    box-shadow: 0 0 0 1px var(--orange), 0 16px 40px var(--orange-glow);
  }
  .sw-card.featured::before { opacity: 1; }
  .sw-featured-tag {
    position: absolute; top: 18px; right: 18px;
    background: var(--orange);
    color: #fff; font-family: var(--mono);
    font-size: .62rem; font-weight: 700;
    letter-spacing: .08em; text-transform: uppercase;
    padding: 3px 10px; border-radius: 99px;
  }

  .sw-cat {
    display: inline-flex; align-items: center; gap: 6px;
    font-family: var(--mono); font-size: .68rem;
    color: var(--orange); text-transform: uppercase; letter-spacing: .08em;
    margin-bottom: 12px;
  }
  .sw-cat-dot {
    width: 5px; height: 5px;
    background: var(--orange); border-radius: 50%;
    flex-shrink: 0;
  }

  .sw-card-icon {
    width: 44px; height: 44px;
    background: var(--orange-dim);
    border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.3rem; color: var(--orange);
    margin-bottom: 16px;
    flex-shrink: 0;
  }

  .sw-title {
    font-size: 1.15rem; font-weight: 700;
    color: var(--text); margin-bottom: 10px;
    line-height: 1.25;
  }

  .sw-desc {
    font-size: .84rem; color: var(--text-muted);
    line-height: 1.6; margin-bottom: 22px;
    flex-grow: 1;
  }

  /* ── PREÇOS ── */
  .sw-price-box {
    background: var(--bg-input);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 14px 16px;
    margin-bottom: 18px;
  }
  .sw-price-single {
    font-size: 1.6rem; font-weight: 800;
    color: var(--green);
    letter-spacing: -.02em;
  }
  .sw-price-note {
    font-size: .72rem; color: var(--text-muted);
    font-family: var(--mono); margin-top: 4px;
    display: block;
  }
  .sw-price-row {
    display: flex; justify-content: space-between; align-items: center;
    padding: 7px 0;
    border-bottom: 1px dashed var(--text-faint);
  }
  .sw-price-row:last-child { border-bottom: none; padding-bottom: 0; }
  .sw-price-label {
    font-size: .8rem; color: var(--text-muted); font-weight: 500;
  }
  .sw-price-val {
    font-size: .9rem; font-weight: 700;
    color: var(--green); font-family: var(--mono);
  }

  /* ── BOTÃO CARD ── */
  .sw-card-btn {
    display: flex; align-items: center; justify-content: center; gap: 8px;
    background: var(--orange-dim);
    color: var(--orange);
    border: 1px solid var(--orange);
    padding: 11px 16px; border-radius: 10px;
    font-family: 'Sora', sans-serif;
    font-weight: 700; font-size: .84rem;
    text-decoration: none; cursor: pointer;
    transition: background .18s, color .18s, transform .15s;
    margin-top: auto;
  }
  .sw-card-btn:hover {
    background: var(--orange); color: #fff;
    transform: translateY(-1px);
  }
  .sw-card-btn i { font-size: .95rem; }

  /* ── CTA FINAL ── */
  .sw-bottom-cta {
    text-align: center;
    padding: 52px 20px 0;
    max-width: 560px; margin: 0 auto;
  }
  .sw-bottom-cta p {
    font-size: .9rem; color: var(--text-muted);
    line-height: 1.6; margin-bottom: 24px;
  }
  .sw-bottom-cta strong { color: var(--text); }
</style>