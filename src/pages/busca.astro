---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const base = import.meta.env.BASE_URL;
const baseUrl = base === '/' ? '' : base.replace(/\/$/, '');
const searchApiUrl = import.meta.env.PUBLIC_SEARCH_API_URL || '';
---

<Layout title="Central de Busca - FP Agency">
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet" />

  <Header />

  <main class="search-page" id="search-page-root" data-base={baseUrl} data-api-url={searchApiUrl}>
    <section class="search-hero" aria-labelledby="search-page-title">
      <div class="search-hero-kicker">
        <i class="fas fa-circle-dot" aria-hidden="true"></i>
        Central de busca
      </div>
      <h1 id="search-page-title">Encontre qualquer ponto da operação FP Agency.</h1>
      <p>Pesquise páginas, status de editores e relatórios mensais em uma experiência única, rápida e consistente.</p>
    </section>

    <section class="search-console" aria-label="Ferramentas de busca">
      <div class="search-tabs" id="search-tabs" role="tablist" aria-label="Tipos de busca">
        <span class="search-tab-indicator" id="search-tab-indicator" aria-hidden="true"></span>
        <button id="tab-site" class="search-tab active" type="button" data-tab="site" data-index="0" role="tab" aria-selected="true" aria-controls="panel-site">
          <i class="fas fa-layer-group" aria-hidden="true"></i>
          <span>Páginas</span>
        </button>
        <button id="tab-aprovacao" class="search-tab" type="button" data-tab="aprovacao" data-index="1" role="tab" aria-selected="false" aria-controls="panel-aprovacao">
          <i class="fas fa-user-check" aria-hidden="true"></i>
          <span>Editores</span>
        </button>
        <button id="tab-relatorio" class="search-tab" type="button" data-tab="relatorio" data-index="2" role="tab" aria-selected="false" aria-controls="panel-relatorio">
          <i class="fas fa-chart-line" aria-hidden="true"></i>
          <span>Relatórios</span>
        </button>
      </div>

      <div class="search-panel active" id="panel-site" role="tabpanel" aria-labelledby="tab-site">
        <div class="search-panel-copy">
          <strong>Busca local instantânea</strong>
          <span>Encontre páginas, seções, diretrizes, programas e recursos da FP Agency.</span>
        </div>
        <div class="search-input-row">
          <label class="sr-only" for="in-site">Buscar no site</label>
          <div class="search-input-shell">
            <i class="fas fa-magnifying-glass" aria-hidden="true"></i>
            <input id="in-site" class="search-input" type="search" placeholder="Ex: recrutador, regras, RPM, inscrição..." autocomplete="off" spellcheck="false" maxlength="100" />
          </div>
          <button class="search-action-btn" id="btn-site" type="button">
            <i class="fas fa-location-crosshairs" aria-hidden="true"></i>
            Localizar
          </button>
        </div>
      </div>

      <div class="search-panel" id="panel-aprovacao" role="tabpanel" hidden>
        <div class="search-panel-copy">
          <strong>Status de editores</strong>
          <span>Consulte aprovação por nome, WhatsApp ou usuário. Para busca automática ao digitar, use @nome.</span>
        </div>
        <div class="search-input-row">
          <label class="sr-only" for="in-aprovacao">Buscar aprovações</label>
          <div class="search-input-shell">
            <i class="fas fa-user-astronaut" aria-hidden="true"></i>
            <input id="in-aprovacao" class="search-input" type="search" placeholder="Ex: Mateus, 81999999999 ou @mateus" autocomplete="off" maxlength="150" />
          </div>
          <label class="sr-only" for="sel-aprovacao">Período de aprovação</label>
          <select id="sel-aprovacao" class="search-select">
            <option value="all">Todo o período</option>
            <option value="7">Últimos 7 dias</option>
            <option value="15">Últimos 15 dias</option>
            <option value="30">Últimos 30 dias</option>
            <option value="90">Últimos 90 dias</option>
          </select>
          <button class="search-action-btn" id="btn-aprovacao" type="button">
            <i class="fas fa-magnifying-glass" aria-hidden="true"></i>
            Buscar
          </button>
        </div>
      </div>

      <div class="search-panel" id="panel-relatorio" role="tabpanel" hidden>
        <div class="search-panel-copy">
          <strong>Relatórios mensais</strong>
          <span>Consulte histórico, views e indicadores por nome de usuário.</span>
        </div>
        <div class="search-input-row">
          <label class="sr-only" for="in-relatorio">Buscar relatórios</label>
          <div class="search-input-shell">
            <i class="fas fa-chart-simple" aria-hidden="true"></i>
            <input id="in-relatorio" class="search-input" type="search" placeholder="Ex: NewsBR, canal ou @usuario" autocomplete="off" maxlength="150" />
          </div>
          <label class="sr-only" for="sel-relatorio">Período de relatório</label>
          <select id="sel-relatorio" class="search-select">
            <option value="all">Todo o histórico</option>
            <option value="1">Mês atual</option>
            <option value="3">Últimos 3 meses</option>
            <option value="6">Últimos 6 meses</option>
            <option value="12">1 ano</option>
          </select>
          <button class="search-action-btn" id="btn-relatorio" type="button">
            <i class="fas fa-magnifying-glass" aria-hidden="true"></i>
            Buscar
          </button>
        </div>
      </div>
    </section>

    <section class="search-results-shell" aria-labelledby="search-results-title">
      <div class="search-results-heading">
        <div>
          <span class="search-results-eyebrow">Resultados</span>
          <h2 id="search-results-title">Pronto para pesquisar</h2>
        </div>
        <div class="search-results-meta" id="search-results-meta">Digite um termo para começar</div>
      </div>

      <div class="search-results" id="master-results" aria-live="polite"></div>
    </section>
  </main>

  <Footer />
</Layout>

<script>
  import Fuse from 'fuse.js';
  import { searchIndex } from '../data/search-index';
  import type { SearchIndexItem, SearchItemType } from '../data/search-index';

  type SearchTab = 'site' | 'aprovacao' | 'relatorio';
  type ApiTab = 'aprovacao' | 'relatorio';
  type ApiBadgeInfo = [string, string, string];

  interface ApiRecord {
    nomeCompleto?: string;
    nome?: string;
    nomeUsuario?: string;
    usuario?: string;
    fonte?: string;
    categoria?: string;
    statusResultado?: string;
    status?: string;
    perfilUrl?: string;
    data?: string;
    whatsapp?: string;
    motivo?: string;
    recrutador?: string;
    whatsRecrutador?: string;
    uid?: string;
    totalVv?: string | number;
    taxaVerticalidade?: string;
    dataInicio?: string;
    videosValidos?: string | number;
    mesReferencia?: string;
  }

  interface ApiPayload {
    success?: boolean;
    status?: string;
    message?: string;
    data?: ApiRecord[];
    total?: number;
    pages?: number;
  }

  interface ApiSearchState {
    page: number;
    pages: number;
    total: number;
    termo: string;
    filtro: string;
    loading: boolean;
    version: number;
    abortController: AbortController | null;
  }

  const PAGE_SIZE = 20;
  const MIN_TERM = 2;
  const API_DEBOUNCE_MS = 500;
  const SITE_INPUT_DEBOUNCE_MS = 80;
  const VALID_TABS: SearchTab[] = ['site', 'aprovacao', 'relatorio'];

  const rootEl = document.getElementById('search-page-root') as HTMLElement | null;
  const basePath = rootEl?.getAttribute('data-base') || '';
  const apiUrl = rootEl?.dataset.apiUrl || '';
  const resultsContainer = document.getElementById('master-results') as HTMLElement | null;
  const resultsTitle = document.getElementById('search-results-title') as HTMLElement | null;
  const resultsMeta = document.getElementById('search-results-meta') as HTMLElement | null;
  const tabIndicator = document.getElementById('search-tab-indicator') as HTMLElement | null;

  const dom = {
    tabs: Array.from(document.querySelectorAll<HTMLButtonElement>('.search-tab')),
    panels: Array.from(document.querySelectorAll<HTMLElement>('.search-panel')),
    siteInput: document.getElementById('in-site') as HTMLInputElement | null,
    aprovacaoInput: document.getElementById('in-aprovacao') as HTMLInputElement | null,
    relatorioInput: document.getElementById('in-relatorio') as HTMLInputElement | null,
    aprovacaoSelect: document.getElementById('sel-aprovacao') as HTMLSelectElement | null,
    relatorioSelect: document.getElementById('sel-relatorio') as HTMLSelectElement | null,
    siteButton: document.getElementById('btn-site') as HTMLButtonElement | null,
    aprovacaoButton: document.getElementById('btn-aprovacao') as HTMLButtonElement | null,
    relatorioButton: document.getElementById('btn-relatorio') as HTMLButtonElement | null,
  };

  const apiCache = new Map<string, ApiPayload>();
  const state = {
    activeTab: 'site' as SearchTab,
    site: { termo: '' },
    aprovacao: { page: 1, pages: 0, total: 0, termo: '', filtro: 'all', loading: false, version: 0, abortController: null } as ApiSearchState,
    relatorio: { page: 1, pages: 0, total: 0, termo: '', filtro: 'all', loading: false, version: 0, abortController: null } as ApiSearchState,
  };

  const normalizeText = (value: unknown): string =>
    String(value || '')
      .normalize('NFD')
      .replace(/[\u0300-\u036f]/g, '')
      .toLowerCase()
      .trim();

  const escapeHtml = (value: unknown): string =>
    String(value == null ? '' : value)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#x27;');

  const escapeRegex = (value: unknown): string => String(value || '').replace(/[.*+?^${}()|[\]\\]/g, '\\$&');

  const highlightText = (text: unknown, query: unknown): string => {
    const safeText = escapeHtml(text);
    const term = stripSearchPrefix(query);
    if (normalizeText(term).length < 3) return safeText;

    const regex = new RegExp(`([\\p{L}\\p{N}_-]*${escapeRegex(term)}[\\p{L}\\p{N}_-]*)`, 'giu');
    return safeText.replace(regex, '<mark>$1</mark>');
  };

  const stripSearchPrefix = (value: unknown): string => String(value || '').replace(/^@+/, '').trim();

  const routeWithBase = (url: string): string => {
    const rawUrl = String(url || '/');
    if (/^https?:\/\//i.test(rawUrl)) return rawUrl;
    const path = rawUrl.startsWith('/') ? rawUrl : `/${rawUrl}`;
    if (!basePath) return path;
    return path === '/' ? `${basePath}/` : `${basePath}${path}`;
  };

  const buildSearchUrl = (tab: string, query: unknown): string => {
    const safeTab = VALID_TABS.includes(tab as SearchTab) ? (tab as SearchTab) : 'site';
    const safeQuery = String(query || '').trim();
    return `${routeWithBase('/busca')}?tab=${encodeURIComponent(safeTab)}${safeQuery ? `&q=${encodeURIComponent(safeQuery)}` : ''}`;
  };

  const updateUrl = (tab: string, query: unknown): void => {
    const nextUrl = buildSearchUrl(tab, query);
    window.history.replaceState(null, '', nextUrl);
  };

  const safeExternalUrl = (rawUrl: unknown): string | null => {
    const url = String(rawUrl || '').trim();
    if (!url || !/^https?:\/\//i.test(url) || /^(javascript|data|vbscript):/i.test(url)) return null;
    return url;
  };

  const debounce = <Args extends unknown[]>(callback: (...args: Args) => void, wait: number) => {
    let timer: number | undefined;
    return (...args: Args): void => {
      window.clearTimeout(timer);
      timer = window.setTimeout(() => callback(...args), wait);
    };
  };

  const createIcon = (iconClass?: string): HTMLElement => {
    const icon = document.createElement('i');
    icon.className = `fas ${iconClass || 'fa-circle-dot'}`;
    icon.setAttribute('aria-hidden', 'true');
    return icon;
  };

  const setResultsHeader = (title: string, meta = ''): void => {
    if (resultsTitle) resultsTitle.textContent = title;
    if (resultsMeta) resultsMeta.textContent = meta;
  };

  const clearResults = () => {
    resultsContainer?.replaceChildren();
  };

  const createFeedback = (message: string, type = 'info'): HTMLElement => {
    const feedback = document.createElement('div');
    feedback.className = `search-feedback ${type}`;
    feedback.append(createIcon(type === 'error' ? 'fa-triangle-exclamation' : 'fa-circle-info'));

    const text = document.createElement('span');
    text.textContent = message;
    feedback.append(text);
    return feedback;
  };

  const renderInitialState = () => {
    setResultsHeader('Pronto para pesquisar', 'Digite um termo para começar');
    clearResults();
    resultsContainer?.append(createFeedback('Use a aba Páginas para busca instantânea, ou consulte editores e relatórios pelas abas acima.'));
  };

  const renderSkeleton = (message = 'Consultando base FP Agency...'): void => {
    clearResults();
    setResultsHeader('Buscando...', message);

    const wrap = document.createElement('div');
    wrap.className = 'search-skeleton-list';

    for (let index = 0; index < 4; index += 1) {
      const item = document.createElement('div');
      item.className = 'search-skeleton-card';
      wrap.append(item);
    }

    resultsContainer?.append(wrap);
  };

  const fuse = new Fuse<SearchIndexItem>(searchIndex, {
    keys: [
      { name: 'title', weight: 0.42 },
      { name: 'description', weight: 0.22 },
      { name: 'keywords', weight: 0.28 },
      { name: 'category', weight: 0.08 },
    ],
    threshold: 0.34,
    ignoreLocation: true,
    includeScore: true,
    minMatchCharLength: 2,
  });

  const getSiteResults = (query: string): SearchIndexItem[] => {
    const normalized = normalizeText(query);
    if (normalized.length < MIN_TERM) {
      return searchIndex
        .slice()
        .sort((a, b) => b.priority - a.priority)
        .slice(0, 9);
    }

    return fuse
      .search(query)
      .map(({ item, score = 1 }) => ({ item, score }))
      .sort((a, b) => (a.score - b.score) || (b.item.priority - a.item.priority))
      .map(({ item }) => item)
      .slice(0, 16);
  };

  const getTypeLabel = (type: SearchItemType): string => {
    if (type === 'feature') return 'Recurso';
    if (type === 'section') return 'Seção';
    return 'Página';
  };

  const createSiteCard = (item: SearchIndexItem, query: string): HTMLAnchorElement => {
    const link = document.createElement('a');
    link.className = 'site-result-card';
    link.href = routeWithBase(item.url);

    const iconWrap = document.createElement('span');
    iconWrap.className = 'site-result-icon';
    iconWrap.append(createIcon(item.icon));

    const body = document.createElement('span');
    body.className = 'site-result-body';

    const top = document.createElement('span');
    top.className = 'site-result-topline';

    const title = document.createElement('span');
    title.className = 'site-result-title';
    title.innerHTML = highlightText(item.title, query);

    const category = document.createElement('span');
    category.className = 'site-result-category';
    category.textContent = item.category || getTypeLabel(item.type);

    top.append(title, category);

    const desc = document.createElement('span');
    desc.className = 'site-result-desc';
    desc.textContent = item.description;

    const keywordLine = document.createElement('span');
    keywordLine.className = 'site-result-keywords';
    keywordLine.textContent = item.keywords.slice(0, 5).join(' · ');

    body.append(top, desc, keywordLine);

    const arrow = createIcon('fa-arrow-right');
    arrow.classList.add('site-result-arrow');

    link.append(iconWrap, body, arrow);
    return link;
  };

  const renderSiteResults = (query: unknown, fromUserAction = false): void => {
    const term = String(query || '').trim();
    state.site.termo = term;
    updateUrl('site', term);

    if (term.length > 0 && normalizeText(term).length < MIN_TERM) {
      clearResults();
      setResultsHeader('Continue digitando', `Mínimo de ${MIN_TERM} caracteres`);
      resultsContainer?.append(createFeedback(`Digite ao menos ${MIN_TERM} caracteres para refinar a busca local.`));
      return;
    }

    const results = getSiteResults(term);
    clearResults();

    if (!results.length) {
      setResultsHeader('Nenhuma página encontrada', `Busca por "${term}"`);
      resultsContainer?.append(createFeedback('Tente outro termo ou use a aba Editores para consultar a base de aprovação.'));
      return;
    }

    const title = term ? `Páginas para "${term}"` : 'Páginas em destaque';
    const meta = `${results.length} resultado${results.length === 1 ? '' : 's'} no índice local`;
    setResultsHeader(title, meta);

    const list = document.createElement('div');
    list.className = 'site-results-list';
    results.forEach((item) => list.append(createSiteCard(item, term)));
    resultsContainer?.append(list);

    if (fromUserAction) {
      resultsContainer?.scrollIntoView({ block: 'start', behavior: 'smooth' });
    }
  };

  const setActiveTab = (tab: string | null | undefined, options: { keepResults?: boolean } = {}): void => {
    const safeTab: SearchTab = VALID_TABS.includes(tab as SearchTab) ? (tab as SearchTab) : 'site';
    const index = VALID_TABS.indexOf(safeTab);
    state.activeTab = safeTab;

    dom.tabs.forEach((button) => {
      const isActive = button.dataset.tab === safeTab;
      button.classList.toggle('active', isActive);
      button.setAttribute('aria-selected', String(isActive));
      button.tabIndex = isActive ? 0 : -1;
    });

    dom.panels.forEach((panel) => {
      const isActive = panel.id === `panel-${safeTab}`;
      panel.classList.toggle('active', isActive);
      panel.hidden = !isActive;
    });

    if (tabIndicator) {
      tabIndicator.style.transform = `translateX(${index * 100}%)`;
    }

    if (!options.keepResults) {
      const activeInput = getInputForTab(safeTab);
      updateUrl(safeTab, activeInput?.value || '');
      if (safeTab === 'site') renderSiteResults(activeInput?.value || '');
      else renderInitialState();
    }
  };

  const getInputForTab = (tab: SearchTab): HTMLInputElement | null => {
    if (tab === 'aprovacao') return dom.aprovacaoInput;
    if (tab === 'relatorio') return dom.relatorioInput;
    return dom.siteInput;
  };

  const getSelectForTab = (tab: ApiTab): HTMLSelectElement | null => (tab === 'aprovacao' ? dom.aprovacaoSelect : dom.relatorioSelect);

  const getButtonForTab = (tab: ApiTab): HTMLButtonElement | null => (tab === 'aprovacao' ? dom.aprovacaoButton : dom.relatorioButton);

  const getApiAction = (tab: ApiTab): string => (tab === 'aprovacao' ? 'buscarAprovacao' : 'buscarRelatorios');

  const makeCacheKey = (tab: ApiTab, term: string, filter: string, page: number): string => `${tab}:${normalizeText(term)}:${filter}:${page}`;

  const parseApiPayload = async (response: Response): Promise<ApiPayload> => {
    const text = await response.text();
    try {
      return JSON.parse(text) as ApiPayload;
    } catch {
      throw new Error('A API retornou uma resposta inválida.');
    }
  };

  const fetchApiPage = async (tab: ApiTab, term: string, filter: string, page: number, signal: AbortSignal): Promise<ApiPayload> => {
    if (!apiUrl) {
      throw new Error('API de busca nao configurada. Defina PUBLIC_SEARCH_API_URL no ambiente.');
    }

    const cacheKey = makeCacheKey(tab, term, filter, page);
    const cachedPayload = apiCache.get(cacheKey);
    if (cachedPayload) return cachedPayload;

    const response = await fetch(apiUrl, {
      method: 'POST',
      body: JSON.stringify({
        action: getApiAction(tab),
        data: { termo: term, filtro: filter, page, limit: PAGE_SIZE },
      }),
      signal,
    });

    const payload = await parseApiPayload(response);
    if (payload?.success === false || payload?.status === 'error') {
      throw new Error(payload?.message || 'Não foi possível consultar a base FP Agency.');
    }

    apiCache.set(cacheKey, payload);
    return payload;
  };

  const setApiLoading = (tab: ApiTab, isLoading: boolean): void => {
    const button = getButtonForTab(tab);
    const s = state[tab];
    s.loading = isLoading;

    if (button) {
      button.disabled = isLoading;
      button.classList.toggle('loading', isLoading);
    }
  };

  const createBadge = (label: unknown, iconClass: string, modifier = 'neutral'): HTMLElement => {
    const badge = document.createElement('span');
    badge.className = `search-badge ${modifier}`;
    badge.append(createIcon(iconClass));

    const text = document.createElement('span');
    text.textContent = String(label || 'Indefinido');
    badge.append(text);
    return badge;
  };

  const getStatusBadgeInfo = (status: unknown): ApiBadgeInfo => {
    const normalized = normalizeText(status);
    if (normalized.includes('aprov')) return ['Aprovado', 'fa-circle-check', 'success'];
    if (normalized.includes('reprov')) return ['Reprovado', 'fa-circle-xmark', 'danger'];
    if (normalized.includes('pend') || normalized.includes('analis')) return [String(status || 'Em análise'), 'fa-clock', 'warning'];
    return [String(status || 'Em análise'), 'fa-circle-question', 'neutral'];
  };

  const getSourceBadgeInfo = (source: unknown): ApiBadgeInfo => {
    const normalized = normalizeText(source);
    if (normalized.includes('cut')) return ['Cut', 'fa-scissors', 'blue'];
    if (normalized.includes('narra')) return ['Narrastars', 'fa-star', 'purple'];
    return [String(source || 'Base FP'), 'fa-database', 'neutral'];
  };

  const createDataBlock = (label: string, value: unknown, extraNode: Node | null = null): HTMLElement => {
    const block = document.createElement('div');
    block.className = 'data-block';

    const labelEl = document.createElement('span');
    labelEl.className = 'data-label';
    labelEl.textContent = label;

    const valueEl = document.createElement('span');
    valueEl.className = 'data-value';
    valueEl.textContent = String(value || '-');

    block.append(labelEl, valueEl);
    if (extraNode) block.append(extraNode);
    return block;
  };

  const createActionLink = (href: string, label: string, iconClass = 'fa-arrow-right', external = false): HTMLAnchorElement => {
    const link = document.createElement('a');
    link.className = 'result-action-link';
    link.href = href;
    if (external) {
      link.target = '_blank';
      link.rel = 'noopener noreferrer';
    }

    link.append(createIcon(iconClass));
    const text = document.createElement('span');
    text.textContent = label;
    link.append(text);
    return link;
  };

  const renderAprovacaoCard = (item: ApiRecord): HTMLElement => {
    const name = String(item?.nomeCompleto || item?.nome || 'Não identificado').trim();
    const source = String(item?.fonte || 'Base FP').trim();
    const status = String(item?.statusResultado || item?.status || 'Em análise').trim();
    const [statusLabel, statusIcon, statusModifier] = getStatusBadgeInfo(status);
    const [sourceLabel, sourceIcon, sourceModifier] = getSourceBadgeInfo(source);

    const card = document.createElement('article');
    card.className = `api-result-card ${sourceModifier === 'blue' ? 'from-cut' : sourceModifier === 'purple' ? 'from-narrastars' : ''}`;

    const head = document.createElement('div');
    head.className = 'api-card-head';

    const identity = document.createElement('div');
    identity.className = 'api-card-identity';
    const title = document.createElement('h3');
    title.textContent = name;
    const subtitle = document.createElement('span');
    subtitle.textContent = source;
    identity.append(title, subtitle);

    const badges = document.createElement('div');
    badges.className = 'api-card-badges';
    badges.append(createBadge(sourceLabel, sourceIcon, sourceModifier), createBadge(statusLabel, statusIcon, statusModifier));
    head.append(identity, badges);

    const grid = document.createElement('div');
    grid.className = 'api-card-grid';

    const profileUrl = safeExternalUrl(item?.perfilUrl);
    const profileLink = profileUrl ? createActionLink(profileUrl, 'Ver perfil', 'fa-arrow-up-right-from-square', true) : null;
    grid.append(
      createDataBlock('Data', item?.data),
      createDataBlock('Categoria', item?.categoria),
      createDataBlock('WhatsApp', item?.whatsapp),
      createDataBlock('Perfil', profileUrl ? 'Disponível' : '-', profileLink),
    );

    if (item?.motivo) {
      const reason = createDataBlock('Motivo', item.motivo);
      reason.classList.add('wide');
      grid.append(reason);
    }

    const recruiterName = String(item?.recrutador || '').trim();
    if (recruiterName && recruiterName !== 'FP Agency') {
      const recruiter = document.createElement('div');
      recruiter.className = 'recruiter-strip';
      recruiter.append(createIcon('fa-user-tie'), createDataBlock('Recrutador', recruiterName), createDataBlock('WhatsApp', item?.whatsRecrutador));
      grid.append(recruiter);
    }

    const actions = document.createElement('div');
    actions.className = 'api-card-actions';
    actions.append(createActionLink(buildSearchUrl('aprovacao', name), 'Abrir esta busca'));

    card.append(head, grid, actions);
    return card;
  };

  const renderRelatorioCard = (item: ApiRecord): HTMLElement => {
    const userName = String(item?.nomeUsuario || item?.usuario || 'Usuário não identificado').trim();
    const uid = String(item?.uid || '').trim();
    const totalViews = Number.parseInt(String(item?.totalVv || '0'), 10);
    const viewsLabel = Number.isFinite(totalViews) ? totalViews.toLocaleString('pt-BR') : String(item?.totalVv || '0');

    const card = document.createElement('article');
    card.className = 'api-result-card report';

    const head = document.createElement('div');
    head.className = 'api-card-head';

    const identity = document.createElement('div');
    identity.className = 'api-card-identity';
    const title = document.createElement('h3');
    title.textContent = userName;
    const subtitle = document.createElement('span');
    subtitle.textContent = String(item?.categoria || 'Relatório mensal');
    identity.append(title, subtitle);

    const badges = document.createElement('div');
    badges.className = 'api-card-badges';
    badges.append(createBadge(item?.mesReferencia || 'Mês', 'fa-calendar-days', 'neutral'));
    head.append(identity, badges);

    const profileUrl = uid ? safeExternalUrl(`https://www.kwai.com/@${uid}`) : null;
    const profileLink = profileUrl ? createActionLink(profileUrl, 'Ver perfil', 'fa-arrow-up-right-from-square', true) : null;

    const grid = document.createElement('div');
    grid.className = 'api-card-grid';
    grid.append(
      createDataBlock('UID Kwai', uid),
      createDataBlock('Taxa vertical', item?.taxaVerticalidade),
      createDataBlock('Data início', item?.dataInicio),
      createDataBlock('Vídeos válidos', item?.videosValidos || '0'),
      createDataBlock('Total views', viewsLabel),
      createDataBlock('Perfil', profileUrl ? 'Disponível' : '-', profileLink),
    );

    const actions = document.createElement('div');
    actions.className = 'api-card-actions';
    actions.append(createActionLink(buildSearchUrl('relatorio', userName), 'Abrir este relatório', 'fa-arrow-right'));

    card.append(head, grid, actions);
    return card;
  };

  const renderPagination = (tab: ApiTab): void => {
    const s = state[tab];
    if (!s.pages || s.page >= s.pages) return;

    const pagination = document.createElement('div');
    pagination.className = 'search-pagination';

    const info = document.createElement('span');
    info.textContent = `${Math.min(s.page * PAGE_SIZE, s.total)} de ${s.total} resultados`;

    const button = document.createElement('button');
    button.className = 'load-more-btn';
    button.type = 'button';
    button.dataset.tab = tab;
    button.append(createIcon('fa-chevron-down'));
    const text = document.createElement('span');
    text.textContent = 'Carregar mais';
    button.append(text);

    pagination.append(info, button);
    resultsContainer?.append(pagination);
  };

  const renderApiResults = (tab: ApiTab, payload: ApiPayload, append = false): void => {
    const items = Array.isArray(payload?.data) ? payload.data : [];
    const total = Number(payload?.total || items.length || 0);
    const pages = Number(payload?.pages || 1);
    const s = state[tab];
    s.total = total;
    s.pages = pages;

    if (!append) clearResults();

    if (!items.length) {
      if (!append) {
        setResultsHeader('Nenhum registro encontrado', `Busca por "${s.termo}"`);
        resultsContainer?.append(createFeedback('Não encontramos registros para essa busca na base FP Agency.'));
      }
      return;
    }

    if (!append) {
      const label = tab === 'aprovacao' ? 'Editores encontrados' : 'Relatórios encontrados';
      setResultsHeader(label, `${total || items.length} resultado${(total || items.length) === 1 ? '' : 's'} para "${s.termo}"`);
    } else {
      resultsContainer?.querySelector('.search-pagination')?.remove();
    }

    const list = document.createElement('div');
    list.className = 'api-results-list';
    items.forEach((item) => list.append(tab === 'aprovacao' ? renderAprovacaoCard(item) : renderRelatorioCard(item)));
    resultsContainer?.append(list);
    renderPagination(tab);
  };

  const runApiSearch = async (tab: ApiTab, options: { append?: boolean } = {}): Promise<void> => {
    const append = Boolean(options.append);
    const s = state[tab];
    const input = getInputForTab(tab);
    const select = getSelectForTab(tab);
    const term = stripSearchPrefix(input?.value || '');
    const filter = select?.value || 'all';

    if (normalizeText(term).length < MIN_TERM) {
      setResultsHeader('Continue digitando', `Mínimo de ${MIN_TERM} caracteres`);
      clearResults();
      resultsContainer?.append(createFeedback(`Digite ao menos ${MIN_TERM} caracteres para consultar ${tab === 'aprovacao' ? 'editores' : 'relatórios'}.`));
      return;
    }

    if (!append) {
      s.page = 1;
      s.termo = term;
      s.filtro = filter;
      renderSkeleton(tab === 'aprovacao' ? 'Consultando aprovações...' : 'Consultando relatórios...');
    } else {
      s.page += 1;
    }

    updateUrl(tab, term);

    const requestVersion = ++s.version;
    if (s.abortController) s.abortController.abort();
    s.abortController = new AbortController();
    setApiLoading(tab, true);

    try {
      const payload = await fetchApiPage(tab, s.termo, s.filtro, s.page, s.abortController.signal);
      if (requestVersion !== s.version) return;
      renderApiResults(tab, payload, append);
    } catch (error) {
      if ((error instanceof Error && error.name === 'AbortError') || requestVersion !== s.version) return;
      if (append) s.page = Math.max(1, s.page - 1);
      setResultsHeader('Falha na consulta', 'A API não respondeu como esperado');
      clearResults();
      resultsContainer?.append(createFeedback(error instanceof Error ? error.message : 'Não foi possível consultar a API agora.', 'error'));
    } finally {
      if (requestVersion === s.version) setApiLoading(tab, false);
    }
  };

  const triggerCurrentSearch = (fromUserAction = true): void => {
    if (state.activeTab === 'site') {
      renderSiteResults(dom.siteInput?.value || '', fromUserAction);
      return;
    }

    runApiSearch(state.activeTab);
  };

  const onSiteInput = debounce(() => {
    if (state.activeTab === 'site') renderSiteResults(dom.siteInput?.value || '');
  }, SITE_INPUT_DEBOUNCE_MS);

  const onApiRealtimeInput = debounce((tab: ApiTab) => {
    const rawValue = getInputForTab(tab)?.value || '';
    if (state.activeTab === tab && rawValue.trim().startsWith('@')) {
      runApiSearch(tab);
    }
  }, API_DEBOUNCE_MS);

  dom.tabs.forEach((button) => {
    button.addEventListener('click', () => setActiveTab(button.dataset.tab || 'site'));
  });

  dom.siteButton?.addEventListener('click', () => renderSiteResults(dom.siteInput?.value || '', true));
  dom.aprovacaoButton?.addEventListener('click', () => runApiSearch('aprovacao'));
  dom.relatorioButton?.addEventListener('click', () => runApiSearch('relatorio'));

  dom.siteInput?.addEventListener('input', onSiteInput);
  dom.aprovacaoInput?.addEventListener('input', () => onApiRealtimeInput('aprovacao'));
  dom.relatorioInput?.addEventListener('input', () => onApiRealtimeInput('relatorio'));

  [dom.siteInput, dom.aprovacaoInput, dom.relatorioInput].forEach((input) => {
    input?.addEventListener('keydown', (event) => {
      if (event.key === 'Enter') {
        event.preventDefault();
        triggerCurrentSearch();
      }
    });
  });

  resultsContainer?.addEventListener('click', (event) => {
    const button = event.target instanceof HTMLElement ? event.target.closest<HTMLButtonElement>('.load-more-btn') : null;
    if (!button) return;

    const tab = button.dataset.tab;
    if (tab === 'aprovacao' || tab === 'relatorio') runApiSearch(tab, { append: true });
  });

  const bootFromUrl = (): void => {
    const params = new URLSearchParams(window.location.search);
    const tabParam = params.get('tab');
    const tab: SearchTab = VALID_TABS.includes(tabParam as SearchTab) ? (tabParam as SearchTab) : 'site';
    const query = params.get('q') || '';

    setActiveTab(tab, { keepResults: true });

    const activeInput = getInputForTab(tab);
    if (activeInput) activeInput.value = query;

    if (query.trim()) {
      if (tab === 'site') renderSiteResults(query);
      else runApiSearch(tab);
      return;
    }

    if (tab === 'site') renderSiteResults('');
    else renderInitialState();
  };

  bootFromUrl();
</script>

