---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const base = import.meta.env.BASE_URL;
const baseUrl = base === '/' ? '' : base;
---

<Layout title="Central de Busca - FP Agency">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

  <Header />

  <div class="fp" id="fp-root" data-base={baseUrl}>
    <div class="fp-loader" id="fp-loader">
      <div class="fp-loader-ring"></div>
      <span class="fp-loader-text">consultando...</span>
    </div>

    <div class="fp-hero">
      <div class="fp-hero-eyebrow"><i class="fas fa-circle-dot"></i> Central de Comando</div>
      <h1 class="fp-hero-title">O que você deseja <span>localizar</span>?</h1>
      <p class="fp-hero-sub">Alterne entre as opções abaixo para buscar editores, relatórios ou informações no site.</p>
    </div>

    <main class="fp-content">
      
      <div class="search-master-card">
        
        <div class="tab-switcher" id="tabSwitcher" role="tablist">
          <div class="tab-slider" id="tabSlider"></div>
          <button class="tab-btn active" data-tab="aprovacao" data-index="0" role="tab" aria-selected="true">
            <i class="fas fa-user-check"></i> Aprovação
          </button>
          <button class="tab-btn" data-tab="relatorio" data-index="1" role="tab" aria-selected="false">
            <i class="fas fa-chart-line"></i> Relatórios
          </button>
          <button class="tab-btn" data-tab="site" data-index="2" role="tab" aria-selected="false">
            <i class="fas fa-globe"></i> No Site
          </button>
        </div>

        <div class="tab-content active" id="content-aprovacao">
          <p class="sc-desc">Acompanhe aprovações digitando o Nome ou número de WhatsApp.</p>
          <div class="input-row">
            <input type="text" id="in-aprovacao" class="fp-input" placeholder="Ex: João ou 81999999999" autocomplete="off" maxlength="150">
            <select id="sel-aprovacao" class="fp-select">
              <option value="all">Todo o período</option>
              <option value="7">Últimos 7 dias</option>
              <option value="15">Últimos 15 dias</option>
              <option value="30">Últimos 30 dias</option>
              <option value="90">Últimos 90 dias</option>
            </select>
            <button class="fp-btn" id="btn-aprovacao"><i class="fas fa-magnifying-glass"></i> Buscar</button>
          </div>
        </div>

        <div class="tab-content" id="content-relatorio">
          <p class="sc-desc">Consulte o desempenho mensal através do Nome de Usuário.</p>
          <div class="input-row">
            <input type="text" id="in-relatorio" class="fp-input" placeholder="Ex: NewsBR" autocomplete="off" maxlength="150">
            <select id="sel-relatorio" class="fp-select">
              <option value="all">Todo o histórico</option>
              <option value="1">Mês atual</option>
              <option value="3">Últimos 3 meses</option>
              <option value="6">Últimos 6 meses</option>
              <option value="12">1 ano</option>
            </select>
            <button class="fp-btn" id="btn-relatorio"><i class="fas fa-magnifying-glass"></i> Buscar</button>
          </div>
        </div>

        <div class="tab-content" id="content-site">
          <p class="sc-desc">Use palavras-chave para encontrar jornadas, regras e páginas institucionais.</p>
          <div class="input-row">
            <input type="text" id="in-site" class="fp-input" placeholder="Ex: privacidade, regras, recrutador..." autocomplete="off" maxlength="100" spellcheck="false">
            <button class="fp-btn" id="btn-site"><i class="fas fa-location-crosshairs"></i> Localizar</button>
          </div>
        </div>

      </div>

      <div class="results-container" id="master-results" aria-live="polite"></div>

    </main>
  </div>

  <Footer />
</Layout>

<script is:inline type="module">
  // Importação do algoritmo de busca inteligente para a aba "No Site"
  import Fuse from 'https://esm.sh/fuse.js@7.0.0';

  const API_URL   = 'https://script.google.com/macros/s/AKfycbwGdUL3p5qf1GozVaGkE0Xx9epH4Pf5pJe59eennDsD34hX0P85HekUl_9p4HqzBzLS/exec';
  const PAGE_SIZE = 20;
  const MIN_TERM  = 2;
  const DEBOUNCE_MS = 380;

  const rootEl = document.getElementById('fp-root');
  const basePath = rootEl ? rootEl.getAttribute('data-base') : '';

  // ESTADO - (Corrigido para 'relatorio' no singular)
  const state = {
    aprovacao:  { page: 1, total: 0, pages: 0, termo: '', filtro: 'all', loading: false },
    relatorio:  { page: 1, total: 0, pages: 0, termo: '', filtro: 'all', loading: false },
    activeTab: 'aprovacao'
  };
  const abort = { aprovacao: null, relatorio: null };

  // Base do Site 100% atualizada (Home, Sobre, Monetização)
  const BASE_SITE = [
    { nome: "Página Inicial (Home)", url: `${basePath}/`, icon: "fa-home", tags: "home inicio fp agency", desc: "Acesse a página principal com nossos programas, jornadas e estrutura." },
    { nome: "Sobre a FP Agency", url: `${basePath}/sobre`, icon: "fa-rocket", tags: "sobre historia missao visao valores ecossistema", desc: "Conheça nossa história, ecossistema completo, missão, visão e valores." },
    { nome: "Kwai Cut", url: `${basePath}/monetize/kwaicut`, icon: "fa-video", tags: "kwai cut monetize monetização edição", desc: "Descubra como monetizar editando vídeos virais no programa Kwai Cut." },
    { nome: "NarraStars", url: `${basePath}/monetize/kwainarrastars`, icon: "fa-microphone", tags: "narrastars narração kwai locução", desc: "Monetize sua voz narrando vídeos virais para o Kwai através do NarraStars." },
    { nome: "Portal do Parceiro", url: `${basePath}/recrutador`, icon: "fa-user-lock", tags: "login cadastro entrar acesso", desc: "Acesse sua conta para visualizar painéis, relatórios completos e realizar cadastros." },
    { nome: "Carteira e Financeiro", url: `${basePath}/recrutador`, icon: "fa-wallet", tags: "saque saldo dinheiro carteira extrato pagamento financeiro", desc: "Gerencie seu saldo, acompanhe os extratos de pagamentos e solicite saques." },
    { nome: "Política de Privacidade", url: `${basePath}/politica-de-privacidade`, icon: "fa-shield-halved", tags: "politica privacidade dados lgpd segurança legal", desc: "Leia nossa política de privacidade e saiba como protegemos e tratamos seus dados." },
    { nome: "Termos de Serviço", url: `${basePath}/termos-de-servico`, icon: "fa-file-contract", tags: "termos serviço regras contrato legal uso", desc: "Termos e condições gerais de uso das plataformas e serviços da FP Agency." },
    { nome: "Aviso Legal", url: `${basePath}/aviso-legal`, icon: "fa-scale-balanced", tags: "aviso legal juridico direitos isencao", desc: "Informações jurídicas, transparência e avisos legais da nossa empresa." },
    { nome: "Área do Recrutador", url: `${basePath}/recrutador`, icon: "fa-users-gear", tags: "recrutador equipe gerenciar convites painel", desc: "Área de uso exclusivo para recrutadores acompanharem e gerenciarem suas equipes." }
  ];

  // Configuração do Fuse (Tolerância a erros de digitação e sistema de pontuação)
  const fuse = new Fuse(BASE_SITE, {
    keys: ['nome', 'tags', 'desc'],
    threshold: 0.4,
    ignoreLocation: true,
    includeScore: true,
    minMatchCharLength: 2
  });

  // ── LÓGICA DE ABAS (UI) ───────────────────────────────────────────────────
  const tabBtns = document.querySelectorAll('.tab-btn');
  const tabContents = document.querySelectorAll('.tab-content');
  const tabSlider = document.getElementById('tabSlider');
  const resultsContainer = document.getElementById('master-results');

  function switchTab(tabId, index) {
    tabSlider.style.transform = `translateX(${index * 100}%)`;
    
    tabBtns.forEach(btn => {
      btn.classList.remove('active');
      btn.setAttribute('aria-selected', 'false');
    });
    tabBtns[index].classList.add('active');
    tabBtns[index].setAttribute('aria-selected', 'true');

    tabContents.forEach(content => {
      content.classList.remove('active');
      content.style.opacity = '0';
      setTimeout(() => content.style.display = 'none', 200);
    });

    const activeContent = document.getElementById(`content-${tabId}`);
    setTimeout(() => {
      activeContent.style.display = 'block';
      setTimeout(() => activeContent.style.opacity = '1', 10);
    }, 200);

    state.activeTab = tabId;
    resultsContainer.innerHTML = ''; 
  }

  tabBtns.forEach((btn, index) => {
    btn.addEventListener('click', () => switchTab(btn.dataset.tab, index));
  });

  // ── Helpers ───────────────────────────────────────────────────────────────
  function esc(v) {
    return String(v == null ? '' : v).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#x27;');
  }
  
  function safeUrl(raw) {
    const u = String(raw || '').trim();
    if (!u || /^(javascript|data|vbscript):/i.test(u) || !/^https?:\/\//i.test(u)) return null;
    return u;
  }
  
  function mkLink(url, label) {
    const u = safeUrl(url);
    if (!u) return '-';
    return `<a href="${esc(u)}" target="_blank" rel="noopener noreferrer" class="btn-link"><i class="fas fa-arrow-up-right-from-square"></i> ${esc(label || 'Ver Perfil')}</a>`;
  }

  // Destaque do texto encontrado
  const highlight = (texto, termo) => {
    if (!termo) return esc(texto);
    const regex = new RegExp(`(${termo.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')})`, 'gi');
    return esc(texto).replace(regex, '<mark>$1</mark>');
  };

  const showLoader = () => document.getElementById('fp-loader').classList.add('on');
  const hideLoader = () => document.getElementById('fp-loader').classList.remove('on');

  function setFeedback(msg, isErr = false) {
    resultsContainer.innerHTML =
      '<div class="feedback ' + (isErr ? 'error' : '') + '">' +
      '<i class="fas ' + (isErr ? 'fa-triangle-exclamation' : 'fa-circle-info') + '"></i> ' +
      esc(msg) + '</div>';
  }

  function debounce(fn, ms) {
    let t;
    return (...a) => { clearTimeout(t); t = setTimeout(() => fn(...a), ms); };
  }

  // ── API Fetch (POST) ──────────────────────────────────────────────────────
  async function fetchAPI(action, termo, filtro, page) {
    const tipo = action === 'buscarAprovacao' ? 'aprovacao' : 'relatorio';
    if (abort[tipo]) abort[tipo].abort();
    abort[tipo] = new AbortController();

    const resp = await fetch(API_URL, {
      method: 'POST',
      signal: abort[tipo].signal,
      body: JSON.stringify({
        action: action,
        data: { termo: termo, filtro: filtro, page: page, limit: PAGE_SIZE }
      })
    });
    const text = await resp.text();
    try { return JSON.parse(text); } 
    catch (_) { throw new Error('Back-end retornou resposta inválida.'); }
  }

  // ── RENDERIZADORES ────────────────────────────────────────────────────────
  function badgeStatus(status) {
    var s = String(status || '').toLowerCase();
    if (s.includes('aprovado')) return ['b-success', 'fa-circle-check', status || 'Aprovado'];
    if (s.includes('reprovado')) return ['b-danger', 'fa-circle-xmark', status || 'Reprovado'];
    if (s.includes('pendente') || s.includes('analis')) return ['b-warning', 'fa-clock', status || 'Em Análise'];
    return ['b-neutral', 'fa-circle-question', status || 'Em Análise'];
  }

  function badgeFonte(fonte) {
    if (fonte === 'Cut') return '<span class="badge b-blue"><i class="fas fa-scissors"></i> CUT</span>';
    if (fonte === 'Narrastars') return '<span class="badge b-purple"><i class="fas fa-star"></i> NARRASTARS</span>';
    return '<span class="badge b-neutral"><i class="fas fa-database"></i> RESULTADOS</span>';
  }

  function renderAprovacao(items, append) {
    if (!append) resultsContainer.innerHTML = '<h3 class="section-badge">Resultados de Aprovação</h3>';
    const frag = document.createDocumentFragment();

    items.forEach(item => {
      const [bClass, bIcon, bLabel] = badgeStatus(item.statusResultado);
      const fonteClass = item.fonte === 'Cut' ? 'from-cut' : item.fonte === 'Narrastars' ? 'from-narrastars' : '';
      const temRecrutador = item.recrutador && item.recrutador !== 'FP Agency';
      const temPerfil = safeUrl(item.perfilUrl);
      const temMotivo = item.motivo && item.motivo.trim();

      const card = document.createElement('div');
      card.className = `result-card ${fonteClass}`;
      card.innerHTML = `
        <div class="rc-head">
          <div class="rc-name-block">
            <span class="rc-name">${esc(item.nomeCompleto) || '<em style="opacity:.5">Não identificado</em>'}</span>
            <span class="rc-fonte">${esc(item.fonte || 'Resultados')}</span>
          </div>
          <div class="rc-badges">
            ${badgeFonte(item.fonte)}
            <span class="badge ${bClass}"><i class="fas ${bIcon}"></i> ${esc(bLabel)}</span>
          </div>
        </div>
        <div class="rc-grid">
          <div class="db"><span class="db-label">Data</span><span class="db-value">${esc(item.data) || '-'}</span></div>
          <div class="db"><span class="db-label">Categoria</span><span class="db-value">${esc(item.categoria) || '-'}</span></div>
          <div class="db"><span class="db-label">WhatsApp</span><span class="db-value">${esc(item.whatsapp) || '-'}</span></div>
          <div class="db"><span class="db-label">Perfil</span><span class="db-value">${temPerfil ? mkLink(item.perfilUrl) : '-'}</span></div>
          ${temMotivo ? `<div class="db"><span class="db-label">Motivo</span><span class="db-value" style="font-size:.82rem; color:var(--text-muted)">${esc(item.motivo)}</span></div>` : ''}
        </div>
        ${temRecrutador ? `
        <div class="rc-recruiter">
          <div class="rc-recruiter-label"><i class="fas fa-user-tie"></i> Recrutado por</div>
          <div class="db"><span class="db-label">Recrutador</span><span class="db-value">${esc(item.recrutador)}</span></div>
          <div class="db"><span class="db-label">WhatsApp</span><span class="db-value">${esc(item.whatsRecrutador) || '-'}</span></div>
        </div>` : ''}
      `;
      frag.appendChild(card);
    });
    resultsContainer.appendChild(frag);
  }

  function renderRelatorios(items, append) {
    if (!append) resultsContainer.innerHTML = '<h3 class="section-badge">Histórico de Relatórios</h3>';
    const frag = document.createDocumentFragment();

    items.forEach(item => {
      const totalInt = parseInt(item.totalVv, 10);
      const views = isNaN(totalInt) ? esc(item.totalVv || '0') : totalInt.toLocaleString('pt-BR');
      const uid = item.uid || '';
      const kwai = uid ? `https://www.kwai.com/@${uid}` : '';

      const card = document.createElement('div');
      card.className = 'result-card';
      card.innerHTML = `
        <div class="rc-head">
          <div class="rc-name-block">
            <span class="rc-name">${esc(item.nomeUsuario) || '-'}</span>
            <span class="rc-fonte">${esc(item.categoria) || '-'}</span>
          </div>
          <div class="rc-badges"><span class="tag-mes">${esc(item.mesReferencia) || '-'}</span></div>
        </div>
        <div class="rc-grid">
          <div class="db">
            <span class="db-label">UID Kwai</span>
            <span class="db-value" style="font-size:.82rem; color:var(--text-muted); font-family:var(--mono)">${esc(uid) || '-'}</span>
            ${kwai ? mkLink(kwai, 'Ver Perfil') : ''}
          </div>
          <div class="db"><span class="db-label">Taxa Vert.</span><span class="db-value" style="color:var(--orange)">${esc(item.taxaVerticalidade) || '-'}</span></div>
          <div class="db"><span class="db-label">Data Início</span><span class="db-value">${esc(item.dataInicio) || '-'}</span></div>
          <div class="db"><span class="db-label">Vídeos Válidos</span><span class="db-value">${esc(item.videosValidos) || '0'}</span></div>
          <div class="db"><span class="db-label">Total Views</span><span class="db-value">${views}</span></div>
        </div>
      `;
      frag.appendChild(card);
    });
    resultsContainer.appendChild(frag);
  }

  function renderSite(termo) {
    resultsContainer.innerHTML = '<h3 class="section-badge">Resultados no Site</h3>';
    
    // Busca inteligente com Fuse.js
    const resultadosLocal = fuse.search(termo);
    
    if (resultadosLocal.length === 0) {
      setFeedback("Nenhuma página encontrada para essa palavra-chave.");
      return;
    }

    const carousel = document.createElement('div');
    carousel.className = 'site-carousel';

    const frag = document.createDocumentFragment();
    resultadosLocal.forEach(res => {
      const item = res.item;
      // Destaque visual da pesquisa (Highlight)
      const nomeHi = highlight(item.nome, termo);
      
      const card = document.createElement('a');
      card.href = item.url;
      card.className = 'site-link-card';
      card.innerHTML = `
        <div class="site-link-icon"><i class="fas ${item.icon}"></i></div>
        <div class="site-link-info">
          <h4>${nomeHi}</h4>
          <p>${esc(item.desc)}</p>
        </div>
        <div class="site-link-action">
          Acessar <i class="fas fa-arrow-right"></i>
        </div>
      `;
      frag.appendChild(card);
    });
    
    carousel.appendChild(frag);
    resultsContainer.appendChild(carousel);
  }

  function renderPagination(tipo) {
    const s = state[tipo];
    const old = resultsContainer.querySelector('.fp-pagination');
    if (old) old.remove();
    if (s.page >= s.pages) return;

    const shown = Math.min(s.page * PAGE_SIZE, s.total);
    const pag = document.createElement('div');
    pag.className = 'fp-pagination';
    pag.innerHTML = `
      <span class="fp-pag-info">${shown} de ${s.total} resultados</span>
      <button class="btn-more" data-tipo="${tipo}">
        <i class="fas fa-chevron-down"></i> Carregar mais
      </button>`;
    resultsContainer.appendChild(pag);
  }

  // ── Lógica Central de Busca (BLINDADA CONTRA TRAVAMENTOS) ────────────────
  async function executarBusca(tipo, append = false) {
    if (tipo === 'site') {
      const termoSite = document.getElementById('in-site').value.trim();
      if (termoSite.length < MIN_TERM) {
        setFeedback(`Digite ao menos ${MIN_TERM} caracteres para buscar no site.`);
        return;
      }
      renderSite(termoSite);
      return;
    }

    const s = state[tipo];
    if (s.loading) {
      console.warn(`[Aviso] Busca de ${tipo} já está em andamento.`);
      return; 
    }

    // IDs foram devidamente mapeados para relatorio no singular
    const inputId  = `in-${tipo}`;
    const selectId = `sel-${tipo}`;
    const btnId    = `btn-${tipo}`;
    const action   = tipo === 'aprovacao' ? 'buscarAprovacao' : 'buscarRelatorios';

    const termo  = document.getElementById(inputId).value.trim();
    const filtro = document.getElementById(selectId).value;
    const btn    = document.getElementById(btnId);

    if (!termo || termo.length < MIN_TERM) {
      setFeedback(`Digite ao menos ${MIN_TERM} caracteres.`);
      return;
    }

    if (!append) {
      s.page = 1;
      s.termo = termo;
      s.filtro = filtro;
    }

    s.loading = true;
    if(btn) btn.disabled = true;
    
    if (!append) setFeedback('Acessando servidor FP Agency...');
    showLoader();

    try {
      console.log(`[Requisicao] Solicitando ${action} para: "${s.termo}"`);
      const res = await fetchAPI(action, s.termo, s.filtro, s.page);
      console.log(`[Resposta] ${action} retornou com sucesso.`);

      if (!res || res.status === 'error') {
        setFeedback(res?.message || 'Erro desconhecido no servidor.', true);
        return;
      }

      s.total = res.total || 0;
      s.pages = res.pages || 1;

      if (!res.data || res.data.length === 0) {
        if (!append) setFeedback('Nenhum registro encontrado para esta busca na base.');
        return;
      }

      if (tipo === 'aprovacao') renderAprovacao(res.data, append);
      else renderRelatorios(res.data, append);

      renderPagination(tipo);

    } catch (err) {
      console.error(`[Falha Crítica] Erro ao buscar ${tipo}:`, err);
      if (err.name === 'AbortError') return;
      setFeedback(err.message, true);
    } finally {
      hideLoader();
      s.loading = false;
      if(btn) btn.disabled = false;
    }
  }

  // ── Listeners de Evento ───────────────────────────────────────────────────
  document.getElementById('btn-aprovacao').addEventListener('click', () => executarBusca('aprovacao'));
  
  // Alterado para corresponder perfeitamente à string "relatorio"
  document.getElementById('btn-relatorio').addEventListener('click', () => executarBusca('relatorio'));
  document.getElementById('btn-site').addEventListener('click', () => executarBusca('site'));

  const onEnterA = debounce(() => executarBusca('aprovacao'), DEBOUNCE_MS);
  const onEnterR = debounce(() => executarBusca('relatorio'), DEBOUNCE_MS);
  const onEnterS = debounce(() => executarBusca('site'), DEBOUNCE_MS);

  document.getElementById('in-aprovacao').addEventListener('keydown', e => { if (e.key==='Enter') onEnterA(); });
  document.getElementById('in-relatorio').addEventListener('keydown', e => { if (e.key==='Enter') onEnterR(); });
  document.getElementById('in-site').addEventListener('keydown', e => { if (e.key==='Enter') onEnterS(); });

  document.addEventListener('click', e => {
    const btn = e.target.closest('.btn-more');
    if (btn) {
      const tipo = btn.dataset.tipo;
      if (tipo) { state[tipo].page++; executarBusca(tipo, true); }
    }
  });

  // ── Leitura de URL (?q=) ──────────────────────────────────────────────────
  document.addEventListener('DOMContentLoaded', () => {
    const params = new URLSearchParams(window.location.search);
    const query  = params.get('q');

    if (query && query.trim() !== '') {
      document.getElementById('in-aprovacao').value = query.trim();
      executarBusca('aprovacao');
    }
  });
</script>

<style is:global>
  /* ─── TOKENS E RESET ─────────────────────────────────────────────────────── */
  :root {
    --bg-card: #181c27;
    --bg-input: #1e2332;
    --border: #2a3048;
    --border-hover: #3d4d7a;
    --orange: #ff6b2b;
    --orange-dim: #ff6b2b22;
    --orange-glow: rgba(255,107,43,.25);
    --green: #22c55e;
    --green-dim: #22c55e1a;
    --red: #ef4444;
    --red-dim: #ef44441a;
    --yellow: #f59e0b;
    --yellow-dim: #f59e0b1a;
    --blue: #3b82f6;
    --blue-dim: #3b82f61a;
    --text: #e2e8f0;
    --text-muted: #94a3b8;
    --text-faint: #475569;
    --radius: 12px;
    --radius-lg: 20px;
