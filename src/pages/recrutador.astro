function maskPhone(i) { let v=i.value.replace(/\D/g,''); if(v.length>11)v=v.slice(0,11); v=v.replace(/^(\d{2})(\d)/g,'($1) $2'); v=v.replace(/(\d)(\d{4})$/,'$1-$2'); i.value=v; }
function maskCPF(i)   { let v=i.value.replace(/\D/g,''); if(v.length>11)v=v.slice(0,11); v=v.replace(/(\d{3})(\d)/,'$1.$2'); v=v.replace(/(\d{3})(\d)/,'$1.$2'); v=v.replace(/(\d{3})(\d{1,2})$/,'$1-$2'); i.value=v; }

function verificarIdade(inputData) {
  const btn=document.getElementById('btnReg');
  const blocoResp=document.getElementById('blocoResponsavel'); const iNome=document.getElementById('nomeResp'); const iCpf=document.getElementById('cpfResp');
  const dataD=new Date(inputData.value+'T00:00:00'); if(!inputData.value) return;
  const hoje=new Date(); let idade=hoje.getFullYear()-dataD.getFullYear();
  if(hoje.getMonth()<dataD.getMonth()||(hoje.getMonth()===dataD.getMonth()&&hoje.getDate()<dataD.getDate())) idade--;
  if(idade<14){ globalAlert("Bloqueado","Mínimo de 14 anos.","error"); btn.disabled=true; inputData.value=''; blocoResp.style.display='none'; iNome.required=false; iCpf.required=false; }
  else if(idade<16){ blocoResp.style.display='block'; iNome.required=true; iCpf.required=true; btn.disabled=false; globalAlert("Declaração Legal","Você precisa de autorização do responsável legal.","warning"); }
  else { blocoResp.style.display='none'; iNome.required=false; iCpf.required=false; btn.disabled=false; }
}

document.getElementById('formCadastro').onsubmit = async (e) => {
  e.preventDefault();
  const btn=document.getElementById('btnReg'); if(btn.disabled) return;
  const emailRegex=/^[^\s@]+@[^\s@]+\.[^\s@]+$/;
  if(!emailRegex.test(e.target.email.value)){ globalAlert("Atenção","E-mail inválido.","warning"); return; }
  if(e.target.cpf.value.length!==14){ globalAlert("Atenção","CPF incompleto.","warning"); return; }
  if(!document.getElementById('cad-dataNasc').value){ globalAlert("Atenção","Preencha a data de nascimento.","warning"); return; }
  const dArr=e.target.dataNasc.value.split('-');
  const dtFmt=`${dArr[2]}/${dArr[1]}/${dArr[0]}`;
  btn.disabled=true; btn.innerText="CRIANDO..."; showLoader();
  const formData={ nome:e.target.nome.value, email:e.target.email.value, cpf:e.target.cpf.value, whatsapp:e.target.whatsapp.value, chavePix:e.target.chavePix.value, dataNasc:dtFmt, nomeResp:e.target.nomeResp.value, cpfResp:e.target.cpfResp.value, termosAgreed:"Sim", idadeAgreed:"Sim" };
  try {
    let idToken; const cu=firebase.auth().currentUser;
    if(cu&&cu.email===e.target.email.value){ await cu.updatePassword(e.target.senha.value); idToken=await cu.getIdToken(); }
    else { const uc=await firebase.auth().createUserWithEmailAndPassword(e.target.email.value,e.target.senha.value); idToken=await uc.user.getIdToken(); }
    const res=await gsRun('cadastrarUsuarioPlanilha',{ idToken, form:formData });
    hideLoader(); btn.disabled=false; btn.innerText="CRIAR CONTA";
    if(res.success){ globalAlert("Bem-Vindo!","Conta criada com sucesso!","success"); e.target.reset(); document.getElementById('blocoResponsavel').style.display='none'; document.getElementById('btnGoogleCad').style.display='flex'; document.getElementById('div-ou-cad').style.display='flex'; document.getElementById('cad-email').readOnly=false; document.getElementById('cad-email').style.backgroundColor='#f8fafc'; firebase.auth().signOut(); nav('Login'); }
    else { globalAlert("Atenção",res.msg,"warning"); }
  } catch(error) {
    hideLoader(); btn.disabled=false; btn.innerText="CRIAR CONTA";
    let msg="Erro ao criar conta.";
    if(error.code==='auth/email-already-in-use') msg="Este e-mail já está em uso.";
    if(error.code==='auth/weak-password') msg="Senha deve ter pelo menos 6 caracteres.";
    globalAlert("Falha",msg,"error");
  }
};

