      else globalAlert("Erro","Falha ao processar exclusão.","error");
    } finally{hideLoader();}
  });
}

/* Avisos */
function formatarTexto(texto) {
  if(!texto) return '';
  let html=texto, placeholders=[];
  
  html=html.replace(/@([^+]+)\+¿([^¿]+)¿@/g,(_,url,txt)=>{ let i=placeholders.length; placeholders.push(`<a href="${url.trim()}" onclick="openLink(event,this.href)" style="display:inline-block;background:var(--primary,#ea580c);color:white;padding:10px 18px;border-radius:8px;text-decoration:none;font-weight:bold;margin:8px 0">${txt.trim()}</a>`); return `__B${i}__`; });
  const urlRe=/(\b(https?|ftp|file):\/\/[-A-Z0-9+&@#\/%?=~_|!:,.;]*[-A-Z0-9+&@#\/%=~_|])/ig;
  html=html.replace(urlRe,url=>`<a href="${url}" onclick="openLink(event,this.href)" style="color:#ea580c;text-decoration:underline;word-break:break-all">${url}</a>`);
  html=html.replace(/^### (.*?)$/gm,'<h4 style="color:#1e293b;margin:15px 0 5px;font-size:1.1rem;font-weight:700">$1</h4>');
  html=html.replace(/^## (.*?)$/gm,'<h3 style="color:#1e293b;margin:18px 0 8px;font-size:1.3rem;font-weight:800">$1</h3>');
  html=html.replace(/^# (.*?)$/gm,'<h2 style="color:#1e293b;margin:20px 0 10px;font-size:1.6rem;font-weight:900">$1</h2>');
  html=html.replace(/^> (.*?)$/gm,'<blockquote style="border-left:4px solid #cbd5e1;background:#f8fafc;padding:10px 15px;color:#475569;margin:10px 0;border-radius:0 8px 8px 0;font-style:italic">$1</blockquote>');
  html=html.replace(/^---$/gm,'<hr style="border:0;border-top:2px dashed #e2e8f0;margin:20px 0">');
  html=html.replace(/\[([^\]]+)\]/g,'<span style="background:#e0f2fe;color:#0369a1;padding:3px 10px;border-radius:12px;font-size:.75rem;font-weight:700;text-transform:uppercase;letter-spacing:.5px;display:inline-block;margin-bottom:5px">$1</span>');
  html=html.replace(/`([^`]+)`/g,'<span style="color:#fb923c;text-decoration:underline;font-weight:500">$1</span>');
  html=html.replace(/\*(.*?)\*/g,'<strong>$1</strong>');
  html=html.replace(/_([^_]+)_/g,'<em>$1</em>');
  html=html.replace(/~([^~]+)~/g,'<del style="color:#94a3b8">$1</del>');
  placeholders.forEach((el,i)=>{ html=html.replace(`__C${i}__`,el).replace(`__B${i}__`,el); });
  return html;
}

