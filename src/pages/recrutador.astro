.rc-btn-primary { display:inline-flex; align-items:center; gap:9px; background:var(--orange); color:#fff; font-family:'Sora',sans-serif; font-weight:700; font-size:.92rem; padding:14px 28px; border-radius:99px; text-decoration:none; border:none; cursor:pointer; box-shadow:0 6px 24px var(--orange-glow); transition:transform .18s,box-shadow .18s; }
.rc-btn-primary:hover { transform:translateY(-3px); box-shadow:0 10px 32px var(--orange-glow); color:#fff; }
.rc-btn-secondary { display:inline-flex; align-items:center; gap:9px; background:var(--bg-card); color:var(--text); font-family:'Sora',sans-serif; font-weight:600; font-size:.92rem; padding:14px 28px; border-radius:99px; text-decoration:none; border:1px solid var(--border); cursor:pointer; transition:border-color .18s,transform .18s; }
.rc-btn-secondary:hover { border-color:var(--border-h); transform:translateY(-2px); color:var(--text); }

.rc-marquee-wrap { overflow:hidden; border-top:1px solid rgba(255,255,255,.06); border-bottom:1px solid rgba(255,255,255,.06); margin:36px 0 52px; }
