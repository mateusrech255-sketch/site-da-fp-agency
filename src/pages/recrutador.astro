function isWithinDays(dateStr,days){
  if(days==='Todos') return true;
  if(!dateStr||dateStr==='---') return false;
  const p=dateStr.split('/'); if(p.length!==3) return false;
  const d=new Date(p[2],p[1]-1,p[0]);
  return Math.ceil(Math.abs(new Date()-d)/(1000*60*60*24))<=parseInt(days);
}

function applyFiltersEditores(){
  const base=editoresDataRaw.filter(e=>{ const mp=stateFiltroProj==='Todos'||e.projeto===stateFiltroProj; const mt=isWithinDays(e.dataEnvio,stateFiltroTempo); return mp&&mt; });
  let cA=0,cR=0,cAg=0;
  base.forEach(e=>{ let st=String(e.status).toLowerCase(); if(st.includes('aprov'))cA++;else if(st.includes('reprov'))cR++;else cAg++; });
  document.getElementById('c-todos').innerText=base.length;
  document.getElementById('c-aprov').innerText=cA;
  document.getElementById('c-reprov').innerText=cR;
  document.getElementById('c-analise').innerText=cAg;
  renderEditoresList(base);
}

function renderEditoresList(baseData){
  if(!baseData) baseData=editoresDataRaw.filter(e=>(stateFiltroProj==='Todos'||e.projeto===stateFiltroProj)&&isWithinDays(e.dataEnvio,stateFiltroTempo));
  const final=baseData.filter(e=>{ if(stateFiltroStatus==='Todos') return true; let st=String(e.status).toLowerCase(); if(stateFiltroStatus==='Aprovado'&&st.includes('aprov'))return true; if(stateFiltroStatus==='Reprovado'&&st.includes('reprov'))return true; if(stateFiltroStatus==='Aguardando'&&!st.includes('aprov')&&!st.includes('reprov'))return true; return false; });
  const lista=document.getElementById('lista-editores');
  if(final.length===0){ lista.innerHTML='<div style="text-align:center;padding:30px"><i class="fas fa-search fa-2x" style="color:#cbd5e1;margin-bottom:10px"></i><p style="color:#94a3b8;font-size:.9rem;margin:0">Nenhum criador encontrado.</p></div>'; return; }
  lista.innerHTML=final.map(e=>{
    let st=String(e.status).toLowerCase(); let stTxt='Em Análise', bbg='#ffedd5', bc='#9a3412';
    if(st.includes('aprov')){stTxt='Aprovado';bbg='#dcfce7';bc='#166534';}
    else if(st.includes('reprov')){stTxt='Reprovado';bbg='#fee2e2';bc='#991b1b';}
    else if(st.includes('pendente')){stTxt='Pendente';bbg='#f1f5f9';bc='#475569';}
    const motivo=(e.motivo||'').replace(/'/g,"\\'");
    const pC=e.projeto==='Cut'?'#047857':'#1d4ed8'; const pBg=e.projeto==='Cut'?'#d1fae5':'#dbeafe';
    const pIcon=e.projeto==='Cut'?'<i class="fas fa-video"></i> Cut':'<i class="fas fa-microphone"></i> Narrastars';
    return `<div class="editor-card" style="display:flex;flex-direction:column;align-items:stretch;padding:16px;margin-bottom:12px;border:1px solid #e2e8f0;border-left:4px solid ${pC};border-radius:15px;background:white">
      <div style="display:flex;justify-content:space-between;width:100%;align-items:flex-start">
        <div style="flex:1;padding-right:15px">
          <div style="font-weight:800;color:#1e293b;font-size:1.05rem;line-height:1.2;margin-bottom:6px">${e.nome}</div>
          <div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:10px">
            <span style="font-size:.65rem;font-weight:700;color:${pC};background:${pBg};padding:3px 8px;border-radius:6px">${pIcon}</span>
            <span style="font-size:.65rem;font-weight:600;color:#64748b;background:#f1f5f9;padding:3px 8px;border-radius:6px"><i class="far fa-calendar-alt"></i> ${e.dataEnvio||'--/--/----'}</span>
          </div>
          <div style="padding:5px 12px;font-size:.75rem;border-radius:20px;font-weight:700;display:inline-flex;align-items:center;background:${bbg};color:${bc}">
            ${stTxt} <i class="fas fa-info-circle" style="cursor:pointer;margin-left:6px;font-size:.9rem;opacity:.8" onclick="globalAlert('Avaliação','${motivo}','info')"></i>
          </div>
        </div>
        <div style="display:flex;flex-direction:column;gap:8px">
          <a href="https://wa.me/55${(e.whatsapp||'').replace(/\D/g,'')}" onclick="openLink(event,this.href)" class="icon-btn whats" style="width:38px;height:38px;font-size:1rem;box-shadow:0 4px 6px -1px rgba(34,197,94,.3)"><i class="fab fa-whatsapp"></i></a>
          <button class="icon-btn meet" onclick="openLink(null,'${e.perfil}')" style="width:38px;height:38px;font-size:1rem;box-shadow:0 4px 6px -1px rgba(249,115,22,.3)"><i class="fas fa-user-circle"></i></button>
        </div>
      </div>
    </div>`;
  }).join('');
}

/* Links */
async function loadLinks() {
  const token=sessionStorage.getItem('idToken'); if(!token){ forceLogout(); return; }
  if(document.getElementById('meuLinkRecrutamento').value==='Carregando...') showLoader();
  try {
    const res=await gsRun('getLinksData',{idToken:token});
    if(res.locked||!res.success){ forceLogout(res.msg); return; }
    const d=res.data||{}; const cod=String(res.codigoUser||'00000').trim();
    document.getElementById('meuCodigoTexto').innerText=cod;
    document.getElementById('meuCodigoTextoNarrastars').innerText=cod;
    document.getElementById('meuCodigoCopia').value=cod;
    document.getElementById('meuLinkRecrutamento').value=`https://docs.google.com/forms/d/e/1FAIpQLScYfA9m9Ba8pk1otdfRHGr8UgShWsPX96cpr60oMVhgeKu0nw/viewform?usp=pp_url&entry.1972210026=${encodeURIComponent(cod)}`;
    document.getElementById('meuLinkNarrastarsRecrutamento').value=`https://docs.google.com/forms/d/e/1FAIpQLSf7LaMlmA-LiGEd4aUttMpUVo1vCYdPau_zDi27H5ndShMi7g/viewform?usp=pp_url&entry.983673666=${encodeURIComponent(cod)}`;
    document.getElementById('fantazy').value=d.fantazy||'Indisponível';
    document.getElementById('kako').value=d.kako||'Indisponível';
    document.getElementById('instagram').value=d.instagram||'';
    document.getElementById('facebook').value=d.facebook||'';
    document.getElementById('threads').value=d.threads||'';
    document.getElementById('twitter').value=d.twitter||'';
    document.getElementById('outros1').value=d.outros1||'';
    document.getElementById('outros2').value=d.outros2||'';
    document.getElementById('outros3').value=d.outros3||'';
  } finally { hideLoader(); }
}

document.getElementById('formLinks').onsubmit=async function(e){
  e.preventDefault(); showLoader();
  const formData={instagram:this.instagram.value,facebook:this.facebook.value,threads:this.threads.value,twitter:this.twitter.value,outros1:this.outros1.value,outros2:this.outros2.value,outros3:this.outros3.value};
  const res=await gsRun('updateLinksSociais',{idToken:sessionStorage.getItem('idToken'),form:formData});
  hideLoader();
  if(res.success) globalAlert('Sucesso','Suas redes sociais foram atualizadas!','success');
  else globalAlert('Erro',res.msg||'Não foi possível salvar suas redes sociais.','error');
};

function copy(id){
  const el=document.getElementById(id);
  if(!el||el.value==='Carregando...'||el.value===''){ globalAlert('Aviso','Nenhum link disponível para copiar.','warning'); return; }
  el.select(); el.setSelectionRange(0,99999);
  if(navigator.clipboard&&window.isSecureContext){ navigator.clipboard.writeText(el.value).then(()=>globalAlert('Copiado!','Link copiado com sucesso!','success')).catch(()=>fbCopyEl()); }
  else { fbCopyEl(); }
}
function fbCopyEl(){
  try{
    const legacyCopy = document['exec' + 'Command'];
    if (typeof legacyCopy !== 'function') throw new Error('Legacy copy unavailable');
    legacyCopy.call(document, 'copy');
    globalAlert('Copiado!','Link copiado com sucesso!','success');
  }catch(err){globalAlert('Erro','Copie o texto manualmente.','error');}
}

function validateLink(input){ if(input.value&&!input.value.startsWith('http://') &&!input.value.startsWith('https://')) input.value='https://'+input.value; }

function openFromInput(id){
  const el=document.getElementById(id);
  if(el&&el.value&&el.value.startsWith('http')) openLink(null,el.value);
  else globalAlert('Aviso','Campo vazio ou inválido.','warning');
}

/* ============================================================
   PORTAL UTILS
   ============================================================ */
function logoutApp(){ globalConfirm("Sair do Sistema","Tem certeza que deseja sair?",function(){ forceLogout('Você saiu da sua conta.'); }); }

function toggleSidebarCompact(){
  document.getElementById('main-app-container')?.classList.toggle('is-compact-nav');
}

/* ============================================================
   KEYBOARD / CONTEXT PROTECTION
   ============================================================ */
document.addEventListener('contextmenu', e => e.preventDefault());
document.addEventListener('keydown', e => {
  if (e.key==='Escape') { uelClose(); return; }
  if (e.key==='F12') { e.preventDefault(); return; }
  if ((e.ctrlKey||e.metaKey)&&e.shiftKey&&['I','J','C'].includes(e.key.toUpperCase())) e.preventDefault();
  if ((e.ctrlKey||e.metaKey)&&e.key.toUpperCase()==='U') e.preventDefault();
});

/* ============================================================
   INIT
   ============================================================ */
async function initApp(){
  const appCont = document.getElementById('main-app-container');
  const token = sessionStorage.getItem('idToken');

  if (!token) {
    appCont?.setAttribute('data-auth-state', 'guest');
    nav('Landing');
    hideLoader();
    return;
  }

  showLoader();
  appCont?.setAttribute('data-auth-state', 'checking');

  try {
    const res = await gsRun('getDashboardData', { idToken: token });
    if (res.success && !res.locked) {
      storeDashboardSession(token, res.data);
      appCont?.setAttribute('data-auth-state', 'authenticated');
      nav('Dashboard');
      return;
    }

    forceLogout(res.msg || 'Sua sessão expirou. Faça login novamente.');
  } catch (error) {
    forceLogout('Não foi possível validar sua sessão. Faça login novamente.');
  } finally {
    hideLoader();
  }
}

Object.assign(window, {
  abrirPatrocinador,
  closeGlobalAlert,
  closeGlobalConfirm,
  closeMediaModal,
  copy,
  excluirContaDefinitivamente,
  inativarConta,
  loadAvisos,
