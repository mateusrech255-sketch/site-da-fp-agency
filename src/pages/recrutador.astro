async function loadDashboard() {
  const token=sessionStorage.getItem('idToken'); if(!token){ forceLogout(); return; }
  const imgEl=document.getElementById('uFoto'); const nomeS=sessionStorage.getItem('user_nome')||'Usuário'; const fotoS=sessionStorage.getItem('user_foto');
  if(fotoS&&fotoS.trim()) imgEl.src=fotoS.trim(); else imgEl.src=`https://ui-avatars.com/api/?name=${encodeURIComponent(nomeS)}&background=fed7aa&color=c2410c&bold=true&size=256`;
  if(document.getElementById('uName').innerText==='...') showLoader();
  try {
    const d=await gsRun('getDashboardData',{idToken:token});
    if(d.locked||!d.success){ forceLogout(d.msg); return; }
    const nome=d.data.nome||'Usuário';
    document.getElementById('uName').innerText = nome.split(' ')[0];
    document.getElementById('uSaldo').innerText = 'R$ '+(d.data.saldo||'0,00');
    document.getElementById('uEquipe').innerText = d.data.equipe||'0';
    document.getElementById('uNivel').innerText  = d.data.nivel||'-';
    sessionStorage.setItem('user_nome',nome); sessionStorage.setItem('user_foto',d.data.avatar||''); sessionStorage.setItem('user_nivel',d.data.nivel||'Bronze');
    if(d.data.avatar&&d.data.avatar.trim()) imgEl.src=d.data.avatar.trim();
    else imgEl.src=`https://ui-avatars.com/api/?name=${encodeURIComponent(nome)}&background=fed7aa&color=c2410c&bold=true&size=256`;
  } finally { hideLoader(); }
}

async function loadFinanceiro() {
  const token=sessionStorage.getItem('idToken'); if(!token){ forceLogout(); return; }
  const listaFin=document.getElementById('lista-financeiro');
  if(listaFin.innerHTML.trim()==='') showLoader();
  try {
    const res=await gsRun('getFinanceiroData',{idToken:token});
    if(res.locked||!res.success){ forceLogout(res.msg); return; }
    document.getElementById('saldo-fin').innerText='R$ '+res.data.saldo;
    if(!res.data.historico||res.data.historico.length===0){ listaFin.innerHTML='<p style="text-align:center;color:#94a3b8;margin-top:20px">Nenhuma transação.</p>'; return; }
    listaFin.innerHTML=res.data.historico.map(h=>{
      let isSaque=String(h.tipo).toLowerCase().includes('saque'); let st=String(h.status).toLowerCase(); let sc='#64748b';
      if(st.includes('pendente')||st.includes('solicitado')) sc='#f59e0b';
      else if(st.includes('pago')||st.includes('realizado')||st.includes('aprovado')) sc='#10b981';
      else if(st.includes('recusado')||st.includes('cancelado')) sc='#ef4444';
      let bc=isSaque?'out':(st.includes('bônus')?'bonus':'in'); let vc=isSaque?'#ef4444':'#10b981';
      return `<div class="hist-item"><div style="display:flex;align-items:center"><div class="icon-box ${bc}"><i class="fas fa-${isSaque?'arrow-down':(st.includes('bônus')?'gift':'arrow-up')}"></i></div><div><div style="font-weight:800;color:#1e293b;font-size:.95rem">${h.tipo}</div><div style="font-size:.75rem;color:#94a3b8;margin-top:2px">${h.data}</div></div></div><div style="text-align:right"><div style="font-weight:900;font-size:1.05rem;color:${vc}">${isSaque?'-':'+'} R$ ${h.valor}</div><div style="font-size:.75rem;font-weight:700;color:${sc};margin-top:2px">${h.status}</div><div style="font-size:.65rem;color:#cbd5e1;font-family:monospace;margin-top:2px">${h.id?`ID: #${h.id}`:''}</div></div></div>`;
    }).join('');
  } finally { hideLoader(); }
}

function tentarSaque() {
  const saldo=parseFloat(document.getElementById('saldo-fin').innerText.replace('R$ ','').replace(/\./g,'').replace(',','.'));
  if(isNaN(saldo)||saldo<=0){ globalAlert("Atenção","Sem saldo disponível.","warning"); return; }
  const nivel=(sessionStorage.getItem('user_nivel')||'Bronze').toLowerCase();
  if((nivel==='bronze'||nivel==='prata')&&!anuncioVisualizado){ document.getElementById('patrocinadorModal').classList.add('active'); return; }
  globalConfirm("Confirmar Saque","Deseja solicitar o saque de todo o seu saldo disponível?",executarSaque);
}
