async function salvarPerfil() {
  const nome=document.getElementById('ui_nome').value.trim(); const novaSenha=document.getElementById('ui_senha').value;
  if(nome===''){ globalAlert("Atenção","Nome não pode ficar vazio.","warning"); return; }
