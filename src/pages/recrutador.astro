const API_URL = "https://script.google.com/macros/s/AKfycbx30E6Ty1JMZeBGRbAmqe6yHG7uRp1K_wXr198sSoURs_uNtwIa90NMSi-_k9H29dhd/exec";

/* ============================================================
   WEBVIEW DETECTION + UNIVERSAL LINK HANDLER
   ============================================================ */
function isLockedWebView() {
  const ua = navigator.userAgent || '';
  return /(Kwai|Instagram|FBAN|FBAV|TikTok|Line\/|MicroMessenger|Snapchat|wv\b|WebView)/i.test(ua);
}
function isAndroid() { return /Android/i.test(navigator.userAgent); }

function openLink(e, url) {
  if (e) e.preventDefault();
  if (!url || !url.startsWith('http')) return;
  if (isLockedWebView()) { uelShow(url); return; }
  const w = window.open(url, '_blank', 'noopener,noreferrer');
  if (!w || w.closed || typeof w.closed === 'undefined') window.location.href = url;
}

/* ── Unified Exit Layer ── */
function uelShow(url) {
  window.__uel_url = url;
  const d = document.getElementById('uel-url-display');
  if (d) d.textContent = url.replace(/^https?:\/\//, '');
  const b = document.getElementById('uel-copy-btn');
  if (b) { b.classList.remove('copied'); b.innerHTML = '<i class="ri-clipboard-line"></i> Copiar Link'; }
  document.getElementById('unified-exit-layer').classList.add('show');
  document.body.style.overflow = 'hidden';
}
function uelClose() {
  document.getElementById('unified-exit-layer').classList.remove('show');
  document.body.style.overflow = '';
  window.__uel_url = null;
}
function uelForceExternal() {
  const url = window.__uel_url; if (!url) return;
  if (isAndroid()) { window.location.href = 'intent://' + url.replace(/^https?:\/\//, '') + '#Intent;scheme=https;action=android.intent.action.VIEW;end'; return; }
  window.location.href = url;
}
function uelCopyUrl() {
  const url = window.__uel_url; if (!url) return;
  const btn = document.getElementById('uel-copy-btn');
  const ok  = () => { if(btn){btn.classList.add('copied');btn.innerHTML='<i class="ri-check-line"></i> Copiado! Cole no navegador';} };
  const err = () => { if(btn) btn.innerHTML='<i class="ri-close-line"></i> Erro ao copiar'; };
  if (navigator.clipboard && navigator.clipboard.writeText) { navigator.clipboard.writeText(url).then(ok).catch(()=>fbCopy(url,ok,err)); }
  else { fbCopy(url,ok,err); }
}
function fbCopy(url,ok,err) {
  try {
    const t=document.createElement('textarea');
    const legacyCopy = document['exec' + 'Command'];
    if (typeof legacyCopy !== 'function') throw new Error('Legacy copy unavailable');
    t.value=url; t.style.cssText='position:fixed;opacity:0;top:0;left:0;'; document.body.appendChild(t); t.focus(); t.select(); legacyCopy.call(document, 'copy'); document.body.removeChild(t); ok();
  } catch(_){err();}
}

/* Auto-patch all external links */
function patchAllLinks() {
  document.querySelectorAll('a[href^="http"]').forEach(link => {
    if (link.dataset.patched) return;
    link.removeAttribute('target');
    link.setAttribute('rel', 'noopener noreferrer external');
    link.addEventListener('click', function(e){ openLink(e, this.href); });
    link.dataset.patched = '1';
  });
}

/* ============================================================
   NAVIGATION
   ============================================================ */
const PUBLIC_VIEWS = new Set(['Landing', 'Diretrizes', 'Login', 'Cadastro', 'Redefinir']);
let _prevPage = 'Landing';

function isPublicView(page) {
  return PUBLIC_VIEWS.has(page);
}

function hasValidSessionToken() {
  return Boolean(sessionStorage.getItem('idToken'));
}

function storeDashboardSession(idToken, data) {
  sessionStorage.setItem('idToken', idToken);
  sessionStorage.setItem('user_nome',  data?.nome || '');
  sessionStorage.setItem('user_nivel', data?.nivel || '');
  sessionStorage.setItem('user_foto',  data?.avatar || data?.foto || '');
}

function setShellState(page) {
  const appCont = document.getElementById('main-app-container');
  const isPublic = isPublicView(page);
  if (!appCont) return;

  appCont.dataset.portalState = isPublic ? 'public' : 'private';
  appCont.dataset.activeView = page;
  appCont.dataset.authState = hasValidSessionToken() ? 'authenticated' : 'guest';
  appCont.classList.toggle('dark-mode', isPublic);

  document.getElementById('wa-fab-container')?.classList.toggle('portal-hidden', !isPublic);
  document.dispatchEvent(new CustomEvent('portal:view-change', { detail: { page, isPublic } }));
}

function nav(page) {
  const target = document.getElementById('view-' + page);
  if (!target) return;

  if (!isPublicView(page) && !hasValidSessionToken()) {
    globalAlert('Sessão Necessária', 'Faça login para acessar o portal do recrutador.', 'warning');
    nav('Login');
    return;
  }

  const cur = document.querySelector('.view.active');
  if (cur) _prevPage = cur.id.replace('view-', '');

  document.querySelectorAll('.view').forEach(v => v.classList.remove('active'));
  target.classList.add('active');
  setShellState(page);

  /* FAQ init */
  document.querySelectorAll('.rc-faq-header').forEach(h => {
    h.onclick = () => {
      const item = h.parentElement;
      document.querySelectorAll('.rc-faq-item.open').forEach(o => { if(o!==item) o.classList.remove('open'); });
      item.classList.toggle('open');
    };
  });

  /* Active nav item */
  document.querySelectorAll('.nav-item').forEach(el => {
    const isActive = el.getAttribute('data-page') === page;
    el.classList.toggle('active', isActive);
    if (isActive) el.scrollIntoView({behavior:'smooth',inline:'center',block:'nearest'});
  });

  if (!isPublicView(page) && typeof window['load'+page] === 'function') window['load'+page]();
  window.scrollTo(0,0);
  setTimeout(patchAllLinks, 100);
}

function navBack() {
  const fallback = hasValidSessionToken() ? 'Dashboard' : 'Landing';
  const previous = _prevPage && document.getElementById('view-' + _prevPage) ? _prevPage : fallback;
  nav(previous === 'Diretrizes' ? fallback : previous);
}

/* ============================================================
   LOADER
   ============================================================ */
let loaderTimeout;
function showLoader() {
  document.getElementById('global-loader')?.classList.add('is-visible');
  clearTimeout(loaderTimeout);
  loaderTimeout = setTimeout(hideLoader, 12000);
}
function hideLoader() {
  document.getElementById('global-loader')?.classList.remove('is-visible');
  clearTimeout(loaderTimeout);
}

/* ============================================================
   MODALS
   ============================================================ */
function globalAlert(title, message, type='info') {
  document.getElementById('global_alertTitle').innerText   = title;
  document.getElementById('global_alertMessage').innerText = message;
  const iconWrap = document.getElementById('global_alertIcon');
  iconWrap.className = 'modal-icon-wrapper ' + type;
  let icon = 'fa-info-circle';
  if(type==='success') icon='fa-check-circle';
  if(type==='error')   icon='fa-times-circle';
  if(type==='warning') icon='fa-exclamation-triangle';
  iconWrap.innerHTML = `<i class="fas ${icon}"></i>`;
  document.getElementById('global_alertModal').classList.add('active');
}
function closeGlobalAlert() { document.getElementById('global_alertModal').classList.remove('active'); }

let confirmCallback = null;
function globalConfirm(title, message, onConfirm) {
  document.getElementById('global_confirmTitle').innerText   = title;
  document.getElementById('global_confirmMessage').innerText = message;
  confirmCallback = onConfirm;
  document.getElementById('global_confirmModal').classList.add('active');
  document.getElementById('global_btnConfirmAction').onclick = function() { closeGlobalConfirm(); if(confirmCallback) confirmCallback(); };
}
function closeGlobalConfirm() { document.getElementById('global_confirmModal').classList.remove('active'); }

let activeMediaInput = null;
function openMediaModal(inputId) { activeMediaInput = inputId; document.getElementById('global_mediaModal').classList.add('active'); }
function closeMediaModal() { document.getElementById('global_mediaModal').classList.remove('active'); }
function selectMedia(type) {
  closeMediaModal();
  const input = document.getElementById(activeMediaInput);
  if (type==='camera') input.setAttribute('capture','environment'); else input.removeAttribute('capture');
  input.click();
}

/* ============================================================
   FIREBASE AUTH
   ============================================================ */
firebase.auth().onAuthStateChanged(async (user) => {
  if (user && sessionStorage.getItem('esperando_login_google') === 'sim') {
    sessionStorage.removeItem('esperando_login_google');
    showLoader();
    try {
      const idToken = await user.getIdToken();
      const res = await gsRun('getDashboardData', { idToken });
      hideLoader();
      if (res.success) {
        storeDashboardSession(idToken, res.data);
        nav('Dashboard');
      } else {
        document.getElementById('cad-nome').value  = user.displayName || '';
        if (user.email) {
          const cadEmail = document.getElementById('cad-email');
          cadEmail.value = user.email;
          cadEmail.readOnly = true;
          cadEmail.classList.add('is-readonly');
        }
        document.getElementById('btnGoogleCad').classList.add('is-hidden');
        document.getElementById('div-ou-cad').classList.add('is-hidden');
        nav('Cadastro');
        globalAlert("Quase lá!", "Complete os campos restantes para finalizar o cadastro.", "info");
      }
    } catch (error) {
      hideLoader();
      sessionStorage.removeItem('esperando_login_google');
      globalAlert('Erro Google', 'Não foi possível validar seu acesso com o Google. Tente novamente.', 'error');
    }
  }
});

async function gsRun(action, dataObj) {
  try {
    const response = await fetch(API_URL, { method:'POST', body:JSON.stringify({ action, data:dataObj }) });
    return await response.json();
  } catch (error) {
    hideLoader();
    return { success:false, locked:false, msg:"Falha de comunicação com o servidor. Tente novamente." };
  }
}

function forceLogout(msg) {
  sessionStorage.clear();
  try { firebase.auth().signOut(); } catch(e){}
  document.getElementById('main-app-container')?.setAttribute('data-auth-state', 'guest');
  if (msg) globalAlert('Sessão Encerrada', msg, 'warning');
  nav('Landing');
}

function togglePassword(inputId, iconEl) {
  const input = document.getElementById(inputId);
  if (input.type==='password') { input.type='text'; iconEl.classList.replace('fa-eye','fa-eye-slash'); }
  else                         { input.type='password'; iconEl.classList.replace('fa-eye-slash','fa-eye'); }
}

async function loginComGoogle() {
  const provider = new firebase.auth.GoogleAuthProvider();
  sessionStorage.setItem('esperando_login_google','sim');
  try { await firebase.auth().signInWithPopup(provider); }
  catch(error) { sessionStorage.removeItem('esperando_login_google'); globalAlert('Erro Google','Erro ao acessar o Google. Verifique se o domínio está autorizado.','error'); }
}
async function preencherComGoogle() { return loginComGoogle(); }

/* ============================================================
   FORM HANDLERS
   ============================================================ */
document.getElementById('loginForm').onsubmit = async function(e) {
  e.preventDefault();
  const btn = document.getElementById('btnLogin'); btn.textContent='Verificando...'; btn.disabled=true;
  showLoader();
  try {
    // 1. Autenticação no Firebase
    const uc = await firebase.auth().signInWithEmailAndPassword(this.email.value, this.senha.value);
    const idToken = await uc.user.getIdToken();
    
    // 2. Chamar o servidor para validar o token e buscar os dados do usuário
    // Aqui definimos a variável 'res' que estava faltando
    const res = await gsRun('getDashboardData', { idToken });

    hideLoader(); 
    btn.textContent = 'ENTRAR'; 
    btn.disabled = false;

    if (res.success) { 
      storeDashboardSession(idToken, res.data);
      nav('Dashboard'); 
    }
    else { 
      globalAlert('Acesso Negado', res.msg, 'error'); 
      firebase.auth().signOut(); 
    }
  } catch (error) {
    hideLoader(); 
    btn.textContent = 'ENTRAR'; 
    btn.disabled = false;
    let msg = "E-mail ou senha incorretos.";
    // Se quiser ver o erro real no console para debugar: console.error(error);
    globalAlert('Erro no Login', msg, 'error');
  }
};

document.getElementById('resetForm').onsubmit = async function(e) {
  e.preventDefault();
  const btn=document.getElementById('btnReset'); const alertBox=document.getElementById('reset-alert');
  btn.innerText='Enviando...'; btn.disabled=true; alertBox.style.display='none';
  showLoader();
  try {
    await firebase.auth().sendPasswordResetEmail(this.email.value);
    hideLoader(); document.getElementById('resetForm').style.display='none'; document.getElementById('reset-subtitle').style.display='none';
    alertBox.style.display='block'; alertBox.style.backgroundColor='transparent'; alertBox.style.border='none';
    alertBox.innerHTML=`<i class="fas fa-check-circle" style="font-size:3.5rem;color:#10b981;margin-bottom:15px;display:block;"></i><span style="font-size:1.1rem;color:#1e293b;">Link enviado!</span><p style="color:#64748b;font-size:.85rem;margin-top:10px">Verifique sua caixa de entrada ou spam.</p>`;
    setTimeout(()=>{ document.getElementById('resetForm').reset(); document.getElementById('resetForm').style.display='block'; document.getElementById('reset-subtitle').style.display='block'; alertBox.style.display='none'; btn.innerText='ENVIAR LINK'; btn.disabled=false; nav('Login'); }, 5000);
  } catch(error) {
    hideLoader(); alertBox.style.display='block';
    alertBox.innerText='E-mail não encontrado.'; alertBox.style.backgroundColor='#fee2e2'; alertBox.style.color='#991b1b'; alertBox.style.border='1px solid #fecaca';
    btn.innerText='ENVIAR LINK'; btn.disabled=false;
  }
};

function maskPhone(i) { let v=i.value.replace(/\D/g,''); if(v.length>11)v=v.slice(0,11); v=v.replace(/^(\d{2})(\d)/g,'($1) $2'); v=v.replace(/(\d)(\d{4})$/,'$1-$2'); i.value=v; }
function maskCPF(i)   { let v=i.value.replace(/\D/g,''); if(v.length>11)v=v.slice(0,11); v=v.replace(/(\d{3})(\d)/,'$1.$2'); v=v.replace(/(\d{3})(\d)/,'$1.$2'); v=v.replace(/(\d{3})(\d{1,2})$/,'$1-$2'); i.value=v; }

function verificarIdade(inputData) {
  const btn=document.getElementById('btnReg');
  const blocoResp=document.getElementById('blocoResponsavel'); const iNome=document.getElementById('nomeResp'); const iCpf=document.getElementById('cpfResp');
  const dataD=new Date(inputData.value+'T00:00:00'); if(!inputData.value) return;
  const hoje=new Date(); let idade=hoje.getFullYear()-dataD.getFullYear();
  if(hoje.getMonth()<dataD.getMonth()||(hoje.getMonth()===dataD.getMonth()&&hoje.getDate()<dataD.getDate())) idade--;
  if(idade<14){ globalAlert("Bloqueado","Mínimo de 14 anos.","error"); btn.disabled=true; inputData.value=''; blocoResp.classList.remove('is-visible'); iNome.required=false; iCpf.required=false; }
  else if(idade<16){ blocoResp.classList.add('is-visible'); iNome.required=true; iCpf.required=true; btn.disabled=false; globalAlert("Declaração Legal","Você precisa de autorização do responsável legal.","warning"); }
  else { blocoResp.classList.remove('is-visible'); iNome.required=false; iCpf.required=false; btn.disabled=false; }
}

document.getElementById('formCadastro').onsubmit = async (e) => {
  e.preventDefault();
  const btn=document.getElementById('btnReg'); if(btn.disabled) return;
  const emailRegex=/^[^\s@]+@[^\s@]+\.[^\s@]+$/;
  if(!emailRegex.test(e.target.email.value)){ globalAlert("Atenção","E-mail inválido.","warning"); return; }
  if(e.target.cpf.value.length!==14){ globalAlert("Atenção","CPF incompleto.","warning"); return; }
  if(!document.getElementById('cad-dataNasc').value){ globalAlert("Atenção","Preencha a data de nascimento.","warning"); return; }
  const dArr=e.target.dataNasc.value.split('-');
  const dtFmt=`${dArr[2]}/${dArr[1]}/${dArr[0]}`;
  btn.disabled=true; btn.innerText="CRIANDO..."; showLoader();
  const formData={ nome:e.target.nome.value, email:e.target.email.value, cpf:e.target.cpf.value, whatsapp:e.target.whatsapp.value, chavePix:e.target.chavePix.value, dataNasc:dtFmt, nomeResp:e.target.nomeResp.value, cpfResp:e.target.cpfResp.value, termosAgreed:"Sim", idadeAgreed:"Sim" };
  try {
    let idToken; const cu=firebase.auth().currentUser;
    if(cu&&cu.email===e.target.email.value){ await cu.updatePassword(e.target.senha.value); idToken=await cu.getIdToken(); }
    else { const uc=await firebase.auth().createUserWithEmailAndPassword(e.target.email.value,e.target.senha.value); idToken=await uc.user.getIdToken(); }
    const res=await gsRun('cadastrarUsuarioPlanilha',{ idToken, form:formData });
    hideLoader(); btn.disabled=false; btn.innerText="CRIAR CONTA";
    if(res.success){
      globalAlert("Bem-Vindo!","Conta criada com sucesso!","success");
      e.target.reset();
      document.getElementById('blocoResponsavel').classList.remove('is-visible');
      document.getElementById('btnGoogleCad').classList.remove('is-hidden');
      document.getElementById('div-ou-cad').classList.remove('is-hidden');
      const cadEmail = document.getElementById('cad-email');
      cadEmail.readOnly=false;
      cadEmail.classList.remove('is-readonly');
      firebase.auth().signOut();
      nav('Login');
    }
    else { globalAlert("Atenção",res.msg,"warning"); }
  } catch(error) {
    hideLoader(); btn.disabled=false; btn.innerText="CRIAR CONTA";
    let msg="Erro ao criar conta.";
    if(error.code==='auth/email-already-in-use') msg="Este e-mail já está em uso.";
    if(error.code==='auth/weak-password') msg="Senha deve ter pelo menos 6 caracteres.";
    globalAlert("Falha",msg,"error");
  }
};

