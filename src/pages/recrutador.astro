---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&family=Sora:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/remixicon@3.5.0/fonts/remixicon.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

  <script is:inline src="https://www.gstatic.com/firebasejs/8.10.1/firebase-app.js"></script>
  <script is:inline src="https://www.gstatic.com/firebasejs/8.10.1/firebase-auth.js"></script>
  <script is:inline src="https://www.gstatic.com/firebasejs/8.10.1/firebase-storage.js"></script>

  <div id="global-loader"><div class="spinner"></div></div>

  <div id="unified-exit-layer" role="dialog" aria-modal="true">
    <div class="uel-icon"><i class="ri-external-link-line"></i></div>
    <div class="uel-title">Abrir no Navegador</div>
    <p class="uel-sub">Este link precisa ser aberto no <strong>navegador do seu celular</strong> para funcionar corretamente.</p>
    <div class="uel-url" id="uel-url-display"></div>
    <button class="uel-btn-open" onclick="uelForceExternal()"><i class="ri-compass-3-line"></i> Abrir no Navegador</button>
    <button class="uel-btn-copy" id="uel-copy-btn" onclick="uelCopyUrl()"><i class="ri-clipboard-line"></i> Copiar Link</button>
    <button class="uel-btn-back" onclick="uelClose()">← Voltar</button>
  </div>

  <div class="custom-modal-overlay" id="global_alertModal">
    <div class="custom-modal-card">
      <div class="modal-icon-wrapper info" id="global_alertIcon"><i class="fas fa-info-circle"></i></div>
      <h3 class="custom-modal-title" id="global_alertTitle">Atenção</h3>
      <p class="custom-modal-text" id="global_alertMessage">Mensagem</p>
      <button class="btn-confirm" onclick="closeGlobalAlert()">OK, Entendi</button>
    </div>
  </div>
  
  <div class="custom-modal-overlay" id="global_confirmModal">
    <div class="custom-modal-card">
      <div class="modal-icon-wrapper warning"><i class="fas fa-question-circle"></i></div>
      <h3 class="custom-modal-title" id="global_confirmTitle">Confirmação</h3>
      <p class="custom-modal-text" id="global_confirmMessage">Deseja continuar?</p>
      <div class="modal-btn-group">
        <button class="btn-cancel" onclick="closeGlobalConfirm()">Cancelar</button>
        <button class="btn-confirm" id="global_btnConfirmAction">Sim</button>
      </div>
    </div>
  </div>

  <div class="custom-modal-overlay" id="global_mediaModal">
    <div class="custom-modal-card">
      <div class="modal-icon-wrapper info"><i class="fas fa-camera"></i></div>
      <h3 class="custom-modal-title">Selecionar Imagem</h3>
      <p class="custom-modal-text">De onde você quer enviar a foto?</p>
      <div class="modal-btn-group" style="flex-direction:column">
        <button class="btn-confirm" onclick="selectMedia('camera')" style="margin-bottom:5px"><i class="fas fa-camera"></i> Tirar Foto</button>
        <button class="btn-confirm" onclick="selectMedia('gallery')" style="background:#475569"><i class="fas fa-images"></i> Da Galeria</button>
        <button class="btn-cancel" onclick="closeMediaModal()" style="margin-top:10px">Cancelar</button>
      </div>
    </div>
  </div>

  <div class="custom-modal-overlay" id="patrocinadorModal">
    <div class="custom-modal-card">
      <div class="modal-icon-wrapper info"><i class="fas fa-external-link-alt"></i></div>
      <h3 class="custom-modal-title">Ação Necessária</h3>
      <p class="custom-modal-text">Para liberar o seu saque, visite o site do patrocinador.<br><br><b>Aguarde o tempo necessário na página!</b></p>
      <button id="btnPatrocinador" class="btn-confirm" onclick="abrirPatrocinador()">Visitar Patrocinador</button>
    </div>
  </div>

  <div class="fp-agency-wrapper" id="main-app-container">

    <div id="view-Landing" class="view">
      <Header />
      <div class="rc">
        <div class="rc-hero">
          <div class="rc-hero-inner">
            <div class="rc-badge"><span class="rc-badge-dot"></span>Programa de Parceiros 2026</div>
            <h1 class="rc-hero-title">Monetize sua influência<br>com <span>transparência</span></h1>
            <p class="rc-hero-sub">Plataforma oficial para recrutadores que buscam renda mensal recorrente indicando usuários para apps parceiros. Modelo 100% baseado em performance (RPM).</p>
            <div class="rc-hero-actions">
              <button class="rc-btn-primary" onclick="nav('Login')"><i class="ri-user-add-line"></i> Cadastrar / Login</button>
              <button class="rc-btn-secondary" onclick="nav('Diretrizes')"><i class="ri-file-list-3-line"></i> Ver Regras e Níveis</button>
            </div>
          </div>
        </div>

        <div class="rc-marquee-wrap" aria-hidden="true">
          <div class="rc-marquee-band">
            <div class="rc-marquee-track">
              <div class="rc-marquee-group">
                <span class="rc-chip"><i class="ri-money-dollar-circle-line"></i> Renda Recorrente</span>
                <span class="rc-chip"><i class="ri-user-add-line"></i> Sem Limite de Indicações</span>
                <span class="rc-chip"><i class="ri-bar-chart-grouped-line"></i> Modelo RPM</span>
                <span class="rc-chip"><i class="ri-shield-check-line"></i> 100% Gratuito</span>
                <span class="rc-chip"><i class="ri-customer-service-2-line"></i> Suporte Dedicado</span>
                <span class="rc-chip"><i class="ri-team-line"></i> Comunidade de Parceiros</span>
                <span class="rc-chip"><i class="ri-trophy-line"></i> Alta Performance</span>
              </div>
              <div class="rc-marquee-group" aria-hidden="true">
                <span class="rc-chip"><i class="ri-money-dollar-circle-line"></i> Renda Recorrente</span>
                <span class="rc-chip"><i class="ri-user-add-line"></i> Sem Limite de Indicações</span>
                <span class="rc-chip"><i class="ri-bar-chart-grouped-line"></i> Modelo RPM</span>
                <span class="rc-chip"><i class="ri-shield-check-line"></i> 100% Gratuito</span>
                <span class="rc-chip"><i class="ri-customer-service-2-line"></i> Suporte Dedicado</span>
                <span class="rc-chip"><i class="ri-team-line"></i> Comunidade de Parceiros</span>
                <span class="rc-chip"><i class="ri-trophy-line"></i> Alta Performance</span>
              </div>
            </div>
          </div>
        </div>

        <div class="rc-section">
          <div class="rc-section-label"><span class="rc-section-label-text">Modelo Operacional</span><div class="rc-section-label-line"></div></div>
          <div class="rc-steps">
            <div class="rc-step"><div class="rc-step-num">Passo 01</div><div class="rc-step-icon"><i class="ri-share-forward-line"></i></div><div class="rc-step-title">Indicação</div><p class="rc-step-desc">Indique usuários reais usando seu link exclusivo ou método autorizado pela FP Agency.</p></div>
            <div class="rc-step"><div class="rc-step-num">Passo 02</div><div class="rc-step-icon"><i class="ri-bar-chart-grouped-line"></i></div><div class="rc-step-title">RPM (Engajamento)</div><p class="rc-step-desc">Seus ganhos são calculados com base na atividade, retenção e qualidade dos usuários indicados.</p></div>
            <div class="rc-step"><div class="rc-step-num">Passo 03</div><div class="rc-step-icon"><i class="ri-wallet-3-line"></i></div><div class="rc-step-title">Comissões Recorrentes</div><p class="rc-step-desc">Receba pagamentos mensais com total transparência enquanto seus indicados permanecerem ativos.</p></div>
          </div>
        </div>

        <div class="rc-section">
          <div class="rc-section-label"><span class="rc-section-label-text">Por que a FP Agency?</span><div class="rc-section-label-line"></div></div>
          <div class="rc-benefits">
            <div class="rc-benefit"><div class="rc-check"><i class="ri-check-line"></i></div><span class="rc-benefit-text">Renda recorrente por usuário ativo</span></div>
            <div class="rc-benefit"><div class="rc-check"><i class="ri-check-line"></i></div><span class="rc-benefit-text">Sem investimento inicial — 100% gratuito</span></div>
            <div class="rc-benefit"><div class="rc-check"><i class="ri-check-line"></i></div><span class="rc-benefit-text">Sem limite de indicações</span></div>
            <div class="rc-benefit"><div class="rc-check"><i class="ri-check-line"></i></div><span class="rc-benefit-text">Infraestrutura escalável</span></div>
            <div class="rc-benefit"><div class="rc-check"><i class="ri-check-line"></i></div><span class="rc-benefit-text">Suporte dedicado ao parceiro</span></div>
            <div class="rc-benefit"><div class="rc-check"><i class="ri-check-line"></i></div><span class="rc-benefit-text">Painel de acompanhamento em tempo real</span></div>
          </div>
          <div class="rc-notice">
            <i class="ri-alert-line"></i>
            <div><div class="rc-notice-title">Transparência Financeira</div><p class="rc-notice-text">Os ganhos são variáveis e dependem exclusivamente do RPM gerado pelos usuários indicados. Não prometemos valores fixos ou mínimos garantidos.</p></div>
          </div>
        </div>

        <div class="rc-section">
          <div class="rc-section-label"><span class="rc-section-label-text">Dúvidas Frequentes</span><div class="rc-section-label-line"></div></div>
          <div class="rc-faq">
            <div class="rc-faq-item"><div class="rc-faq-header">O que é RPM e como é calculado?<i class="ri-add-line"></i></div><div class="rc-faq-body"><div class="rc-faq-content">RPM significa "Receita por Mil". É o valor gerado a cada mil interações ou visualizações dos usuários que você indicou. Quanto mais engajados seus indicados, maior seu RPM.</div></div></div>
            <div class="rc-faq-item"><div class="rc-faq-header">Existe custo para entrar no programa?<i class="ri-add-line"></i></div><div class="rc-faq-body"><div class="rc-faq-content">Não. O programa é 100% gratuito e baseado exclusivamente em desempenho.</div></div></div>
            <div class="rc-faq-item"><div class="rc-faq-header">Como e quando recebo meus pagamentos?<i class="ri-add-line"></i></div><div class="rc-faq-body"><div class="rc-faq-content">Os pagamentos são processados após o fechamento do ciclo contábil com o aplicativo parceiro. Datas e métodos de saque são detalhados no onboarding.</div></div></div>
            <div class="rc-faq-item"><div class="rc-faq-header">Há limite de quantas pessoas posso indicar?<i class="ri-add-line"></i></div><div class="rc-faq-body"><div class="rc-faq-content">Não há limite. Quanto mais indicações qualificadas, maior seu potencial de renda mensal.</div></div></div>
            <div class="rc-faq-item"><div class="rc-faq-header">Quais aplicativos fazem parte do programa?<i class="ri-add-line"></i></div><div class="rc-faq-body"><div class="rc-faq-content">Kwai Cut, Kwai Narrastars, Kako Live e Fantazy. Novos parceiros podem ser adicionados conforme o programa cresce.</div></div></div>
          </div>
        </div>

        <div class="rc-section" style="margin-bottom:0">
          <div class="rc-cta">
            <div class="rc-cta-title">Pronto para escalar seus resultados?</div>
            <p class="rc-cta-sub">Junte-se ao time de recrutadores de alta performance e comece a gerar renda recorrente hoje.</p>
            <div class="rc-cta-btns">
              <button class="rc-btn-primary" onclick="nav('Login')"><i class="ri-whatsapp-line"></i> Iniciar Cadastro Agora</button>
              <button class="rc-btn-secondary" onclick="nav('Login')"><i class="ri-user-line"></i> Acessar Minha Conta</button>
            </div>
          </div>
        </div>
      </div>
      <Footer />
    </div>

    <div id="view-Diretrizes" class="view">
      <div class="dg">
        <div class="dg-banner">
          <div class="dg-banner-inner">
            <div class="dg-vigencia"><span class="dg-vigencia-dot"></span>Vigência: 01/01/2026 a 30/12/2026</div>
            <h1 class="dg-banner-title">Diretrizes &amp;<br><span>Gamificação</span></h1>
            <p class="dg-banner-sub">Este é o seu primeiro passo para abrir sua própria agência. Desempenho gera recompensa — maximize seus ganhos.</p>
          </div>
        </div>

        <button class="dg-back" onclick="navBack()"><i class="ri-arrow-left-line"></i> Voltar</button>

        <div class="dg-section" style="margin-top:28px">
          <div class="dg-section-label"><span class="dg-section-label-text">Metas do Mês (Maio)</span><div class="dg-section-label-line"></div></div>
          <div class="dg-meta-grid">
            <div class="dg-meta-card">
              <div class="dg-meta-head"><div class="dg-meta-icon"><i class="ri-scissors-cut-fill"></i></div><div><div class="dg-meta-title">Kwai Cut</div><div class="dg-meta-sub">Campanha de Vídeo</div></div></div>
              <div class="dg-meta-rows"><div class="dg-meta-row"><i class="ri-flashlight-fill"></i><div><div class="dg-meta-row-label">Meta</div><div class="dg-meta-row-val">10% dos recrutados</div></div></div><div class="dg-meta-row"><i class="ri-user-add-fill"></i><div><div class="dg-meta-row-label">Mínimo</div><div class="dg-meta-row-val">2 recrutamentos</div></div></div></div>
              <div class="dg-penalty"><i class="ri-alarm-warning-fill"></i><div><div class="dg-penalty-label">Penalidade</div><div class="dg-penalty-val">Desconto de 5% caso a meta não seja atingida</div></div></div>
            </div>
            <div class="dg-meta-card">
              <div class="dg-meta-head"><div class="dg-meta-icon"><i class="ri-mic-2-fill"></i></div><div><div class="dg-meta-title">Kwai Narrastars</div><div class="dg-meta-sub">Campanha de Áudio</div></div></div>
              <div class="dg-meta-rows"><div class="dg-meta-row"><i class="ri-flashlight-fill"></i><div><div class="dg-meta-row-label">Meta</div><div class="dg-meta-row-val">12% dos recrutados</div></div></div><div class="dg-meta-row"><i class="ri-user-add-fill"></i><div><div class="dg-meta-row-label">Mínimo</div><div class="dg-meta-row-val">1 recrutamento</div></div></div></div>
              <div class="dg-penalty"><i class="ri-alarm-warning-fill"></i><div><div class="dg-penalty-label">Penalidade</div><div class="dg-penalty-val">Desconto de 8% caso a meta não seja atingida</div></div></div>
            </div>
          </div>
        </div>

        <div class="dg-section">
          <div class="dg-section-label"><span class="dg-section-label-text">Sistema de Classificação</span><div class="dg-section-label-line"></div></div>
          <div class="dg-levels">
            <div class="dg-level gold">
              <div class="dg-bonus-row"><i class="ri-trending-up-line"></i>Multiplicador de ganhos:<span>× 1,35 de bônus</span></div>
              <div class="dg-level-head"><span class="dg-level-badge gold">🥇 Nível Ouro — Elite</span><span class="dg-level-range">30+ pessoas</span></div>
              <div class="dg-level-body">
                <div class="dg-perk"><div class="dg-perk-icon"><i class="ri-building-4-line"></i></div><div><div class="dg-perk-title">Sub Agência</div><div class="dg-perk-desc">Gerencie sua própria equipe de recrutadores</div></div></div>
                <div class="dg-perk"><div class="dg-perk-icon"><i class="ri-vip-crown-line"></i></div><div><div class="dg-perk-title">Suporte VIP</div><div class="dg-perk-desc">Atendimento prioritário dedicado</div></div></div>
                <div class="dg-perk"><div class="dg-perk-icon"><i class="ri-shield-check-line"></i></div><div><div class="dg-perk-title">Penalidade Zero</div><div class="dg-perk-desc">Isenção total de multas por metas</div></div></div>
                <div class="dg-perk"><div class="dg-perk-icon"><i class="ri-check-double-line"></i></div><div><div class="dg-perk-title">Todos os benefícios</div><div class="dg-perk-desc">Inclui todos os perks de Prata e Bronze</div></div></div>
              </div>
            </div>
            <div class="dg-level silver">
              <div class="dg-bonus-row"><i class="ri-trending-up-line"></i>Multiplicador de ganhos:<span>× 1,14 de bônus</span></div>
              <div class="dg-level-head"><span class="dg-level-badge silver">🥈 Nível Prata — Avançado</span><span class="dg-level-range">11 a 30 pessoas</span></div>
              <div class="dg-level-body">
                <div class="dg-perk"><div class="dg-perk-icon"><i class="ri-rocket-line"></i></div><div><div class="dg-perk-title">Mentorias Estratégicas</div><div class="dg-perk-desc">Sessões de crescimento e escala</div></div></div>
                <div class="dg-perk"><div class="dg-perk-icon"><i class="ri-bar-chart-box-line"></i></div><div><div class="dg-perk-title">Relatórios Detalhados</div><div class="dg-perk-desc">Dashboard completo de desempenho</div></div></div>
                <div class="dg-perk"><div class="dg-perk-icon"><i class="ri-check-double-line"></i></div><div><div class="dg-perk-title">Benefícios Bronze</div><div class="dg-perk-desc">Inclui todos os perks do nível inicial</div></div></div>
              </div>
            </div>
            <div class="dg-level bronze">
              <div class="dg-bonus-row"><i class="ri-trending-up-line"></i>Multiplicador de ganhos:<span>× 1,05 de bônus</span></div>
              <div class="dg-level-head"><span class="dg-level-badge bronze">🥉 Nível Bronze — Iniciante</span><span class="dg-level-range">1 a 9 pessoas</span></div>
              <div class="dg-level-body">
                <div class="dg-perk"><div class="dg-perk-icon"><i class="ri-tools-line"></i></div><div><div class="dg-perk-title">Ferramentas</div><div class="dg-perk-desc">Acesso a Kwai Cut e Narrastars</div></div></div>
                <div class="dg-perk"><div class="dg-perk-icon"><i class="ri-customer-service-2-line"></i></div><div><div class="dg-perk-title">Suporte Básico</div><div class="dg-perk-desc">Onboarding e start no programa</div></div></div>
                <div class="dg-perk"><div class="dg-perk-icon"><i class="ri-user-add-line"></i></div><div><div class="dg-perk-title">Link de Indicação</div><div class="dg-perk-desc">Link exclusivo para rastrear indicações</div></div></div>
              </div>
            </div>
          </div>
        </div>

        <div class="dg-section">
          <div class="dg-section-label"><span class="dg-section-label-text">Política Geral</span><div class="dg-section-label-line"></div></div>
          <div class="dg-policy">
            <div class="dg-policy-rules">
              <div class="dg-rule"><div><div class="dg-rule-title">Critério de Validação</div><div class="dg-rule-desc">O novo membro deve se cadastrar corretamente e permanecer ativo por no mínimo 30 dias. Contas inativas ou automatizadas não são contabilizadas.</div></div></div>
              <div class="dg-rule"><div><div class="dg-rule-title">Boas Práticas</div><div class="dg-rule-desc">Apresente informações honestas. Oriente seus recrutados para performance real. Use provas sociais verdadeiras.</div></div></div>
              <div class="dg-rule"><div><div class="dg-rule-title">Transparência Financeira</div><div class="dg-rule-desc">Os ganhos são variáveis e dependem do RPM gerado. Não prometemos valores fixos. Nunca prometa ganhos específicos a recrutados.</div></div></div>
            </div>
            <div class="dg-prohibited">
              <div class="dg-prohibited-title"><i class="ri-error-warning-fill"></i> Proibido — Sujeito a Banimento Imediato</div>
              <div class="dg-prohibit-list">
                <div class="dg-prohibit-item"><i class="ri-close-circle-fill"></i><div><div class="dg-prohibit-title">Informações Falsas</div><div class="dg-prohibit-desc">Divulgação de promessas ou ganhos irreais para atrair recrutados.</div></div></div>
                <div class="dg-prohibit-item"><i class="ri-close-circle-fill"></i><div><div class="dg-prohibit-title">Spam</div><div class="dg-prohibit-desc">Comportamento agressivo ou não solicitado em grupos de terceiros.</div></div></div>
                <div class="dg-prohibit-item"><i class="ri-close-circle-fill"></i><div><div class="dg-prohibit-title">Fraude / Bots</div><div class="dg-prohibit-desc">Autocriação de contas ou uso de automação para inflar métricas.</div></div></div>
              </div>
            </div>
          </div>
        </div>

        <div class="dg-section" style="margin-bottom:0">
          <div class="dg-cta">
            <div class="dg-cta-title">Pronto para atingir o nível Ouro?</div>
            <p class="dg-cta-sub">Construa um time forte e focado. Cada indicação ativa é um passo rumo à sua própria agência.</p>
            <button class="dg-cta-btn" onclick="navBack()"><i class="ri-arrow-left-line"></i> Voltar para Início</button>
          </div>
        </div>
      </div>
    </div>

    <div id="view-Login" class="view">
      <div class="auth-wrapper">
        <div class="auth-card" style="background:white;padding:2rem;border-radius:16px;box-shadow:0 4px 12px rgba(249,115,22,.08);text-align:center;width:92%;max-width:400px;">
          <h1 style="color:var(--primary);margin:0 0 5px">Portal Parceiro</h1>
          <p style="color:#9a3412;margin-bottom:25px">Faça login para continuar</p>
          <button type="button" class="btn" style="background:white;color:#333;border:1px solid #e2e8f0;display:flex;align-items:center;justify-content:center;gap:10px;margin-bottom:20px;font-weight:500" onclick="loginComGoogle()">
            <img src="https://www.gstatic.com/firebasejs/ui/2.0.0/images/auth/google.svg" alt="Google" style="width:20px;height:20px"> Continuar com o Google
          </button>
          <div style="margin:20px 0;display:flex;align-items:center;gap:10px"><div style="height:1px;background:#e2e8f0;flex:1"></div><span style="font-size:.8rem;color:#94a3b8">ou use seu acesso</span><div style="height:1px;background:#e2e8f0;flex:1"></div></div>
          
          <form id="loginForm" onsubmit="event.preventDefault()">
            <input type="email" name="email" placeholder="E-mail cadastrado" required>
            
            <div class="password-wrapper"><input type="password" id="senha" name="senha" placeholder="Sua senha" required><i class="fas fa-eye toggle-password" onclick="togglePassword('senha',this)"></i></div>
            <div style="text-align:right;margin:-6px 0 16px;font-size:.75rem"><a onclick="nav('Redefinir')" style="color:var(--primary);font-weight:600;cursor:pointer">Esqueceu a senha?</a></div>
            <button type="submit" class="btn" id="btnLogin">ENTRAR</button>
            
            <div style="margin:20px 0;display:flex;align-items:center;gap:10px"><div style="height:1px;background:#e2e8f0;flex:1"></div><span style="font-size:.8rem;color:#94a3b8">ou</span><div style="height:1px;background:#e2e8f0;flex:1"></div></div>
            <button type="button" class="btn" style="background:transparent;border:2px solid var(--primary);color:var(--primary)" onclick="nav('Cadastro')">CRIAR NOVA CONTA</button>
            <div style="margin-top:16px"><button type="button" class="btn" style="background:transparent;border:1px solid #e2e8f0;color:#64748b;font-size:.85rem" onclick="nav('Landing')">← Voltar para o Início</button></div>
