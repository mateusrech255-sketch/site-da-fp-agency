function excluirContaDefinitivamente() {
  globalConfirm("Exclusão Permanente","ATENÇÃO: Esta ação é IRREVERSÍVEL. Todos os dados serão apagados para sempre. Continuar?",async()=>{
    showLoader();
    try {
      const user=firebase.auth().currentUser; if(!user) return forceLogout();
      const foto=sessionStorage.getItem('user_foto');
      if(foto&&foto.includes('firebasestorage')&&appStorage){ try{await appStorage.refFromURL(foto).delete();}catch(e){} }
