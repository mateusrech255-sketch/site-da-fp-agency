function copy(id){
  const el=document.getElementById(id);
  if(!el||el.value==='Carregando...'||el.value===''){ globalAlert('Aviso','Nenhum link disponível para copiar.','warning'); return; }
  el.select(); el.setSelectionRange(0,99999);
  if(navigator.clipboard&&window.isSecureContext){ navigator.clipboard.writeText(el.value).then(()=>globalAlert('Copiado!','Link copiado com sucesso!','success')).catch(()=>fbCopyEl(el)); }
  else { fbCopyEl(el); }
}
function fbCopyEl(el){ try{document.execCommand('copy');globalAlert('Copiado!','Link copiado com sucesso!','success');}catch(err){globalAlert('Erro','Copie o texto manualmente.','error');} }

function validateLink(input){ if(input.value&&!input.value.startsWith('http://') &&!input.value.startsWith('https://')) input.value='https://'+input.value; }

function openFromInput(id){
  const el=document.getElementById(id);
  if(el&&el.value&&el.value.startsWith('http')) openLink(null,el.value);
  else globalAlert('Aviso','Campo vazio ou inválido.','warning');
}

