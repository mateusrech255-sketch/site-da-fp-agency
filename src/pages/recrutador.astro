firebase.auth().onAuthStateChanged(async (user) => {
  if (user && sessionStorage.getItem('esperando_login_google') === 'sim') {
    sessionStorage.removeItem('esperando_login_google');
    showLoader();
    const idToken = await user.getIdToken();
    const res = await gsRun('getDashboardData', { idToken });
    hideLoader();
    if (res.success) {
      sessionStorage.setItem('idToken', idToken);
      sessionStorage.setItem('user_nome',  res.data.nome);
