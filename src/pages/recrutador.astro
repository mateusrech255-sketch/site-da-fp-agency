      try { const user=firebase.auth().currentUser; if(user) await user.updatePassword(novaSenha); }
      catch(error){
        if(error.code==='auth/requires-recent-login'){ try{await firebase.auth().sendPasswordResetEmail(firebase.auth().currentUser.email);globalAlert("Segurança","Link de redefinição enviado ao seu e-mail.","info");document.getElementById('ui_senha').value='';}catch(e){globalAlert("Erro","Falha ao enviar e-mail.","error");} return; }
