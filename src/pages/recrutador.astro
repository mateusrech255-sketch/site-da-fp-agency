  tentarSaque,
  togglePassword,
  toggleSidebarCompact,
  uelClose,
  uelCopyUrl,
  uelForceExternal,
  validateLink,
  verificarIdade,
});

if (document.readyState==='loading') document.addEventListener('DOMContentLoaded', initApp);
else initApp();

</script>

