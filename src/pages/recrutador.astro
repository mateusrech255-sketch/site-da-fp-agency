    if(res.success){ globalAlert("Sucesso",novaSenha!==''?"Perfil e senha salvos!":res.msg,"success"); sessionStorage.setItem('user_nome',nome); document.getElementById('ui_senha').value=''; }
  } finally { hideLoader(); }
}

async function subirFoto(input) {
  if(!appStorage) return;
  const file=input.files[0]; if(!file) return;
  const fotoAntiga=sessionStorage.getItem('user_foto');
  const stat=document.getElementById('ui_status'); const pCont=document.getElementById('progContainer'); const pBar=document.getElementById('progBar');
  const imgUrl=URL.createObjectURL(file); document.getElementById('ui_foto').src=imgUrl;
  stat.innerText='Otimizando foto...'; stat.style.color='var(--primary)';
  const img=new Image();
  img.onload=function(){
    const canvas=document.createElement('canvas'); const ctx=canvas.getContext('2d');
    let w=img.width,h=img.height; const MAX=800;
    if(w>h){ if(w>MAX){h*=MAX/w;w=MAX;} } else { if(h>MAX){w*=MAX/h;h=MAX;} }
    canvas.width=w; canvas.height=h; ctx.drawImage(img,0,0,w,h);
    canvas.toBlob(function(blob){
      URL.revokeObjectURL(imgUrl); stat.innerText='Enviando...'; pCont.style.display='block';
      const email=firebase.auth().currentUser.email; const safe=email.replace(/[@.]/g,'_');
      const nome=safe+'_'+Date.now()+'.jpg';
      const task=appStorage.ref().child('fotos_perfil/'+nome).put(blob);
      task.on('state_changed',snap=>{ pBar.style.width=((snap.bytesTransferred/snap.totalBytes)*100)+'%'; },
        err=>{ stat.innerText='Erro no upload.'; stat.style.color='red'; },
        async()=>{
          const url=await task.snapshot.ref.getDownloadURL();
          stat.innerText='Finalizando...';
          const res=await gsRun('updateProfilePhoto',{idToken:sessionStorage.getItem('idToken'),urlFoto:url});
          pCont.style.display='none';
          if(res.success){ stat.innerText='Perfil atualizado!'; stat.style.color='green'; sessionStorage.setItem('user_foto',url);
            if(fotoAntiga&&fotoAntiga.includes('firebasestorage')){ try{await appStorage.refFromURL(fotoAntiga).delete();}catch(e){} }
            setTimeout(()=>stat.innerText='',3000);
          } else { stat.innerText='Erro ao salvar dados.'; stat.style.color='red'; }
          input.value=''; document.getElementById('inputFileCamera').value=''; document.getElementById('inputFileGallery').value='';
        });
    },'image/jpeg',0.7);
  };
  img.src=imgUrl;
}

function removerFoto() {
  const fotoAtual=sessionStorage.getItem('user_foto');
  if(!fotoAtual||!fotoAtual.includes('firebasestorage')){ globalAlert("Aviso","Nenhuma foto customizada para apagar.","info"); return; }
