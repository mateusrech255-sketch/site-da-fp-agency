async function gsRun(action, dataObj) {
  try {
    const response = await fetch(API_URL, { method:'POST', body:JSON.stringify({ action, data:dataObj }) });
    return await response.json();
  } catch (error) {
    hideLoader();
    return { success:false, locked:false, msg:"Falha de comunicação com o servidor. Tente novamente." };
  }
}

function forceLogout(msg) {
  sessionStorage.clear();
  try { firebase.auth().signOut(); } catch(e){}
  const bNav = document.getElementById('topNavSidebar');
  if (bNav) bNav.style.setProperty('display','none','important');
  if (msg) globalAlert('Sessão Encerrada', msg, 'warning');
  nav('Landing');
}

