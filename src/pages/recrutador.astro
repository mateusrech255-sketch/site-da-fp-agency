/* Editores */
let editoresDataRaw=[], stateFiltroProj='Todos', stateFiltroTempo='Todos', stateFiltroStatus='Todos';

async function loadEditores() {
  const token=sessionStorage.getItem('idToken'); if(!token){ forceLogout(); return; }
