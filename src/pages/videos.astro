---
import Layout from '../layouts/Layout.astro';

const base = import.meta.env.BASE_URL;
const basePath = base === '/' ? '' : base.replace(/\/$/, '');
const site = Astro.site ?? new URL('http://localhost:4321');
const pageUrl = new URL(`${basePath}/videos`, site).toString();
const apiBaseUrl = import.meta.env.PUBLIC_VIDEO_API_URL || 'http://localhost:3001';

const title = 'Baixar videos online em MP4 e MP3 | FP Agency';
const description =
  'Analise e gere downloads temporarios de videos do YouTube, TikTok, Instagram, Facebook e Kwai em MP4 ou MP3 com a plataforma FP Agency.';

const faqItems = [
  {
    question: 'Quais plataformas sao suportadas?',
    answer: 'A ferramenta suporta YouTube, TikTok, Instagram Reels, Instagram Videos, Facebook Videos e Kwai.',
  },
  {
    question: 'O download fica salvo no servidor?',
    answer:
      'Nao. A API gera links temporarios e faz streaming quando necessario. Tokens expiram automaticamente para reduzir risco e consumo de recursos.',
  },
  {
    question: 'Preciso instalar algo no meu computador?',
    answer:
      'Nao. O navegador usa a API da FP Agency. No servidor, a VPS precisa ter Node.js, yt-dlp e ffmpeg instalados.',
  },
  {
    question: 'Posso baixar qualquer video?',
    answer:
      'Use apenas conteudos proprios, publicos ou com autorizacao. Videos privados, removidos ou restritos podem ser bloqueados pela plataforma original.',
  },
];

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'FP Agency Video Downloader',
    applicationCategory: 'MultimediaApplication',
    operatingSystem: 'Web',
    url: pageUrl,
    description,
    offers: {
      '@type': 'Offer',
      price: '0',
      priceCurrency: 'BRL',
    },
    featureList: [
      'Analise de videos por URL',
      'Downloads em MP4 360p, 480p, 720p e 1080p',
      'Conversao para MP3 128kbps e 320kbps',
      'Suporte a YouTube, TikTok, Instagram, Facebook e Kwai',
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqItems.map((item) => ({
      '@type': 'Question',
      name: item.question,
      acceptedAnswer: {
        '@type': 'Answer',
        text: item.answer,
      },
    })),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      {
        '@type': 'ListItem',
        position: 1,
        name: 'FP Agency',
        item: new URL(`${basePath}/`, site).toString(),
      },
      {
        '@type': 'ListItem',
        position: 2,
        name: 'Download de Videos',
        item: pageUrl,
      },
    ],
  },
];
---

<Layout title={title} description={description} canonical={pageUrl} image={`${basePath}/favicon.svg`} jsonLd={jsonLd}>
  <main class="video-download-page" data-api-base={apiBaseUrl}>
    <header class="video-nav" aria-label="Navegacao da ferramenta de videos">
      <a class="video-brand" href={`${basePath}/`} aria-label="Voltar para FP Agency">
        <span class="brand-mark">FP</span>
        <span>FP Agency Videos</span>
      </a>

      <nav class="video-nav-links" aria-label="Secoes da pagina">
        <a href="#como-funciona">Como funciona</a>
        <a href="#plataformas">Plataformas</a>
        <a href="#faq">FAQ</a>
      </nav>
    </header>

    <section class="hero-section" aria-labelledby="hero-title">
      <div class="hero-copy">
        <p class="eyebrow">Downloader profissional para creators</p>
        <h1 id="hero-title">Baixe videos online em MP4 ou MP3 com rapidez e seguranca.</h1>
        <p class="hero-lead">
          Cole um link publico do YouTube, TikTok, Instagram, Facebook ou Kwai. A plataforma identifica o servico,
          analisa o video e libera opcoes temporarias de download.
        </p>

        <div class="trust-row" aria-label="Recursos principais">
          <span>yt-dlp</span>
          <span>API segura</span>
          <span>MP4 e MP3</span>
          <span>Mobile first</span>
        </div>
      </div>

      <section class="tool-panel" aria-labelledby="tool-title">
        <div class="panel-header">
          <div>
            <p class="panel-kicker">Analisar video</p>
            <h2 id="tool-title">Cole a URL para comecar</h2>
          </div>
          <span class="status-dot" aria-hidden="true"></span>
        </div>

        <form class="analyzer-form" id="video-form" novalidate>
          <label for="video-url">URL do video</label>
          <div class="input-shell">
            <input
              id="video-url"
              name="url"
              type="url"
              inputmode="url"
              autocomplete="off"
              spellcheck="false"
              placeholder="https://www.youtube.com/watch?v=..."
              aria-describedby="form-message"
              required
            />
            <span class="service-pill" id="service-pill">Aguardando link</span>
          </div>

          <button class="primary-button" id="analyze-button" type="submit">
            <span>Analisar Video</span>
          </button>

          <p class="form-message" id="form-message" role="status" aria-live="polite">
            Use apenas conteudos proprios, publicos ou com autorizacao.
          </p>
        </form>
      </section>
    </section>

    <section class="analysis-section" id="analysis-section" hidden aria-labelledby="analysis-title">
      <div class="section-heading">
        <p class="eyebrow">Resultado da analise</p>
        <h2 id="analysis-title">Escolha o formato ideal</h2>
      </div>

      <div class="result-layout">
        <article class="video-result" aria-label="Informacoes do video analisado">
          <img
            id="video-thumbnail"
            class="video-thumbnail"
            src=""
            alt=""
            width="640"
            height="360"
            loading="lazy"
            decoding="async"
            referrerpolicy="no-referrer"
          />
          <div class="video-meta">
            <span class="platform-badge" id="result-platform">Plataforma</span>
            <h3 id="result-title">Titulo do video</h3>
            <dl>
              <div>
                <dt>Autor</dt>
                <dd id="result-author">-</dd>
              </div>
              <div>
                <dt>Duracao</dt>
                <dd id="result-duration">-</dd>
              </div>
              <div>
                <dt>Analise</dt>
                <dd id="result-time">-</dd>
              </div>
            </dl>
          </div>
        </article>

        <article class="download-panel" aria-label="Opcoes de download">
          <div class="download-group">
            <div class="group-title">
              <h3>Video MP4</h3>
              <span>360p a 1080p</span>
            </div>
            <div class="option-grid" id="video-options"></div>
          </div>

          <div class="download-group">
            <div class="group-title">
              <h3>Audio MP3</h3>
              <span>128kbps e 320kbps</span>
            </div>
            <div class="option-grid" id="audio-options"></div>
          </div>

          <p class="download-message" id="download-message" role="status" aria-live="polite"></p>
        </article>
      </div>
    </section>

    <section class="content-section" id="como-funciona" aria-labelledby="how-title">
      <div class="section-heading">
        <p class="eyebrow">Como funciona</p>
        <h2 id="how-title">Fluxo simples, backend robusto.</h2>
      </div>

      <div class="steps-grid">
        <article>
          <span>01</span>
          <h3>Cole o link</h3>
          <p>A interface detecta automaticamente a plataforma e valida o formato da URL antes da analise.</p>
        </article>
        <article>
          <span>02</span>
          <h3>Analise o video</h3>
          <p>A API consulta o yt-dlp com protecao contra comandos maliciosos e retorna metadados seguros.</p>
        </article>
        <article>
          <span>03</span>
          <h3>Baixe com token</h3>
          <p>O servidor cria um link temporario para MP4 ou MP3, com expiracao automatica e rate limit.</p>
        </article>
      </div>
    </section>

    <section class="content-section" id="plataformas" aria-labelledby="platforms-title">
      <div class="section-heading">
        <p class="eyebrow">Plataformas suportadas</p>
        <h2 id="platforms-title">Pronto para os principais canais de video.</h2>
      </div>

      <div class="platform-grid">
        <article><span>YT</span><strong>YouTube</strong><small>Videos publicos e shorts</small></article>
        <article><span>TK</span><strong>TikTok</strong><small>Videos curtos e links vm/vt</small></article>
        <article><span>IG</span><strong>Instagram Reels</strong><small>Reels publicos</small></article>
        <article><span>IV</span><strong>Instagram Videos</strong><small>Posts e videos publicos</small></article>
        <article><span>FB</span><strong>Facebook Videos</strong><small>Watch e videos publicos</small></article>
        <article><span>KW</span><strong>Kwai</strong><small>Links kwai.com e kwai.app</small></article>
      </div>
    </section>

    <section class="content-section faq-section" id="faq" aria-labelledby="faq-title">
      <div class="section-heading">
        <p class="eyebrow">Perguntas frequentes</p>
        <h2 id="faq-title">O essencial antes de baixar.</h2>
      </div>

      <div class="faq-list">
        {faqItems.map((item) => (
          <details>
            <summary>{item.question}</summary>
            <p>{item.answer}</p>
          </details>
        ))}
      </div>
    </section>

    <footer class="video-footer">
      <div>
        <strong>FP Agency Videos</strong>
        <p>Ferramenta profissional para analise e download temporario de videos publicos.</p>
      </div>
      <nav aria-label="Links legais">
        <a href={`${basePath}/termos-de-servico`}>Termos</a>
        <a href={`${basePath}/politica-de-privacidade`}>Privacidade</a>
        <a href={`${basePath}/aviso-legal`}>Aviso legal</a>
      </nav>
    </footer>
  </main>
</Layout>

<style>
  :global(body) {
    background: #050505;
  }

  .video-download-page {
    --page-bg: #050505;
    --card-bg: #101010;
    --accent: #00ff88;
    --text: #ffffff;
    --muted: rgba(255, 255, 255, 0.68);
    --soft: rgba(255, 255, 255, 0.08);
    --soft-strong: rgba(255, 255, 255, 0.14);
    --danger: #ff5b5b;
    --warning: #ffd166;
    width: 100%;
    min-height: 100vh;
    background:
      linear-gradient(rgba(255, 255, 255, 0.025) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.025) 1px, transparent 1px),
      var(--page-bg);
    background-size: 44px 44px;
    color: var(--text);
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    overflow-x: hidden;
  }

  .video-download-page [hidden] {
    display: none !important;
  }

  .video-nav,
  .hero-section,
  .analysis-section,
  .content-section,
  .video-footer {
    width: min(calc(100% - 32px), 1180px);
    margin: 0 auto;
  }

  .video-nav {
    min-height: 78px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    border-bottom: 1px solid var(--soft);
  }

  .video-brand,
  .video-nav-links,
  .trust-row,
  .panel-header,
  .group-title,
  .video-footer,
  .video-footer nav {
    display: flex;
    align-items: center;
  }

  .video-brand {
    gap: 12px;
    color: var(--text);
    font-weight: 800;
  }

  .brand-mark {
    width: 36px;
    height: 36px;
    display: grid;
    place-items: center;
    border: 1px solid rgba(0, 255, 136, 0.42);
    border-radius: 8px;
    background: rgba(0, 255, 136, 0.1);
    color: var(--accent);
    font-size: 0.82rem;
  }

  .video-nav-links {
    gap: 18px;
    color: var(--muted);
    font-size: 0.94rem;
  }

  .video-nav-links a,
  .video-footer a {
    color: inherit;
    transition: color 180ms ease;
  }

  .video-nav-links a:hover,
  .video-footer a:hover {
    color: var(--accent);
  }

  .hero-section {
    min-height: calc(100vh - 78px);
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(360px, 0.95fr);
    align-items: center;
    gap: 42px;
    padding: 54px 0 70px;
  }

  .eyebrow,
  .panel-kicker {
    margin: 0 0 12px;
    color: var(--accent);
    font-size: 0.82rem;
    font-weight: 800;
    text-transform: uppercase;
  }

  h1,
  h2,
  h3,
  p {
    margin: 0;
  }

  h1 {
    max-width: 780px;
    font-size: clamp(2.35rem, 6vw, 5rem);
    line-height: 0.98;
    color: var(--text);
  }

  .hero-lead {
    max-width: 690px;
    margin-top: 22px;
    color: var(--muted);
    font-size: clamp(1rem, 2vw, 1.18rem);
    line-height: 1.7;
  }

  .trust-row {
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 26px;
  }

  .trust-row span,
  .platform-badge,
  .service-pill {
    border: 1px solid var(--soft);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.04);
    color: rgba(255, 255, 255, 0.78);
  }

  .trust-row span {
    padding: 9px 12px;
    font-size: 0.88rem;
  }

  .tool-panel,
  .video-result,
  .download-panel,
  .steps-grid article,
  .platform-grid article,
  .faq-list details {
    background: rgba(16, 16, 16, 0.94);
    border: 1px solid var(--soft);
    border-radius: 8px;
    box-shadow: 0 20px 70px rgba(0, 0, 0, 0.32);
  }

  .tool-panel {
    padding: clamp(22px, 4vw, 34px);
    position: relative;
  }

  .tool-panel::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    border-top: 1px solid rgba(0, 255, 136, 0.35);
    pointer-events: none;
  }

  .panel-header {
    justify-content: space-between;
    gap: 18px;
    margin-bottom: 26px;
  }

  .panel-header h2 {
    font-size: clamp(1.35rem, 3vw, 2rem);
  }

  .status-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 0 8px rgba(0, 255, 136, 0.12);
    animation: pulse 1.9s ease-in-out infinite;
  }

  .analyzer-form {
    display: grid;
    gap: 14px;
  }

  .analyzer-form label {
    color: rgba(255, 255, 255, 0.84);
    font-weight: 700;
    font-size: 0.94rem;
  }

  .input-shell {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: 10px;
    padding: 8px;
    border: 1px solid var(--soft);
    border-radius: 8px;
    background: #050505;
    transition:
      border-color 180ms ease,
      box-shadow 180ms ease;
  }

  .input-shell:focus-within {
    border-color: rgba(0, 255, 136, 0.72);
    box-shadow: 0 0 0 4px rgba(0, 255, 136, 0.08);
  }

  .input-shell input {
    width: 100%;
    min-width: 0;
    border: 0;
    outline: 0;
    background: transparent;
    color: var(--text);
    font: inherit;
    padding: 13px 10px;
  }

  .input-shell input::placeholder {
    color: rgba(255, 255, 255, 0.36);
  }

  .service-pill {
    padding: 8px 11px;
    white-space: nowrap;
    font-size: 0.78rem;
  }

  .service-pill.is-active {
    border-color: rgba(0, 255, 136, 0.4);
    background: rgba(0, 255, 136, 0.11);
    color: var(--accent);
  }

  .primary-button,
  .download-option {
    border: 0;
    border-radius: 8px;
    cursor: pointer;
    font: inherit;
    font-weight: 800;
    transition:
      transform 180ms ease,
      border-color 180ms ease,
      background 180ms ease,
      opacity 180ms ease;
  }

  .primary-button {
    min-height: 54px;
    background: var(--accent);
    color: #001b0e;
  }

  .primary-button:hover,
  .download-option:not(:disabled):hover {
    transform: translateY(-1px);
  }

  .primary-button:disabled,
  .download-option:disabled {
    cursor: not-allowed;
    opacity: 0.54;
  }

  .form-message,
  .download-message {
    min-height: 24px;
    color: var(--muted);
    font-size: 0.92rem;
    line-height: 1.5;
  }

  .form-message.is-error,
  .download-message.is-error {
    color: var(--danger);
  }

  .form-message.is-success,
  .download-message.is-success {
    color: var(--accent);
  }

  .analysis-section,
  .content-section {
    padding: 74px 0;
  }

  .section-heading {
    max-width: 760px;
    margin-bottom: 28px;
  }

  .section-heading h2 {
    font-size: clamp(1.8rem, 4vw, 3.2rem);
    line-height: 1.08;
  }

  .result-layout {
    display: grid;
    grid-template-columns: minmax(0, 0.92fr) minmax(360px, 1.08fr);
    gap: 22px;
  }

  .video-result {
    overflow: hidden;
  }

  .video-thumbnail {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 9;
    height: auto;
    object-fit: cover;
    background: #090909;
    border-bottom: 1px solid var(--soft);
  }

  .video-meta {
    padding: 20px;
  }

  .platform-badge {
    display: inline-flex;
    margin-bottom: 14px;
    padding: 7px 10px;
    color: var(--accent);
    border-color: rgba(0, 255, 136, 0.36);
  }

  .video-meta h3 {
    font-size: clamp(1.18rem, 3vw, 1.58rem);
    line-height: 1.2;
  }

  .video-meta dl {
    display: grid;
    gap: 12px;
    margin: 18px 0 0;
  }

  .video-meta dl div {
    display: flex;
    justify-content: space-between;
    gap: 18px;
    padding-top: 12px;
    border-top: 1px solid var(--soft);
  }

  .video-meta dt {
    color: var(--muted);
  }

  .video-meta dd {
    margin: 0;
    color: var(--text);
    text-align: right;
  }

  .download-panel {
    padding: 22px;
    display: grid;
    gap: 24px;
  }

  .download-group {
    display: grid;
    gap: 14px;
  }

  .group-title {
    justify-content: space-between;
    gap: 16px;
  }

  .group-title h3 {
    font-size: 1.05rem;
  }

  .group-title span {
    color: var(--muted);
    font-size: 0.88rem;
  }

  .option-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 10px;
  }

  .download-option {
    display: grid;
    gap: 7px;
    align-content: start;
    min-height: 98px;
    padding: 14px;
    border: 1px solid var(--soft);
    background: #070707;
    color: var(--text);
    text-align: left;
  }

  .download-option:not(:disabled):hover {
    border-color: rgba(0, 255, 136, 0.48);
    background: rgba(0, 255, 136, 0.08);
  }

  .download-option strong {
    font-size: 1rem;
  }

  .download-option span {
    color: var(--muted);
    font-size: 0.84rem;
    font-weight: 600;
    line-height: 1.35;
  }

  .download-option small {
    color: rgba(255, 255, 255, 0.54);
    font-size: 0.78rem;
  }

  .steps-grid,
  .platform-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
  }

  .steps-grid article,
  .platform-grid article {
    padding: 22px;
  }

  .steps-grid span,
  .platform-grid span {
    display: inline-grid;
    place-items: center;
    width: 40px;
    height: 40px;
    margin-bottom: 18px;
    border-radius: 8px;
    background: rgba(0, 255, 136, 0.1);
    color: var(--accent);
    font-weight: 900;
  }

  .steps-grid h3,
  .platform-grid strong {
    display: block;
    margin-bottom: 9px;
    color: var(--text);
    font-size: 1.05rem;
  }

  .steps-grid p,
  .platform-grid small,
  .faq-list p,
  .video-footer p {
    color: var(--muted);
    line-height: 1.65;
  }

  .platform-grid {
    grid-template-columns: repeat(6, minmax(0, 1fr));
  }

  .faq-list {
    display: grid;
    gap: 10px;
  }

  .faq-list details {
    padding: 18px 20px;
  }

  .faq-list summary {
    cursor: pointer;
    color: var(--text);
    font-weight: 800;
  }

  .faq-list p {
    margin-top: 12px;
  }

  .video-footer {
    justify-content: space-between;
    gap: 24px;
    padding: 36px 0 48px;
    border-top: 1px solid var(--soft);
    color: var(--muted);
  }

  .video-footer strong {
    display: block;
    margin-bottom: 6px;
    color: var(--text);
  }

  .video-footer nav {
    gap: 16px;
    flex-wrap: wrap;
  }

  @keyframes pulse {
    0%,
    100% {
      transform: scale(1);
      opacity: 1;
    }

    50% {
      transform: scale(0.86);
      opacity: 0.7;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    *,
    *::before,
    *::after {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      scroll-behavior: auto !important;
      transition-duration: 0.01ms !important;
    }
  }

  @media (max-width: 980px) {
    .hero-section,
    .result-layout {
      grid-template-columns: 1fr;
    }

    .hero-section {
      min-height: auto;
      padding-top: 42px;
    }

    .platform-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 720px) {
    .video-nav {
      align-items: flex-start;
      flex-direction: column;
      justify-content: center;
      padding: 16px 0;
    }

    .video-nav-links {
      width: 100%;
      justify-content: space-between;
      gap: 12px;
      font-size: 0.86rem;
    }

    .input-shell,
    .option-grid,
    .steps-grid,
    .platform-grid {
      grid-template-columns: 1fr;
    }

    .service-pill {
      justify-self: start;
      margin-left: 10px;
      margin-bottom: 8px;
    }

    .video-meta dl div,
    .group-title,
    .video-footer {
      align-items: flex-start;
      flex-direction: column;
    }

    .video-meta dd {
      text-align: left;
    }
  }
</style>

<script type="module">
  const page = document.querySelector('.video-download-page');
  const apiRoot = String(page?.dataset.apiBase || 'http://localhost:3001').replace(/\/$/, '');
  const API_TIMEOUT_MS = 60000;
  const form = document.getElementById('video-form');
  const urlInput = document.getElementById('video-url');
  const analyzeButton = document.getElementById('analyze-button');
  const servicePill = document.getElementById('service-pill');
  const formMessage = document.getElementById('form-message');
  const analysisSection = document.getElementById('analysis-section');
  const thumbnail = document.getElementById('video-thumbnail');
  const resultPlatform = document.getElementById('result-platform');
  const resultTitle = document.getElementById('result-title');
  const resultAuthor = document.getElementById('result-author');
  const resultDuration = document.getElementById('result-duration');
  const resultTime = document.getElementById('result-time');
  const videoOptions = document.getElementById('video-options');
  const audioOptions = document.getElementById('audio-options');
  const downloadMessage = document.getElementById('download-message');

  const services = [
    { label: 'YouTube', domains: ['youtube.com', 'youtu.be', 'youtube-nocookie.com', 'music.youtube.com'] },
    { label: 'TikTok', domains: ['tiktok.com', 'vm.tiktok.com', 'vt.tiktok.com'] },
    { label: 'Instagram Reels', domains: ['instagram.com'], pathIncludes: ['/reel/'] },
    { label: 'Instagram Videos', domains: ['instagram.com'] },
    { label: 'Facebook Videos', domains: ['facebook.com', 'fb.watch', 'fb.com'] },
    { label: 'Kwai', domains: ['kwai.com', 'kwai.app', 'kw.ai'] },
  ];

  let currentVideo = null;
  let currentUrl = '';

  urlInput?.addEventListener('input', () => {
    updateDetectedService(urlInput.value);
  });

  form?.addEventListener('submit', async (event) => {
    event.preventDefault();

    const url = urlInput.value.trim();
    const service = detectService(url);

    if (!service) {
      showFormMessage('Cole um link valido do YouTube, TikTok, Instagram, Facebook ou Kwai.', 'error');
      urlInput.focus();
      return;
    }

    setAnalyzeLoading(true);
    showFormMessage('Analisando video com seguranca...', 'neutral');
    clearDownloadMessage();

    try {
      const data = await postJson('/api/info', { url });
      currentVideo = data;
      currentUrl = data.url || url;
      renderVideoInfo(data);
      showFormMessage('Analise concluida. Escolha uma opcao de download.', 'success');
      analysisSection.hidden = false;
      analysisSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
    } catch (error) {
      showFormMessage(error.message, 'error');
    } finally {
      setAnalyzeLoading(false);
    }
  });

  document.addEventListener('click', async (event) => {
    const button = event.target.closest('.download-option');
    if (!button || button.disabled || !currentVideo) return;

    button.disabled = true;
    button.dataset.loading = 'true';
    const previousLabel = button.querySelector('small')?.textContent || '';
    const small = button.querySelector('small');
    if (small) small.textContent = 'Gerando link temporario...';
    showDownloadMessage('Preparando download seguro...', 'neutral');

    try {
      const data = await postJson('/api/download', {
        url: currentUrl,
        type: button.dataset.type,
        quality: button.dataset.quality,
        title: currentVideo.title,
      });

      triggerDownload(data.downloadUrl, data.filename);
      showDownloadMessage(`Link temporario gerado. Expira em ${formatExpiresAt(data.expiresAt)}.`, 'success');
    } catch (error) {
      showDownloadMessage(error.message, 'error');
    } finally {
      button.disabled = button.dataset.available !== 'true';
      button.dataset.loading = 'false';
      if (small) small.textContent = previousLabel;
    }
  });

  function updateDetectedService(value) {
    const service = detectService(value);
    servicePill.textContent = service ? service.label : 'Aguardando link';
    servicePill.classList.toggle('is-active', Boolean(service));
  }

  function detectService(value) {
    let parsed;

    try {
      parsed = new URL(value.trim());
    } catch {
      return null;
    }

    if (!['http:', 'https:'].includes(parsed.protocol)) return null;

    const host = parsed.hostname.toLowerCase().replace(/^www\./, '');
    const path = parsed.pathname.toLowerCase();

    return (
      services.find((service) => {
        const domainMatch = service.domains.some((domain) => host === domain || host.endsWith(`.${domain}`));
        const pathMatch = service.pathIncludes ? service.pathIncludes.some((item) => path.includes(item)) : true;
        return domainMatch && pathMatch;
      }) || null
    );
  }

  async function postJson(endpoint, payload) {
    let response;
    const controller = new AbortController();
    const timeoutId = window.setTimeout(() => controller.abort(), API_TIMEOUT_MS);

    try {
      response = await fetch(`${apiRoot}${endpoint}`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify(payload),
        signal: controller.signal,
      });
    } catch (error) {
      if (error?.name === 'AbortError') {
        throw new Error('A API demorou demais para responder. Verifique o servidor Express e tente novamente.');
      }

      throw new Error(`Nao foi possivel conectar com a API em ${apiRoot}. Execute npm run dev e verifique se o Express esta online.`);
    } finally {
      window.clearTimeout(timeoutId);
    }

    const body = await response.json().catch(() => null);

    if (!response.ok || body?.success === false) {
      const message = mapApiError(body?.error) || mapStatusToMessage(response.status);
      throw new Error(message);
    }

    return body.data;
  }

  function renderVideoInfo(data) {
    thumbnail.src = data.thumbnail || '';
    thumbnail.alt = data.title ? `Thumbnail do video ${data.title}` : 'Thumbnail do video analisado';
    resultPlatform.textContent = data.platform?.label || 'Plataforma detectada';
    resultTitle.textContent = data.title || 'Video sem titulo';
    resultAuthor.textContent = data.author || 'Autor nao informado';
    resultDuration.textContent = data.durationLabel || 'Duracao indisponivel';
    resultTime.textContent = new Intl.DateTimeFormat('pt-BR', {
      hour: '2-digit',
      minute: '2-digit',
      day: '2-digit',
      month: '2-digit',
    }).format(new Date(data.analyzedAt || Date.now()));

    renderOptions(videoOptions, data.downloadOptions?.video || []);
    renderOptions(audioOptions, data.downloadOptions?.audio || []);
  }

  function renderOptions(container, options) {
    container.replaceChildren();

    options.forEach((option) => {
      const button = document.createElement('button');
      button.type = 'button';
      button.className = 'download-option';
      button.disabled = !option.available;
      button.dataset.type = option.type;
      button.dataset.quality = option.value;
      button.dataset.available = option.available ? 'true' : 'false';

      const title = document.createElement('strong');
      title.textContent = option.quality;

      const meta = document.createElement('span');
      meta.textContent = `${option.resolution || 'Formato'} - ${option.estimatedSizeLabel || 'Tamanho indisponivel'}`;

      const hint = document.createElement('small');
      hint.textContent = option.available ? 'Baixar agora' : 'Indisponivel para este link';

      button.append(title, meta, hint);
      container.append(button);
    });
  }

  function setAnalyzeLoading(isLoading) {
    analyzeButton.disabled = isLoading;
    analyzeButton.querySelector('span').textContent = isLoading ? 'Analisando...' : 'Analisar Video';
  }

  function showFormMessage(message, type) {
    formMessage.textContent = message;
    formMessage.className = `form-message ${type === 'error' ? 'is-error' : type === 'success' ? 'is-success' : ''}`;
  }

  function showDownloadMessage(message, type) {
    downloadMessage.textContent = message;
    downloadMessage.className = `download-message ${type === 'error' ? 'is-error' : type === 'success' ? 'is-success' : ''}`;
  }

  function clearDownloadMessage() {
    downloadMessage.textContent = '';
    downloadMessage.className = 'download-message';
  }

  function triggerDownload(url, filename) {
    const anchor = document.createElement('a');
    anchor.href = url;
    anchor.download = filename || 'fp-agency-video';
    anchor.rel = 'noopener';
    document.body.append(anchor);
    anchor.click();
    anchor.remove();
  }

  function formatExpiresAt(value) {
    return new Intl.DateTimeFormat('pt-BR', {
      hour: '2-digit',
      minute: '2-digit',
    }).format(new Date(value));
  }

  function mapStatusToMessage(status) {
    if (status === 400) return 'Link invalido ou plataforma nao suportada.';
    if (status === 403) return 'Video privado, restrito ou origem nao autorizada.';
    if (status === 404) return 'Video removido ou link temporario expirado.';
    if (status === 429) return 'Limite excedido. Aguarde alguns minutos e tente novamente.';
    return 'Falha do servidor. Tente novamente em instantes.';
  }

  function mapApiError(error) {
    if (!error) return '';

    const messages = {
      INVALID_URL: 'Link invalido. Cole uma URL completa do video.',
      UNSUPPORTED_DOMAIN: 'Dominio nao suportado. Use YouTube, TikTok, Instagram, Facebook ou Kwai.',
      VIDEO_PRIVATE: 'Video privado, restrito ou exige login.',
      VIDEO_REMOVED: 'Video indisponivel, removido ou bloqueado pela plataforma.',
      FORMAT_UNAVAILABLE: 'Esta qualidade nao esta disponivel para o video informado.',
      PROVIDER_RATE_LIMIT: 'A plataforma limitou novas tentativas. Aguarde alguns minutos.',
      YTDLP_NOT_FOUND: 'yt-dlp nao esta instalado ou nao foi encontrado no servidor.',
      YTDLP_TIMEOUT: 'yt-dlp demorou demais para responder. Tente novamente em instantes.',
      INVALID_PROVIDER_RESPONSE: 'A plataforma retornou uma resposta inesperada.',
      SERVER_ERROR: 'Falha interna da API. Verifique os logs do Express.',
    };

    return messages[error.code] || error.message || '';
  }
</script>
