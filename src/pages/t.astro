/* ============================================================
   WEBVIEW DETECTION + UNIVERSAL LINK HANDLER
   ============================================================ */
function isLockedWebView() {
  const ua = navigator.userAgent || '';
  return /(Kwai|Instagram|FBAN|FBAV|TikTok|Line\/|MicroMessenger|Snapchat|wv\b|WebView)/i.test(ua);
}
function isAndroid() { return /Android/i.test(navigator.userAgent); }

function openLink(e, url) {
  if (e) e.preventDefault();
  if (!url || !url.startsWith('http')) return;
  if (isLockedWebView()) { uelShow(url); return; }
  const w = window.open(url, '_blank', 'noopener,noreferrer');
  if (!w || w.closed || typeof w.closed === 'undefined') window.location.href = url;
}

/* ── Unified Exit Layer ── */
function uelShow(url) {
  window.__uel_url = url;
  const d = document.getElementById('uel-url-display');
  if (d) d.textContent = url.replace(/^https?:\/\//, '');
  const b = document.getElementById('uel-copy-btn');
  if (b) { b.classList.remove('copied'); b.innerHTML = '<i class="ri-clipboard-line"></i> Copiar Link'; }
  document.getElementById('unified-exit-layer').classList.add('show');
  document.body.style.overflow = 'hidden';
}
function uelClose() {
  document.getElementById('unified-exit-layer').classList.remove('show');
  document.body.style.overflow = '';
  window.__uel_url = null;
}
function uelForceExternal() {
  const url = window.__uel_url; if (!url) return;
  if (isAndroid()) { window.location.href = 'intent://' + url.replace(/^https?:\/\//, '') + '#Intent;scheme=https;action=android.intent.action.VIEW;end'; return; }
  window.location.href = url;
}
function uelCopyUrl() {
  const url = window.__uel_url; if (!url) return;
  const btn = document.getElementById('uel-copy-btn');
  const ok  = () => { if(btn){btn.classList.add('copied');btn.innerHTML='<i class="ri-check-line"></i> Copiado! Cole no navegador';} };
  const err = () => { if(btn) btn.innerHTML='<i class="ri-close-line"></i> Erro ao copiar'; };
  if (navigator.clipboard && navigator.clipboard.writeText) { navigator.clipboard.writeText(url).then(ok).catch(()=>fbCopy(url,ok,err)); }
  else { fbCopy(url,ok,err); }
}
function fbCopy(url,ok,err) {
  try { const t=document.createElement('textarea'); t.value=url; t.style.cssText='position:fixed;opacity:0;top:0;left:0;'; document.body.appendChild(t); t.focus(); t.select(); document.execCommand('copy'); document.body.removeChild(t); ok(); } catch(_){err();}
}

function patchAllLinks() {
  document.querySelectorAll('a[href^="http"]').forEach(link => {
    if (link.dataset.patched) return;
    link.removeAttribute('target');
    link.setAttribute('rel', 'noopener noreferrer external');
    link.addEventListener('click', function(e){ openLink(e, this.href); });
    link.dataset.patched = '1';
  });
}

/* ============================================================
   NAVIGATION
   ============================================================ */
// 'Comunidade' é adicionada aos views públicos!
const PUBLIC_VIEWS = new Set(['Landing', 'Diretrizes', 'Login', 'Cadastro', 'Redefinir', 'Comunidade']);
let _prevPage = 'Landing';

function isPublicView(page) {
  return PUBLIC_VIEWS.has(page);
}

function hasValidSessionToken() {
  return Boolean(sessionStorage.getItem('idToken'));
}

function storeDashboardSession(idToken, data) {
  sessionStorage.setItem('idToken', idToken);
  sessionStorage.setItem('user_nome',  data?.nome || '');
  sessionStorage.setItem('user_nivel', data?.nivel || '');
  sessionStorage.setItem('user_foto',  data?.avatar || data?.foto || '');
}

function setShellState(page) {
  const appCont = document.getElementById('main-app-container');
  const isPublic = isPublicView(page);
  if (!appCont) return;

  appCont.dataset.portalState = isPublic ? 'public' : 'private';
  appCont.dataset.activeView = page;
  appCont.dataset.authState = hasValidSessionToken() ? 'authenticated' : 'guest';
  appCont.classList.toggle('dark-mode', isPublic);

  document.getElementById('wa-fab-container')?.classList.toggle('portal-hidden', !isPublic);
  document.dispatchEvent(new CustomEvent('portal:view-change', { detail: { page, isPublic } }));
}

function nav(page) {
  const target = document.getElementById('view-' + page);
  if (!target) return;

  if (!isPublicView(page) && !hasValidSessionToken()) {
    globalAlert('Sessão Necessária', 'Faça login para acessar esta área.', 'warning');
    nav('Login');
    return;
  }

  const cur = document.querySelector('.view.active');
  if (cur) _prevPage = cur.id.replace('view-', '');

  document.querySelectorAll('.view').forEach(v => v.classList.remove('active'));
  target.classList.add('active');
  setShellState(page);

  document.querySelectorAll('.rc-faq-header').forEach(h => {
    h.onclick = () => {
      const item = h.parentElement;
      document.querySelectorAll('.rc-faq-item.open').forEach(o => { if(o!==item) o.classList.remove('open'); });
      item.classList.toggle('open');
    };
  });

  document.querySelectorAll('.nav-item').forEach(el => {
    const isActive = el.getAttribute('data-page') === page;
    el.classList.toggle('active', isActive);
    if (isActive) el.scrollIntoView({behavior:'smooth',inline:'center',block:'nearest'});
  });

  if (typeof window['load'+page] === 'function') window['load'+page]();
  window.scrollTo(0,0);
  setTimeout(patchAllLinks, 100);
}

function navBack() {
  const token = sessionStorage.getItem('idToken');
  nav(token ? 'Dashboard' : 'Landing');
}

/* ============================================================
   LOADER & MODALS
   ============================================================ */
let loaderTimeout;
function showLoader() {
  document.getElementById('global-loader')?.classList.add('is-visible');
  clearTimeout(loaderTimeout);
  loaderTimeout = setTimeout(hideLoader, 12000);
}
function hideLoader() {
  document.getElementById('global-loader')?.classList.remove('is-visible');
  clearTimeout(loaderTimeout);
}

function globalAlert(title, message, type='info') {
  document.getElementById('global_alertTitle').innerText   = title;
  document.getElementById('global_alertMessage').innerText = message;
  const iconWrap = document.getElementById('global_alertIcon');
  iconWrap.className = 'modal-icon-wrapper ' + type;
  let icon = 'fa-info-circle';
  if(type==='success') icon='fa-check-circle';
  if(type==='error')   icon='fa-times-circle';
  if(type==='warning') icon='fa-exclamation-triangle';
  iconWrap.innerHTML = `<i class="fas ${icon}"></i>`;
  document.getElementById('global_alertModal').classList.add('active');
}
function closeGlobalAlert() { document.getElementById('global_alertModal').classList.remove('active'); }

let confirmCallback = null;
function globalConfirm(title, message, onConfirm) {
  document.getElementById('global_confirmTitle').innerText   = title;
  document.getElementById('global_confirmMessage').innerText = message;
  confirmCallback = onConfirm;
  document.getElementById('global_confirmModal').classList.add('active');
  document.getElementById('global_btnConfirmAction').onclick = function() { closeGlobalConfirm(); if(confirmCallback) confirmCallback(); };
}
function closeGlobalConfirm() { document.getElementById('global_confirmModal').classList.remove('active'); }

let activeMediaInput = null;
function openMediaModal(inputId) { activeMediaInput = inputId; document.getElementById('global_mediaModal').classList.add('active'); }
function closeMediaModal() { document.getElementById('global_mediaModal').classList.remove('active'); }
function selectMedia(type) {
  closeMediaModal();
  const input = document.getElementById(activeMediaInput);
  if (type==='camera') input.setAttribute('capture','environment'); else input.removeAttribute('capture');
  input.click();
}

/* ============================================================
   FIREBASE AUTH E GS-RUN
   ============================================================ */
async function gsRun(action, dataObj) {
  try {
    const response = await fetch(API_URL, { method:'POST', body:JSON.stringify({ action, data:dataObj }) });
    return await response.json();
  } catch (error) {
    hideLoader();
    return { success:false, locked:false, msg:"Falha de comunicação com o servidor. Tente novamente." };
  }
}

function forceLogout(msg) {
  sessionStorage.clear();
  try { firebase.auth().signOut(); } catch(e){}
  document.getElementById('main-app-container')?.setAttribute('data-auth-state', 'guest');
  if (msg) globalAlert('Sessão Encerrada', msg, 'warning');
  nav('Landing');
}

function togglePassword(inputId, iconEl) {
  const input = document.getElementById(inputId);
  if (input.type==='password') { input.type='text'; iconEl.classList.replace('fa-eye','fa-eye-slash'); }
  else                         { input.type='password'; iconEl.classList.replace('fa-eye-slash','fa-eye'); }
}

/* ============================================================
   NOVO: LÓGICA DA COMUNIDADE (FEED E POSTAGEM)
   ============================================================ */
let feedDataRaw = [];

// Abre o modal somente se o usuário estiver logado
function abrirModalPost() {
  if (!hasValidSessionToken()) {
    globalAlert('Acesso Restrito', 'Você precisa fazer login para publicar na comunidade.', 'warning');
    nav('Login');
    return;
  }
  document.getElementById('modalPostFeed').classList.add('active');
  document.getElementById('postUrl').value = '';
}

function fecharModalPost() {
  document.getElementById('modalPostFeed').classList.remove('active');
}

// Submete a publicação para a API
async function enviarPost() {
  const token = sessionStorage.getItem('idToken');
  const urlKwai = document.getElementById('postUrl').value;
  const categoria = document.getElementById('postCategoria').value;
  
  if (!urlKwai || !urlKwai.includes('kwai')) {
    globalAlert('Erro', 'Por favor, cole um link válido do Kwai.', 'error');
    return;
  }

  const btn = document.getElementById('btnSubmitPost');
  btn.disabled = true;
  btn.innerText = 'Enviando...';
  showLoader();

  try {
    const res = await gsRun('salvarPostFeed', { idToken: token, url: urlKwai, categoria: categoria });
    if (res.success) {
      fecharModalPost();
      globalAlert('Publicado!', 'Seu vídeo foi enviado para a comunidade.', 'success');
      loadComunidade(); // Recarrega o feed
    } else {
      globalAlert('Ops!', res.msg, 'error');
    }
  } catch(e) {
    globalAlert('Erro', 'Ocorreu um erro ao publicar.', 'error');
  } finally {
    hideLoader();
    btn.disabled = false;
    btn.innerText = 'Publicar';
  }
}

// Carrega a página da comunidade (Feed + Top 10)
async function loadComunidade() {
  const feedGrid = document.getElementById('feedGrid');
  const top10Container = document.getElementById('feedTop10List');
  
  if (feedGrid.innerHTML.includes('fa-circle-notch')) showLoader();
  
  try {
    // Busca dados do Feed
    const resFeed = await gsRun('getFeedData', {});
    if (resFeed.success) {
      feedDataRaw = resFeed.data || [];
      renderFeedCards(feedDataRaw);
    } else {
      feedGrid.innerHTML = `<p style="text-align:center;width:100%;color:#94a3b8">Não foi possível carregar a comunidade.</p>`;
    }

    // Busca dados do Top 10 (Ranking)
    // Passamos vazio pois a página é pública, a API deve retornar os dados gerais
    const resRank = await gsRun('getRankingData', {});
    if (resRank.success && resRank.data && resRank.data.length > 0) {
      // Pega apenas os 10 primeiros
      const top10 = resRank.data.slice(0, 10);
      top10Container.innerHTML = top10.map((u, i) => {
        const nome = (u.nome || 'Usuário').split(' ')[0];
        const avatar = (u.avatar && u.avatar.indexOf('http')===0) 
            ? u.avatar 
            : `https://ui-avatars.com/api/?name=${encodeURIComponent(nome)}&background=fed7aa&color=c2410c&bold=true&size=256`;
        
        return `
          <div class="top10-item">
            <div class="top10-avatar">
              <img src="${escapeHtml(avatar)}" alt="${escapeHtml(nome)}" loading="lazy">
              <div class="top10-badge">${i+1}</div>
            </div>
            <div class="top10-name">${escapeHtml(nome)}</div>
          </div>
        `;
      }).join('');
    } else {
      top10Container.innerHTML = `<p style="padding:20px;color:#94a3b8;font-size:0.85rem;">Ranking ainda em apuração.</p>`;
    }

  } catch (error) {
    console.error(error);
  } finally {
    hideLoader();
  }
}

// Função para extrair o ID do Kwai e gerar o iframe
function renderFeedCards(dataArray) {
  const grid = document.getElementById('feedGrid');
  if (!dataArray || dataArray.length === 0) {
    grid.innerHTML = `
      <div style="text-align:center;grid-column:1/-1;padding:40px 20px;">
        <i class="fas fa-video fa-3x" style="color:#3d4d7a;margin-bottom:15px;opacity:0.5"></i>
        <h3 style="color:#e2e8f0;font-size:1.2rem;margin-bottom:10px">Nenhuma publicação ainda</h3>
        <p style="color:#64748b;font-size:0.9rem">Seja o primeiro a compartilhar seu conteúdo com a agência!</p>
      </div>`;
    return;
  }

  grid.innerHTML = dataArray.map(post => {
    // Tenta extrair o videoId da URL para o embed oficial do kwai (https://k.kwai.com/video/ID)
    // Se a url for curta (kwai-video.com/p/xxx), usamos a tag <a> como fallback
    let embedHtml = '';
    const videoIdMatch = post.url.match(/video\/([a-zA-Z0-9_]+)/);
    
    if (videoIdMatch && videoIdMatch[1]) {
      const videoId = videoIdMatch[1];
      embedHtml = `<iframe src="https://k.kwai.com/video/${videoId}" frameborder="0" allowfullscreen class="kwai-iframe"></iframe>`;
    } else {
      // Se for link curto ou formato diferente, criamos um card clicável bonito
      embedHtml = `
        <a href="${post.url}" target="_blank" rel="noopener noreferrer" class="feed-link-card">
          <div class="play-btn"><i class="fas fa-play"></i></div>
          <span>Assistir no Kwai</span>
        </a>
      `;
    }

    const avatar = (post.avatar && post.avatar.indexOf('http')===0) 
            ? post.avatar 
            : `https://ui-avatars.com/api/?name=${encodeURIComponent(post.nome)}&background=fed7aa&color=c2410c&bold=true&size=256`;

    return `
      <div class="feed-card">
        <div class="feed-card-header">
          <img src="${escapeHtml(avatar)}" alt="Avatar">
          <div class="feed-card-info">
            <strong>${escapeHtml(post.nome.split(' ')[0])}</strong>
            <span>${escapeHtml(post.dataHora || 'Recentemente')}</span>
          </div>
          <div class="feed-card-tag">${escapeHtml(post.categoria)}</div>
        </div>
        <div class="feed-card-media">
          ${embedHtml}
        </div>
      </div>
    `;
  }).join('');
}

// Filtra visualmente os cards já carregados
function filtrarFeed(categoria, btnElement) {
  document.querySelectorAll('.feed-filter').forEach(btn => btn.classList.remove('active'));
  btnElement.classList.add('active');
  
  if (categoria === 'Todos') {
    renderFeedCards(feedDataRaw);
  } else {
    const filtrado = feedDataRaw.filter(p => p.categoria === categoria);
    renderFeedCards(filtrado);
  }
}

/* ============================================================
   FUNÇÕES GERAIS / EXISTENTES
   ============================================================ */

document.getElementById('loginForm').onsubmit = async function(e) {
  e.preventDefault();
  const btn = document.getElementById('btnLogin'); btn.textContent='Verificando...'; btn.disabled=true;
  showLoader();
  try {
    const uc = await firebase.auth().signInWithEmailAndPassword(this.email.value, this.senha.value);
    const idToken = await uc.user.getIdToken();
    const res = await gsRun('getDashboardData', { idToken });

    hideLoader(); 
    btn.textContent = 'ENTRAR'; 
    btn.disabled = false;

    if (res.success) { 
      storeDashboardSession(idToken, res.data);
      nav('Dashboard'); 
    }
    else { 
      globalAlert('Acesso Negado', res.msg, 'error'); 
      firebase.auth().signOut(); 
    }
  } catch (error) {
    hideLoader(); 
    btn.textContent = 'ENTRAR'; 
    btn.disabled = false;
    globalAlert('Erro no Login', 'E-mail ou senha incorretos.', 'error');
  }
};

