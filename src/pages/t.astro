/* ============================================================
   INIT
   ============================================================ */
async function initApp(){
  const appCont = document.getElementById('main-app-container');
  const token = sessionStorage.getItem('idToken');

  if (!token) {
    appCont?.setAttribute('data-auth-state', 'guest');
    // Para visitantes não logados, o padrão é ir para o Landing
    nav('Landing');
    hideLoader();
    return;
  }

  showLoader();
  appCont?.setAttribute('data-auth-state', 'checking');

  try {
    const res = await gsRun('getDashboardData', { idToken: token });
    if (res.success && !res.locked) {
      storeDashboardSession(token, res.data);
      appCont?.setAttribute('data-auth-state', 'authenticated');
      // Se estiver logado e abrir o site, vai direto para o Dashboard
      nav('Dashboard');
      return;
    }

    forceLogout(res.msg || 'Sua sessão expirou. Faça login novamente.');
  } catch (error) {
    forceLogout('Não foi possível validar sua sessão. Faça login novamente.');
  } finally {
    hideLoader();
  }
}

if (document.readyState==='loading') document.addEventListener('DOMContentLoaded', initApp);
else initApp();

