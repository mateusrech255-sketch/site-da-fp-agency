.feed-card-info span { color:#64748b; font-size:0.7rem; margin-top:2px; font-family:var(--mono); }
.feed-card-tag { background:rgba(255,107,43,.15); color:#ff9a5c; padding:4px 10px; border-radius:8px; font-size:0.7rem; font-weight:800; text-transform:uppercase; letter-spacing:0.5px; }

.feed-card-media { position:relative; width:100%; aspect-ratio:9/16; background:#0f1117; display:flex; align-items:center; justify-content:center; }
.kwai-iframe { width:100%; height:100%; border:none; }
.feed-link-card { text-decoration:none; display:flex; flex-direction:column; align-items:center; justify-content:center; width:100%; height:100%; background:linear-gradient(135deg, #1e2332, #0f1117); }
.play-btn { width:60px; height:60px; border-radius:50%; background:rgba(255,107,43,0.2); border:2px solid #ff6b2b; color:#ff6b2b; display:flex; align-items:center; justify-content:center; font-size:1.5rem; margin-bottom:15px; transition:transform 0.2s; }
.feed-link-card:hover .play-btn { transform:scale(1.1); background:#ff6b2b; color:#fff; }
.feed-link-card span { color:#cbd5e1; font-weight:600; font-size:0.9rem; }

/* DARK THEME HERITAGE */
.rc, .dg {
  --bg:           #0f1117;
  --bg-card:      #181c27;
  --bg-input:     #1e2332;
  --border:       #2a3048;
  --border-h:     #3d4d7a;
  --orange:       #ff6b2b;
  --orange2:      #ff9a5c;
  --orange-dim:   #ff6b2b18;
  --orange-glow:  rgba(255,107,43,.22);
  --green:        #22c55e;
  --green-dim:    #22c55e18;
  --red:          #ef4444;
  --red-dim:      #ef444418;
  --yellow:       #f59e0b;
  --yellow-dim:   #f59e0b18;
  --text:         #e2e8f0;
  --text-muted:   #64748b;
  --text-faint:   #1e2332;
  --grad-gold:    linear-gradient(135deg,#92680a,#f5d27a,#9a6f12,#f5e08a,#92680a);
  --grad-silver:  linear-gradient(135deg,#4b4b4a,#c8c8c6,#636362,#b8b8b6,#4b4b4a);
  --grad-bronze:  linear-gradient(135deg,#5a2f00,#c8865a,#7a3e18,#c48040,#5a2f00);
}

/* Componentes Antigos para Layout Geral */
.rc { font-family:'Sora',sans-serif; background:transparent; color:var(--text); overflow-x:hidden; position:relative; padding-bottom:80px; min-height:100dvh; }
.rc-hero { position:relative; padding:56px 20px 48px; text-align:center; overflow:hidden; }
.rc-hero::before { content:''; position:absolute; top:-60px; left:50%; transform:translateX(-50%); width:700px; height:380px; background:radial-gradient(ellipse,rgba(255,107,43,.13) 0%,transparent 65%); pointer-events:none; }
.rc-hero::after  { content:''; position:absolute; inset:0; background-image:linear-gradient(rgba(255,107,43,.04) 1px,transparent 1px),linear-gradient(90deg,rgba(255,107,43,.04) 1px,transparent 1px); background-size:44px 44px; pointer-events:none; -webkit-mask-image:radial-gradient(ellipse 80% 60% at 50% 0%,black 25%,transparent 100%); mask-image:radial-gradient(ellipse 80% 60% at 50% 0%,black 25%,transparent 100%); }
.rc-hero-inner { position:relative; z-index:1; }
.rc-badge { display:inline-flex; align-items:center; gap:8px; font-family:var(--mono); font-size:.7rem; color:var(--orange); letter-spacing:.1em; text-transform:uppercase; background:var(--orange-dim); padding:5px 15px; border-radius:99px; border:1px solid rgba(255,107,43,.3); margin-bottom:20px; }
.rc-badge-dot { width:6px; height:6px; border-radius:50%; background:var(--orange); box-shadow:0 0 8px var(--orange); animation:rc-pulse 2s ease-in-out infinite; }
@keyframes rc-pulse { 0%,100%{opacity:1} 50%{opacity:.3} }
.rc-hero-title { font-size:clamp(1.9rem,5.5vw,3.2rem); font-weight:900; line-height:1.05; letter-spacing:-.03em; margin-bottom:14px; }
.rc-hero-title span { background:linear-gradient(135deg,var(--orange),var(--orange2)); -webkit-background-clip:text; background-clip:text; color:transparent; }
.rc-hero-sub { font-size:.98rem; color:var(--text-muted); max-width:520px; margin:0 auto 32px; line-height:1.65; }
.rc-hero-actions { display:flex; flex-wrap:wrap; gap:12px; justify-content:center; }
.rc-partners { display:flex; align-items:center; justify-content:center; flex-wrap:wrap; gap:10px; margin-top:30px; color:var(--text-muted); font-size:.9rem; }
.rc-partners span:not(:first-child) { color:#fff; font-weight:600; }
.rc-btn-primary { display:inline-flex; align-items:center; gap:9px; background:var(--orange); color:#fff; font-family:'Sora',sans-serif; font-weight:700; font-size:.92rem; padding:14px 28px; border-radius:99px; text-decoration:none; border:none; cursor:pointer; box-shadow:0 6px 24px var(--orange-glow); transition:transform .18s,box-shadow .18s; }
.rc-btn-primary:hover { transform:translateY(-3px); box-shadow:0 10px 32px var(--orange-glow); color:#fff; }
.rc-btn-secondary { display:inline-flex; align-items:center; gap:9px; background:var(--bg-card); color:var(--text); font-family:'Sora',sans-serif; font-weight:600; font-size:.92rem; padding:14px 28px; border-radius:99px; text-decoration:none; border:1px solid var(--border); cursor:pointer; transition:border-color .18s,transform .18s; }
.rc-btn-secondary:hover { border-color:var(--border-h); transform:translateY(-2px); color:var(--text); }
.rc-section { padding:0 20px; max-width:960px; margin:0 auto 56px; }
.rc-section-last { margin-bottom:0; }
.rc-section-label { display:flex; align-items:center; gap:12px; margin-bottom:28px; }
.rc-section-label-text { font-family:var(--mono); font-size:.7rem; color:var(--text-muted); text-transform:uppercase; letter-spacing:.12em; white-space:nowrap; }
.rc-section-label-line { flex:1; height:1px; background:var(--border); }
.rc-who-grid { display:grid; grid-template-columns:repeat(auto-fit, minmax(200px, 1fr)); gap:15px; margin-top:20px; }
.rc-who-card { background:var(--bg-card); padding:24px; border-radius:15px; border:1px solid var(--border); text-align:center; }
.rc-who-card i { font-size:2.2rem; color:var(--orange); }
.rc-who-card h4 { color:#fff; margin:10px 0 5px; }
.rc-who-card p { font-size:.85rem; color:var(--text-muted); }
.rc-table-intro { color:var(--text-muted); font-size:.95rem; text-align:center; margin-bottom:20px; }
.rc-table-wrap { background:var(--bg-card); border:1px solid var(--border); border-radius:15px; overflow:hidden; }
.rc-earnings-table { width:100%; border-collapse:collapse; text-align:left; color:#fff; }
.rc-earnings-table thead { background:rgba(255,107,43,.1); }
.rc-earnings-table th,
.rc-earnings-table td { padding:15px; border-bottom:1px solid var(--border); }
.rc-earnings-table tbody tr:last-child td { border-bottom:0; }
.rc-earnings-table th { color:var(--orange); }
.rc-money { font-weight:700; color:#22c55e; }
.rc-table-note { color:var(--text-muted); font-size:.8rem; text-align:center; margin-top:10px; }
.rc-cta { background:linear-gradient(135deg,rgba(255,107,43,.12),rgba(255,154,92,.05)); border:1px solid rgba(255,107,43,.3); border-radius:20px; padding:48px 32px; text-align:center; position:relative; overflow:hidden; }
.rc-cta::before { content:''; position:absolute; top:-60px; right:-60px; width:240px; height:240px; background:radial-gradient(circle,rgba(255,107,43,.1) 0%,transparent 70%); pointer-events:none; }
.rc-cta-title { font-size:clamp(1.3rem,3.5vw,1.8rem); font-weight:800; color:var(--text); margin-bottom:10px; }
.rc-cta-sub   { font-size:.9rem; color:var(--text-muted); margin:0 auto 28px; max-width:400px; line-height:1.6; }
.rc-cta-btns  { display:flex; flex-wrap:wrap; gap:12px; justify-content:center; }

.dg { font-family:'Sora',sans-serif; background:transparent; color:var(--text); overflow-x:hidden; position:relative; padding-bottom:80px; }
.dg-banner { position:relative; overflow:hidden; background:linear-gradient(135deg,rgba(255,107,43,.15),rgba(255,154,92,.06)); border-bottom:1px solid rgba(255,107,43,.2); padding:52px 20px 48px; text-align:center; }
.dg-banner::before { content:''; position:absolute; top:-80px; left:50%; transform:translateX(-50%); width:700px; height:400px; background:radial-gradient(ellipse,rgba(255,107,43,.14) 0%,transparent 65%); pointer-events:none; }
.dg-banner::after  { content:''; position:absolute; inset:0; background-image:linear-gradient(rgba(255,107,43,.04) 1px,transparent 1px),linear-gradient(90deg,rgba(255,107,43,.04) 1px,transparent 1px); background-size:44px 44px; pointer-events:none; -webkit-mask-image:radial-gradient(ellipse 80% 70% at 50% 0%,black 30%,transparent 100%); mask-image:radial-gradient(ellipse 80% 70% at 50% 0%,black 30%,transparent 100%); }
.dg-banner-inner { position:relative; z-index:1; }
.dg-vigencia { display:inline-flex; align-items:center; gap:7px; font-family:var(--mono); font-size:.7rem; color:var(--orange); letter-spacing:.1em; text-transform:uppercase; background:var(--orange-dim); padding:5px 15px; border-radius:99px; border:1px solid rgba(255,107,43,.3); margin-bottom:20px; }
.dg-vigencia-dot { width:6px; height:6px; border-radius:50%; background:var(--orange); box-shadow:0 0 8px var(--orange); animation:dg-pulse 2s ease-in-out infinite; }
@keyframes dg-pulse { 0%,100%{opacity:1} 50%{opacity:.3} }
.dg-banner-title { font-size:clamp(1.8rem,5vw,3rem); font-weight:900; line-height:1.05; letter-spacing:-.03em; margin-bottom:14px; }
.dg-banner-title span { background:linear-gradient(135deg,var(--orange),var(--orange2)); -webkit-background-clip:text; background-clip:text; color:transparent; }
.dg-banner-sub { font-size:.98rem; color:var(--text-muted); max-width:480px; margin:0 auto; line-height:1.65; }
.dg-back { display:inline-flex; align-items:center; gap:7px; font-family:var(--mono); font-size:.75rem; color:var(--text-muted); text-decoration:none; letter-spacing:.05em; transition:color .2s,gap .2s; margin:28px 20px 0; cursor:pointer; background:none; border:none; }
.dg-back:hover { color:var(--orange); gap:10px; }
.dg-section { padding:0 20px; max-width:900px; margin:0 auto 52px; }
.dg-section-label { display:flex; align-items:center; gap:12px; margin-bottom:24px; }
.dg-section-label-text { font-family:var(--mono); font-size:.7rem; color:var(--text-muted); text-transform:uppercase; letter-spacing:.12em; white-space:nowrap; }
.dg-section-label-line { flex:1; height:1px; background:var(--border); }
.dg-levels { display:flex; flex-direction:column; gap:16px; }
.dg-level { background:var(--bg-card); border:1px solid var(--border); border-radius:20px; overflow:hidden; transition:border-color .22s,transform .22s,box-shadow .22s; }
.dg-level:hover { transform:translateY(-4px); box-shadow:0 20px 48px rgba(0,0,0,.35); }
.dg-level.gold   { border-top:3px solid #c9982a; } .dg-level.gold:hover   { border-color:#c9982a; border-top-color:#c9982a; }
.dg-level.silver { border-top:3px solid #8d8d8c; } .dg-level.silver:hover { border-color:#8d8d8c; border-top-color:#8d8d8c; }
.dg-level.bronze { border-top:3px solid #a05a2c; } .dg-level.bronze:hover { border-color:#a05a2c; border-top-color:#a05a2c; }
.dg-level-head { display:flex; justify-content:space-between; align-items:center; padding:22px 26px; flex-wrap:wrap; gap:12px; }
.dg-level-badge { display:inline-flex; align-items:center; gap:8px; padding:8px 16px; border-radius:8px; font-weight:800; font-size:.82rem; }
.dg-level-badge.gold   { background:var(--grad-gold);   color:#2d1a00; }
.dg-level-badge.silver { background:var(--grad-silver); color:#1a1a1a; }
.dg-level-badge.bronze { background:var(--grad-bronze); color:#fff; }
.dg-level-range { font-family:var(--mono); font-size:.72rem; color:var(--text-muted); background:var(--bg-input); border:1px solid var(--border); padding:5px 12px; border-radius:99px; }
.dg-bonus-row { padding:14px 26px; border-top:1px solid var(--text-faint); display:flex; align-items:center; gap:10px; font-family:var(--mono); font-size:.78rem; color:var(--text-muted); }
.dg-bonus-row span { font-size:1.05rem; font-weight:800; }
.gold   .dg-bonus-row { border-top-color:rgba(201,152,42,.15); } .gold   .dg-bonus-row span { color:#e8b84b; }
.silver .dg-bonus-row span { color:#c0c0c0; }
.bronze .dg-bonus-row span { color:#c88050; }
.dg-level-body { padding:0 26px 26px; display:grid; grid-template-columns:repeat(auto-fit,minmax(180px,1fr)); gap:10px; }
.dg-perk { display:flex; align-items:flex-start; gap:10px; background:var(--bg-input); border:1px solid var(--border); border-radius:10px; padding:14px; }
.dg-perk-icon { width:32px; height:32px; border-radius:8px; flex-shrink:0; display:flex; align-items:center; justify-content:center; font-size:.95rem; }
.gold   .dg-perk-icon { background:rgba(201,152,42,.15); color:#e8b84b; }
.silver .dg-perk-icon { background:rgba(141,141,140,.15); color:#bdbdbd; }
.bronze .dg-perk-icon { background:rgba(160,90,44,.15);  color:#c88050; }
.dg-perk-title { font-size:.83rem; font-weight:700; color:var(--text); margin-bottom:2px; }
.dg-perk-desc  { font-size:.76rem; color:var(--text-muted); line-height:1.45; }
.dg-cta { background:linear-gradient(135deg,rgba(255,107,43,.1),rgba(255,154,92,.04)); border:1px solid rgba(255,107,43,.25); border-radius:20px; padding:44px 28px; text-align:center; position:relative; overflow:hidden; }
.dg-cta::before { content:''; position:absolute; top:-60px; right:-60px; width:220px; height:220px; background:radial-gradient(circle,rgba(255,107,43,.08) 0%,transparent 70%); pointer-events:none; }
.dg-cta-title { font-size:1.4rem; font-weight:800; color:var(--text); margin-bottom:9px; }
.dg-cta-sub   { font-size:.88rem; color:var(--text-muted); margin:0 auto 24px; line-height:1.6; max-width:360px; }
.dg-cta-btn { display:inline-flex; align-items:center; gap:9px; background:var(--orange); color:#fff; font-family:'Sora',sans-serif; font-weight:700; font-size:.92rem; padding:14px 32px; border-radius:99px; text-decoration:none; box-shadow:0 6px 24px var(--orange-glow); transition:transform .18s,box-shadow .18s; border:none; cursor:pointer; }
.dg-cta-btn:hover { transform:translateY(-3px); box-shadow:0 10px 32px var(--orange-glow); color:#fff; }

/* Dashboard etc.. (mantidos os Private originais) */
.fp-agency-wrapper .auth-wrapper { display:flex; flex-direction:column; justify-content:center; align-items:center; min-height:calc(100dvh - 96px); padding:20px 15px; position:relative; z-index:10; }
.view:not(.active) .auth-wrapper { min-height:0; height:0; overflow:hidden; }
.fp-agency-wrapper .auth-card { background:white; padding:2rem; border-radius:16px; box-shadow:0 4px 12px rgba(249,115,22,.08); text-align:center; width:92%; max-width:400px; }
.fp-agency-wrapper .auth-card-reset { padding:2.5rem 2rem; }
.fp-agency-wrapper .auth-title { color:var(--primary); margin:0 0 5px; font-size:1.8rem; font-weight:800; }
.fp-agency-wrapper h2.auth-title { font-size:1.5rem; }
.fp-agency-wrapper .auth-subtitle { color:var(--gray); font-size:.85rem; margin-bottom:25px; }
.fp-agency-wrapper .auth-subtitle-accent { color:#9a3412; }
.fp-agency-wrapper .auth-google-btn { background:white; color:#333; border:1px solid #e2e8f0; display:flex; align-items:center; justify-content:center; gap:10px; margin-bottom:20px; font-weight:500; }
.fp-agency-wrapper .auth-google-icon { width:20px; height:20px; }
.fp-agency-wrapper .auth-separator { display:flex; align-items:center; gap:10px; margin:20px 0; }
.fp-agency-wrapper .auth-separator div { height:1px; background:#e2e8f0; flex:1; }
.fp-agency-wrapper .auth-separator span { font-size:.8rem; color:#94a3b8; }
.fp-agency-wrapper .btn-outline-primary { background:transparent; border:2px solid var(--primary); color:var(--primary); }
.fp-agency-wrapper .btn-outline-muted { background:transparent; border:1px solid #e2e8f0; color:#64748b; font-size:.85rem; }
.fp-agency-wrapper .auth-back-action { margin-top:16px; }
.fp-agency-wrapper .view-heading { width:min(calc(100% - 32px), 920px); margin:18px auto 12px; color:#1e293b; font-size:1.35rem; font-weight:800; letter-spacing:0; }
.fp-agency-wrapper .dashboard-hero { display:flex; align-items:center; gap:14px; width:min(calc(100% - 24px), 920px); margin:16px auto 12px; padding:14px; background:linear-gradient(135deg,var(--primary),var(--primary-dark)); color:white; border-radius:18px; box-shadow:var(--shadow); position:relative; z-index:2; }
.fp-agency-wrapper .dashboard-welcome { min-width:0; text-align:left; }
.fp-agency-wrapper .dashboard-welcome small { opacity:.9; }
.fp-agency-wrapper .dashboard-welcome div { font-size:1.35rem; font-weight:800; line-height:1.1; overflow:hidden; text-overflow:ellipsis; text-transform:uppercase; white-space:nowrap; }
.fp-agency-wrapper .profile-avatar { aspect-ratio:1 / 1; border-radius:50%; flex-shrink:0; object-fit:cover; object-position:center; background-color:var(--bg-card); }
.fp-agency-wrapper .profile-avatar-sm { width:50px; height:50px; border:2px solid rgba(255,255,255,.8); }
.fp-agency-wrapper .profile-avatar-lg { width:120px; height:120px; border:3px solid var(--orange); box-shadow:0 4px 15px rgba(255,107,43,0.2); }
.fp-agency-wrapper .card-float { background:white; margin:12px auto 15px; padding:18px; width:min(calc(100% - 24px), 920px); border-radius:var(--radius); box-shadow:var(--shadow); position:relative; z-index:1; }
.fp-agency-wrapper .balance-card { text-align:center; }
.fp-agency-wrapper .finance-balance-card { text-align:center; background:linear-gradient(135deg,var(--primary),var(--primary-dark)); color:white; padding:30px 20px; }
.fp-agency-wrapper .plain-card { background:transparent; box-shadow:none; padding:0; }
.fp-agency-wrapper .editors-panel { background:transparent; box-shadow:none; padding:12px 10px; }
.fp-agency-wrapper .links-panel { padding-bottom:20px; }
.fp-agency-wrapper .card { background:white; margin:15px 12px; padding:18px; border-radius:16px; box-shadow:0 2px 8px -2px rgba(0,0,0,.04); }
.fp-agency-wrapper .guardian-consent { display:none; background:#fffbeb; padding:15px; border-radius:12px; border:1px solid #fde68a; margin-bottom:15px; text-align:left; }
.fp-agency-wrapper .guardian-consent.is-visible { display:block; }
.fp-agency-wrapper .auth-forgot { text-align:right; margin:0 0 16px; font-size:.75rem; }

/* Botões baseados */
.fp-agency-wrapper .btn { width:100%; padding:15px; background:var(--primary); color:white; border:none; border-radius:10px; font-weight:700; font-size:1rem; cursor:pointer; transition:.2s; }
.fp-agency-wrapper .btn:active { transform:scale(.98); background:var(--primary-dark); }
.fp-agency-wrapper .btn.danger { background:#ef4444; }
.fp-agency-wrapper .btn.secondary { background:#e2e8f0; color:var(--text); }
.fp-agency-wrapper .btn.auth-google-btn { background:white; color:#333; border:1px solid #e2e8f0; display:flex; align-items:center; justify-content:center; gap:10px; margin-bottom:20px; font-weight:500; }
.fp-agency-wrapper .btn.btn-outline-primary { background:transparent; border:2px solid var(--primary); color:var(--primary); }
.fp-agency-wrapper .btn.btn-outline-muted { background:transparent; border:1px solid #e2e8f0; color:#64748b; font-size:.85rem; }
.fp-agency-wrapper .password-wrapper { position:relative; width:100%; }
.fp-agency-wrapper .password-wrapper input { padding-right:40px; margin-bottom:15px; }
.fp-agency-wrapper .toggle-password { position:absolute; right:15px; top:40%; transform:translateY(-50%); cursor:pointer; color:#94a3b8; font-size:1.1rem; transition:.2s; }
.fp-agency-wrapper .toggle-password:hover { color:var(--primary); }

/* Menu Base */
.fp-agency-wrapper .bottom-nav { position: fixed; bottom: 0; left: 0; width: 100%; background: rgba(255, 255, 255, 0.95); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px); box-shadow: 0 -4px 20px rgba(0,0,0,0.06); display: none; align-items: center; overflow-x: auto; scroll-snap-type: x mandatory; -webkit-overflow-scrolling: touch; -ms-overflow-style: none; scrollbar-width: none; z-index: 5000; height: 75px; padding: 0 5px; border-top: 1px solid rgba(249,115,22,0.1); padding-bottom: env(safe-area-inset-bottom); }
.fp-agency-wrapper[data-portal-state="private"] .bottom-nav { display:flex; }
.fp-agency-wrapper[data-portal-state="public"] .bottom-nav { display:flex; background:rgba(15,17,23,0.95); border-top:1px solid rgba(255,255,255,0.05); } /* Menu no modo dark publico */
.fp-agency-wrapper .bottom-nav::-webkit-scrollbar { display: none; }

.fp-agency-wrapper .nav-item { scroll-snap-align: start; flex: 0 0 72px; height: 100%; display: flex; flex-direction: column; align-items: center; justify-content: center; color: #64748b; text-decoration: none; font-size: 0.65rem; font-weight: 600; gap: 5px; cursor: pointer; transition: all 0.2s; -webkit-tap-highlight-color: transparent; }
.fp-agency-wrapper[data-portal-state="public"] .nav-item { color:#94a3b8; }
.fp-agency-wrapper .nav-item i { font-size: 1.25rem; width: 42px; height: 32px; display: flex; align-items: center; justify-content: center; border-radius: 10px; transition: all 0.2s; }
.fp-agency-wrapper .nav-item:hover { color: var(--primary); }
.fp-agency-wrapper .nav-item.active { color: var(--primary); font-weight: 700; }
.fp-agency-wrapper .nav-item.active i { background: #fff7ed; color: var(--primary); transform: translateY(-2px); }
.fp-agency-wrapper[data-portal-state="public"] .nav-item.active i { background:rgba(255,107,43,0.15); }
.fp-agency-wrapper .nav-item.logout { color: #ef4444; }

