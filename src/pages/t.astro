---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { Image } from 'astro:assets';

const defaultProfileAvatar = 'https://ui-avatars.com/api/?name=Usuario&background=fed7aa&color=c2410c&bold=true&size=256';
---

<Layout>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&family=Sora:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/remixicon@3.5.0/fonts/remixicon.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

  <script is:inline src="https://www.gstatic.com/firebasejs/8.10.1/firebase-app.js"></script>
  <script is:inline src="https://www.gstatic.com/firebasejs/8.10.1/firebase-auth.js"></script>
  <script is:inline src="https://www.gstatic.com/firebasejs/8.10.1/firebase-storage.js"></script>

  <style is:inline>
    /* Garante que as imagens de perfil no Dashboard e Configurações fiquem sempre perfeitamente redondas */
    #uFoto, #ui_foto {
      object-fit: cover !important;
      object-position: center !important;
      aspect-ratio: 1 / 1 !important;
    }

    /* Garante que a imagem injetada no Ranking ocupe 100% da div protetora sem gerar bordas duplas */
    .rank-list img, .top10-avatar img {
      object-fit: cover !important;
      object-position: center !important;
      aspect-ratio: 1 / 1 !important;
      width: 100% !important;
      height: 100% !important;
      border-radius: 50% !important;
      border: none !important;
    }
  </style>

  <div id="global-loader"><div class="spinner"></div></div>

  <div id="unified-exit-layer" role="dialog" aria-modal="true">
    <div class="uel-icon"><i class="ri-external-link-line"></i></div>
    <div class="uel-title">Abrir no Navegador</div>
    <p class="uel-sub">Este link precisa ser aberto no <strong>navegador do seu celular</strong> para funcionar corretamente.</p>
    <div class="uel-url" id="uel-url-display"></div>
    <button class="uel-btn-open" onclick="uelForceExternal()"><i class="ri-compass-3-line"></i> Abrir no Navegador</button>
    <button class="uel-btn-copy" id="uel-copy-btn" onclick="uelCopyUrl()"><i class="ri-clipboard-line"></i> Copiar Link</button>
    <button class="uel-btn-back" onclick="uelClose()">← Voltar</button>
  </div>

  <div class="custom-modal-overlay" id="global_alertModal">
    <div class="custom-modal-card">
      <div class="modal-icon-wrapper info" id="global_alertIcon"><i class="fas fa-info-circle"></i></div>
      <h3 class="custom-modal-title" id="global_alertTitle">Atenção</h3>
      <p class="custom-modal-text" id="global_alertMessage">Mensagem</p>
      <button class="btn-confirm" onclick="closeGlobalAlert()">OK, Entendi</button>
    </div>
  </div>
  
  <div class="custom-modal-overlay" id="global_confirmModal">
    <div class="custom-modal-card">
      <div class="modal-icon-wrapper warning"><i class="fas fa-question-circle"></i></div>
      <h3 class="custom-modal-title" id="global_confirmTitle">Confirmação</h3>
      <p class="custom-modal-text" id="global_confirmMessage">Deseja continuar?</p>
      <div class="modal-btn-group">
        <button class="btn-cancel" onclick="closeGlobalConfirm()">Cancelar</button>
        <button class="btn-confirm" id="global_btnConfirmAction">Sim</button>
      </div>
    </div>
  </div>

  <div class="custom-modal-overlay" id="global_mediaModal">
    <div class="custom-modal-card">
      <div class="modal-icon-wrapper info"><i class="fas fa-camera"></i></div>
      <h3 class="custom-modal-title">Selecionar Imagem</h3>
      <p class="custom-modal-text">De onde você quer enviar a foto?</p>
      <div class="modal-btn-group modal-stack">
        <button class="btn-confirm" onclick="selectMedia('camera')"><i class="fas fa-camera"></i> Tirar Foto</button>
        <button class="btn-confirm media-gallery-btn" onclick="selectMedia('gallery')"><i class="fas fa-images"></i> Da Galeria</button>
        <button class="btn-cancel" onclick="closeMediaModal()">Cancelar</button>
      </div>
    </div>
  </div>

  <div class="custom-modal-overlay" id="patrocinadorModal">
    <div class="custom-modal-card">
      <div class="modal-icon-wrapper info"><i class="fas fa-external-link-alt"></i></div>
      <h3 class="custom-modal-title">Ação Necessária</h3>
      <p class="custom-modal-text">Para liberar o seu saque, visite o site do patrocinador.<br><br><b>Aguarde o tempo necessário na página!</b></p>
      <button id="btnPatrocinador" class="btn-confirm" onclick="abrirPatrocinador()">Visitar Patrocinador</button>
    </div>
  </div>

  <div class="custom-modal-overlay" id="modalPostFeed">
    <div class="custom-modal-card">
      <div class="modal-icon-wrapper" style="background:#fff7ed;color:#ea580c"><i class="fas fa-share-square"></i></div>
      <h3 class="custom-modal-title">Nova Publicação</h3>
      <p class="custom-modal-text" style="margin-bottom:15px">Compartilhe seu vídeo ou live do Kwai com a comunidade.</p>
      <form id="formPostFeed" onsubmit="event.preventDefault(); enviarPost();" style="text-align:left">
        <label>URL do Kwai</label>
        <input type="url" id="postUrl" placeholder="Cole o link do vídeo ou live" required>
        
        <label>Categoria</label>
        <select id="postCategoria" required>
          <option value="Notícias">📰 Notícias / FTV</option>
          <option value="Games">🎮 Games</option>
          <option value="Humor">😂 Humor</option>
          <option value="Daily">📱 Daily / Vlog</option>
          <option value="Live">🔴 Live (Ao Vivo)</option>
        </select>
        
        <div class="modal-btn-group modal-stack" style="margin-top:10px">
          <button type="submit" class="btn-confirm" id="btnSubmitPost">Publicar</button>
          <button type="button" class="btn-cancel" onclick="fecharModalPost()">Cancelar</button>
        </div>
      </form>
    </div>
  </div>

  <div class="fp-agency-wrapper" id="main-app-container" data-portal-state="public" data-auth-state="checking" data-active-view="Landing">
    <div class="app-shell-header" id="portalHeaderWrapper">
      <Header />
    </div>

    <main class="app-shell-content" id="views-container" aria-live="polite">

    <div id="view-Landing" class="view view-container view-public active" data-view="Landing" data-public="true">
      <div class="rc">
        <div class="rc-hero">
          <div class="rc-hero-inner">
            <div class="rc-badge"><span class="rc-badge-dot"></span>Programa de Parceiros 2026</div>
            <h1 class="rc-hero-title">Transforme sua audiência<br>em <span>oportunidades</span></h1>
            <p class="rc-hero-sub">Participe do programa oficial de recrutadores e receba comissões conforme o desempenho dos usuários que você indicar. Ou explore a comunidade da FP Agency.</p>

            <div class="rc-hero-actions">
              <button class="rc-btn-primary" onclick="nav('Login')"><i class="ri-user-add-line"></i> Entrar / Cadastro</button>
              <button class="rc-btn-secondary" onclick="nav('Comunidade')"><i class="ri-live-line"></i> Ver Comunidade</button>
            </div>

            <div class="rc-partners">
              <span>Parceiros Oficiais:</span>
              <span><i class="fas fa-video"></i> Kwai Cut</span>
              <span><i class="fas fa-microphone"></i> Narrastars</span>
            </div>
          </div>
        </div>

        <div class="rc-section">
          <div class="rc-section-label"><span class="rc-section-label-text">Quem pode participar?</span><div class="rc-section-label-line"></div></div>
          <div class="rc-who-grid">
             <div class="rc-who-card">
                <i class="ri-vidicon-line"></i>
                <h4>Criadores</h4>
                <p>Produtores de conteúdo de qualquer nicho na internet.</p>
             </div>
             <div class="rc-who-card">
                <i class="ri-links-line"></i>
                <h4>Afiliados</h4>
                <p>Especialistas em tráfego pago e alta conversão.</p>
             </div>
             <div class="rc-who-card">
                <i class="ri-group-line"></i>
                <h4>Gestores</h4>
                <p>Líderes de comunidades, WhatsApp e grupos VIP.</p>
             </div>
             <div class="rc-who-card">
                <i class="ri-megaphone-line"></i>
                <h4>Influenciadores</h4>
                <p>Pessoas com grande poder de influência e indicação.</p>
             </div>
          </div>
        </div>

        <div id="simulador" class="rc-section">
          <div class="rc-section-label"><span class="rc-section-label-text">Potencial de Ganhos</span><div class="rc-section-label-line"></div></div>
          <p class="rc-table-intro">Veja uma estimativa de ganhos mensais baseada em atividade média (RPM):</p>
          <div class="rc-table-wrap">
            <table class="rc-earnings-table">
              <thead>
                <tr>
                  <th>Usuários Ativos</th>
                  <th>RPM Médio Estimado</th>
                  <th>Ganho Estimado</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td>50</td>
                  <td>R$ 10,00</td>
                  <td class="rc-money">R$ 500,00</td>
                </tr>
                <tr>
                  <td>100</td>
                  <td>R$ 10,00</td>
                  <td class="rc-money">R$ 1.000,00</td>
                </tr>
                <tr>
                  <td>300</td>
                  <td>R$ 10,00</td>
                  <td class="rc-money">R$ 3.000,00</td>
                </tr>
              </tbody>
            </table>
          </div>
          <p class="rc-table-note">* Valores puramente estimativos. Os ganhos variam de acordo com o desempenho real nas plataformas.</p>
        </div>

        <div class="rc-section rc-section-last">
          <div class="rc-cta">
            <div class="rc-cta-title">Pronto para escalar seus resultados?</div>
            <p class="rc-cta-sub">Junte-se ao time de recrutadores de alta performance e transforme indicações em negócio.</p>
            <div class="rc-cta-btns">
              <button class="rc-btn-primary" onclick="nav('Login')"><i class="ri-user-add-line"></i> Iniciar Cadastro Agora</button>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div id="view-Comunidade" class="view view-container view-public" data-view="Comunidade" data-public="true">
      <div class="feed-view">
        <div class="feed-header">
          <div class="feed-header-inner">
            <h1 class="feed-title">Comunidade <span>FP</span></h1>
            <p class="feed-subtitle">Inspire-se, compartilhe seus vídeos e acompanhe as lives dos parceiros da agência.</p>
            <button class="btn-publicar" onclick="abrirModalPost()"><i class="fas fa-plus"></i> Publicar Vídeo</button>
          </div>
        </div>

        <div class="feed-top10-wrapper">
          <div class="feed-section-title"><i class="fas fa-fire" style="color:#ef4444"></i> Em Alta (Top 10)</div>
          <div class="top10-scroll" id="feedTop10List">
            <div style="padding:20px;color:#94a3b8;font-size:0.85rem;"><i class="fas fa-circle-notch fa-spin"></i> Carregando Top 10...</div>
          </div>
        </div>

        <div class="feed-filters-wrapper">
          <div class="feed-filters" id="feedFilterButtons">
            <button class="feed-filter active" onclick="filtrarFeed('Todos', this)">Tudo</button>
            <button class="feed-filter" onclick="filtrarFeed('Live', this)">🔴 Lives</button>
            <button class="feed-filter" onclick="filtrarFeed('Notícias', this)">Notícias</button>
            <button class="feed-filter" onclick="filtrarFeed('Games', this)">Games</button>
            <button class="feed-filter" onclick="filtrarFeed('Humor', this)">Humor</button>
            <button class="feed-filter" onclick="filtrarFeed('Daily', this)">Daily</button>
          </div>
        </div>

        <div class="feed-grid" id="feedGrid">
          <div style="text-align:center;padding:50px;color:#94a3b8;grid-column:1/-1;">
            <i class="fas fa-circle-notch fa-spin fa-2x"></i>
            <p style="margin-top:10px">Carregando comunidade...</p>
          </div>
        </div>
      </div>
    </div>

    <div id="view-Diretrizes" class="view view-container view-public" data-view="Diretrizes" data-public="true">
      <div class="dg">
        <div class="dg-banner">
          <div class="dg-banner-inner">
            <div class="dg-vigencia"><span class="dg-vigencia-dot"></span>Vigência: 01/01/2026 a 30/12/2026</div>
            <h1 class="dg-banner-title">Diretrizes &amp;<br><span>Gamificação</span></h1>
            <p class="dg-banner-sub">Este é o seu primeiro passo para abrir sua própria agência. Desempenho gera recompensa — maximize seus ganhos.</p>
          </div>
        </div>

        <button class="dg-back" onclick="navBack()"><i class="ri-arrow-left-line"></i> Voltar</button>

        <div class="dg-section" style="margin-top:28px">
          <div class="dg-section-label"><span class="dg-section-label-text">Seu Progresso Atual</span><div class="dg-section-label-line"></div></div>
          <div style="background:var(--bg-card); padding:25px; border-radius:15px; border:1px solid var(--border); position:relative; overflow:hidden;">
            <div style="display:flex; justify-content:space-between; align-items:flex-end;">
              <div>
                <p style="color:var(--text-muted); font-size:0.85rem; margin-bottom:5px;">Rumo ao nível</p>
                <h3 style="color:#fff; font-size:1.4rem; margin:0;">Prata <i class="fas fa-medal" style="color:#c0c0c0;"></i></h3>
              </div>
              <div style="text-align:right;">
                <span style="color:var(--orange); font-weight:bold; font-size:1.2rem;">60%</span>
              </div>
            </div>

            <div style="width:100%; height:12px; background:rgba(255,255,255,0.05); border-radius:6px; margin:15px 0; overflow:hidden; border:1px solid var(--border);">
              <div style="width:60%; height:100%; background:linear-gradient(90deg, var(--orange), #ff9a5c); border-radius:6px; box-shadow: 0 0 10px rgba(255,107,43,0.5);"></div>
            </div>
            <p style="color:var(--text-muted); font-size:0.9rem;">Faltam apenas <strong>mais 5 aprovações</strong> para desbloquear prêmios mensais e comissões aceleradas!</p>
          </div>
        </div>

        <div class="dg-section">
          <div class="dg-section-label"><span class="dg-section-label-text">Sistema de Classificação</span><div class="dg-section-label-line"></div></div>
          <div class="dg-levels">
            <div class="dg-level gold">
              <div class="dg-bonus-row"><i class="ri-trending-up-line"></i>Multiplicador de ganhos:<span>× 1,35 de bônus</span></div>
              <div class="dg-level-head"><span class="dg-level-badge gold">🥇 Nível Ouro — Elite</span><span class="dg-level-range">30+ pessoas</span></div>
              <div class="dg-level-body">
                <div class="dg-perk"><div class="dg-perk-icon"><i class="ri-building-4-line"></i></div><div><div class="dg-perk-title">Sub Agência</div><div class="dg-perk-desc">Gerencie sua própria equipe de recrutadores</div></div></div>
                <div class="dg-perk"><div class="dg-perk-icon"><i class="ri-vip-crown-line"></i></div><div><div class="dg-perk-title">Suporte VIP</div><div class="dg-perk-desc">Atendimento prioritário dedicado</div></div></div>
              </div>
            </div>
            <div class="dg-level silver">
              <div class="dg-bonus-row"><i class="ri-trending-up-line"></i>Multiplicador de ganhos:<span>× 1,14 de bônus</span></div>
              <div class="dg-level-head"><span class="dg-level-badge silver">🥈 Nível Prata — Avançado</span><span class="dg-level-range">11 a 30 pessoas</span></div>
              <div class="dg-level-body">
                <div class="dg-perk"><div class="dg-perk-icon"><i class="ri-rocket-line"></i></div><div><div class="dg-perk-title">Mentorias Estratégicas</div><div class="dg-perk-desc">Sessões de crescimento e escala</div></div></div>
                <div class="dg-perk"><div class="dg-perk-icon"><i class="ri-bar-chart-box-line"></i></div><div><div class="dg-perk-title">Relatórios Detalhados</div><div class="dg-perk-desc">Dashboard completo de desempenho</div></div></div>
              </div>
            </div>
            <div class="dg-level bronze">
              <div class="dg-bonus-row"><i class="ri-trending-up-line"></i>Multiplicador de ganhos:<span>× 1,05 de bônus</span></div>
              <div class="dg-level-head"><span class="dg-level-badge bronze">🥉 Nível Bronze — Iniciante</span><span class="dg-level-range">1 a 9 pessoas</span></div>
              <div class="dg-level-body">
                <div class="dg-perk"><div class="dg-perk-icon"><i class="ri-tools-line"></i></div><div><div class="dg-perk-title">Ferramentas</div><div class="dg-perk-desc">Acesso a Kwai Cut e Narrastars</div></div></div>
                <div class="dg-perk"><div class="dg-perk-icon"><i class="ri-user-add-line"></i></div><div><div class="dg-perk-title">Link de Indicação</div><div class="dg-perk-desc">Link exclusivo para rastrear indicações</div></div></div>
              </div>
            </div>
          </div>
        </div>

        <div class="dg-section" style="margin-bottom:0">
          <div class="dg-cta">
            <div class="dg-cta-title">Pronto para atingir o nível Ouro?</div>
            <button class="dg-cta-btn" onclick="navBack()"><i class="ri-arrow-left-line"></i> Voltar para Início</button>
          </div>
        </div>
      </div>
    </div>

    <div id="view-Login" class="view view-container view-public view-auth" data-view="Login" data-public="true">
      <div class="auth-wrapper">
        <div class="auth-card">
          <h1 class="auth-title">Portal Parceiro</h1>
          <p class="auth-subtitle auth-subtitle-accent">Faça login para continuar</p>
          <button type="button" class="btn auth-google-btn" onclick="loginComGoogle()">
            <Image src="https://www.gstatic.com/firebasejs/ui/2.0.0/images/auth/google.svg" class="auth-google-icon" width={20} height={20} alt="Google" loading="lazy" decoding="async" /> Continuar com o Google
          </button>
          <div class="auth-separator"><div></div><span>ou use seu acesso</span><div></div></div>
          
          <form id="loginForm" onsubmit="event.preventDefault()">
            <input type="email" name="email" placeholder="E-mail cadastrado" required>
            
            <div class="password-wrapper"><input type="password" id="senha" name="senha" placeholder="Sua senha" required><i class="fas fa-eye toggle-password" onclick="togglePassword('senha',this)"></i></div>
            <div class="auth-forgot"><a onclick="nav('Redefinir')" style="color:var(--primary);font-weight:600;cursor:pointer">Esqueceu a senha?</a></div>
            <button type="submit" class="btn" id="btnLogin">ENTRAR</button>
            
            <div class="auth-separator"><div></div><span>ou</span><div></div></div>
            <button type="button" class="btn btn-outline-primary" onclick="nav('Cadastro')">CRIAR NOVA CONTA</button>
            <div class="auth-back-action"><button type="button" class="btn btn-outline-muted" onclick="nav('Landing')">← Voltar para o Início</button></div>
          </form>
        </div>
      </div>
    </div>

    <div id="view-Cadastro" class="view view-container view-public view-auth" data-view="Cadastro" data-public="true">
      <div class="auth-wrapper">
        <div class="auth-card">
          <h1 class="auth-title">Cadastro</h1>
          <p class="auth-subtitle">Crie sua conta para começar</p>
          <button type="button" class="btn auth-google-btn" id="btnGoogleCad" onclick="preencherComGoogle()">
            <Image src="https://www.gstatic.com/firebasejs/ui/2.0.0/images/auth/google.svg" class="auth-google-icon" width={20} height={20} alt="Google" loading="lazy" decoding="async" /> Preencher dados com o Google
          </button>
          <div id="div-ou-cad" class="auth-separator"><div></div><span>ou digite manualmente</span><div></div></div>
          
          <form id="formCadastro" onsubmit="event.preventDefault()">
            <input type="text"  name="nome"     id="cad-nome"     placeholder="Nome Completo" required>
            <input type="email" name="email"    id="cad-email"    placeholder="Seu Email" required>
            <input type="tel"   name="cpf"      id="cad-cpf"      placeholder="CPF (Apenas números)" required maxlength="14" oninput="maskCPF(this)">
            <input type="tel"   name="whatsapp" id="cad-whatsapp" placeholder="WhatsApp" required oninput="maskPhone(this)">
            <label for="cad-dataNasc" style="text-align:left">Data de Nascimento</label>
            <input type="date" name="dataNasc" id="cad-dataNasc" required onchange="verificarIdade(this)" style="color:#334155;padding:15px;background:#f8fafc;border:1px solid #e2e8f0;border-radius:10px;width:100%;margin-bottom:15px;font-family:inherit">
            
            <div id="blocoResponsavel" class="guardian-consent">
              <div style="font-size:.75rem;color:#b45309;margin-bottom:10px;line-height:1.4"><b>Declaração de Responsabilidade Legal:</b> Por possuir entre 14 e 15 anos, você declara autorização expressa do responsável legal.</div>
              <input type="text" name="nomeResp" id="nomeResp" placeholder="Nome Completo do Responsável" style="margin-bottom:10px">
              <input type="tel"  name="cpfResp"  id="cpfResp"  placeholder="CPF do Responsável" maxlength="14" oninput="maskCPF(this)" style="margin-bottom:0">
            </div>
            
            <input type="text" name="chavePix" placeholder="Chave PIX (Opcional)">
            <div class="password-wrapper"><input type="password" id="senhaCad" name="senha" placeholder="Senha" required minlength="6"><i class="fas fa-eye toggle-password" onclick="togglePassword('senhaCad',this)"></i></div>
            
            <div style="text-align:left;margin:10px 0 20px;font-size:.75rem;color:var(--gray)">
              <label for="chkTermos" style="display:flex;align-items:flex-start;gap:8px;margin-bottom:12px;cursor:pointer"><input type="checkbox" name="termos" id="chkTermos" required style="width:auto;margin-top:2px"><span style="line-height:1.4">Concordo com a <a onclick="openLink(null,'https://www.fpagency.com.br/politica-de-privacidade')" style="color:var(--primary);cursor:pointer">Política de Privacidade</a>, <a onclick="openLink(null,'https://www.fpagency.com.br/termos-de-servico')" style="color:var(--primary);cursor:pointer">Termos de Uso</a>.</span></label>
              <label for="chkIdade" style="display:flex;align-items:flex-start;gap:8px;cursor:pointer"><input type="checkbox" name="idade" id="chkIdade" required style="width:auto;margin-top:2px"><span id="txtConfirmIdade" style="line-height:1.4">Confirmo que tenho mais de 14 anos de idade.</span></label>
            </div>
            <button type="submit" class="btn" id="btnReg">CRIAR CONTA</button>
          </form>
          
          <div class="link" style="margin-top:25px;padding-top:20px;border-top:1px solid #e2e8f0">
            <p style="margin:0 0 10px;font-size:.9rem;color:var(--gray);font-weight:500">Já tem conta?</p>
            <button type="button" class="btn" onclick="nav('Login')">FAZER LOGIN</button>
          </div>
        </div>
      </div>
    </div>

