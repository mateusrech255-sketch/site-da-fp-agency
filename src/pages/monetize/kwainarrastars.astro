---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<Layout>
  <link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/remixicon@3.5.0/fonts/remixicon.css" rel="stylesheet">

  <div class="fp-agency-wrapper">
    <Header />

    <main class="ns">
      <div class="ns-hero">
        <div class="ns-hero-inner">

          <div class="ns-badge">
            <i class="ri-star-fill ns-badge-star"></i>
            Programa Ativo · Vagas Abertas
          </div>

          <p class="ns-hero-kicker">FP Agency × Kwai</p>
          <h1 class="ns-hero-title">
            Programa<br>
            <span class="kwai">Kwai</span> <span class="narra">Narrastars</span>
          </h1>

          <div class="ns-exclusive-pill">
            <i class="ri-coins-line"></i>
            Exclusivo: Ganhe com Tarefas Pagas além do RPM
          </div>

          <p class="ns-hero-sub">
            Narre vídeos, cresça seu canal e seja remunerado por visualizações <em>e</em> por tarefas especiais.
            Suporte completo, treinamento e comunidade da FP Agency.
          </p>

          <div class="ns-hero-actions">
            <a href={`${import.meta.env.BASE_URL}/kwai-narrastars/inscricao`} class="ns-btn-primary">
              <i class="ri-quill-pen-line"></i> Quero me Inscrever
            </a>
            <a href={`${import.meta.env.BASE_URL}/kwai-narrastars/treinamento`} class="ns-btn-secondary">
              <i class="ri-play-circle-line"></i> Ver Treinamento
            </a>
          </div>

        </div>
      </div>

      <div class="ns-stats">
        <div class="ns-stat">
          <div class="ns-stat-icon"><i class="ri-mic-line"></i></div>
          <div>
            <div class="ns-stat-val">Narração</div>
            <div class="ns-stat-lbl">Estilo FTV & Notícias</div>
          </div>
        </div>
        <div class="ns-stat">
          <div class="ns-stat-icon"><i class="ri-money-dollar-circle-line"></i></div>
          <div>
            <div class="ns-stat-val">RPM + Tarefas</div>
            <div class="ns-stat-lbl">2 Fontes de Renda</div>
          </div>
        </div>
        <div class="ns-stat">
          <div class="ns-stat-icon"><i class="ri-global-line"></i></div>
          <div>
            <div class="ns-stat-val">Em Dólar</div>
            <div class="ns-stat-lbl">Pagamentos</div>
          </div>
        </div>
        <div class="ns-stat">
          <div class="ns-stat-icon"><i class="ri-shield-star-line"></i></div>
          <div>
            <div class="ns-stat-val">100%</div>
            <div class="ns-stat-lbl">Suporte FP Agency</div>
          </div>
        </div>
      </div>

      <div class="ns-marquee-wrap" aria-hidden="true">
        <div class="ns-marquee-band">
          <div class="ns-marquee-track">
            <div class="ns-marquee-group">
              <span class="ns-chip"><i class="ri-mic-line"></i> Narração de Vídeos</span>
              <span class="ns-chip"><i class="ri-money-dollar-circle-line"></i> Monetização RPM</span>
              <span class="ns-chip"><i class="ri-coins-line"></i> Tarefas Pagas</span>
              <span class="ns-chip"><i class="ri-motion-line"></i> NARRA Motions</span>
              <span class="ns-chip"><i class="ri-graduation-cap-line"></i> Treinamento Completo</span>
              <span class="ns-chip"><i class="ri-team-line"></i> Comunidade Ativa</span>
              <span class="ns-chip"><i class="ri-global-line"></i> Pagamento em Dólar</span>
              <span class="ns-chip"><i class="ri-star-line"></i> Estilo FTV & Notícias</span>
            </div>
            <div class="ns-marquee-group" aria-hidden="true">
              <span class="ns-chip"><i class="ri-mic-line"></i> Narração de Vídeos</span>
              <span class="ns-chip"><i class="ri-money-dollar-circle-line"></i> Monetização RPM</span>
              <span class="ns-chip"><i class="ri-coins-line"></i> Tarefas Pagas</span>
              <span class="ns-chip"><i class="ri-motion-line"></i> NARRA Motions</span>
              <span class="ns-chip"><i class="ri-graduation-cap-line"></i> Treinamento Completo</span>
              <span class="ns-chip"><i class="ri-team-line"></i> Comunidade Ativa</span>
              <span class="ns-chip"><i class="ri-global-line"></i> Pagamento em Dólar</span>
              <span class="ns-chip"><i class="ri-star-line"></i> Estilo FTV & Notícias</span>
            </div>
          </div>
        </div>
      </div>

      <div class="ns-section">
        <div class="ns-section-label">
          <span class="ns-section-label-text">Exclusivo Narrastars</span>
          <div class="ns-section-label-line"></div>
        </div>

        <a href={`${import.meta.env.BASE_URL}/kwai-narrastars/tarefas-pagas`} class="ns-tasks-card">
          <div class="ns-tasks-icon"><i class="ri-coins-line"></i></div>
          <div class="ns-tasks-body">
            <div class="ns-tasks-tag"><i class="ri-star-fill" style="font-size:.6rem"></i> Diferencial exclusivo</div>
            <div class="ns-tasks-title">Tarefas Pagas</div>
            <div class="ns-tasks-desc">
              Além do RPM por visualizações, Narrastars têm acesso a tarefas especiais remuneradas.
              Complete desafios, ganhe bônus e aumente seus rendimentos mensais além do canal.
            </div>
          </div>
          <span class="ns-tasks-cta">
            <i class="ri-arrow-right-line"></i> Saiba Mais
          </span>
        </a>
      </div>

      <div class="ns-section">
        <div class="ns-section-label">
          <span class="ns-section-label-text">Navegue pelo programa</span>
          <div class="ns-section-label-line"></div>
        </div>

        <div class="ns-nav-grid">
          <a href={`${import.meta.env.BASE_URL}/kwai-narrastars/treinamento`} class="ns-nav-card c-purple">
            <div class="ns-nav-icon"><i class="ri-graduation-cap-line"></i></div>
            <div class="ns-nav-tag">Passo a passo</div>
            <h3 class="ns-nav-title">Treinamento Narrastars</h3>
            <p class="ns-nav-desc">Aprenda técnicas de narração, ritmo, entonação e edição para criar vídeos que retêm audiência e geram views.</p>
            <div class="ns-nav-arrow"><i class="ri-arrow-right-line"></i> Acessar Treinamento</div>
          </a>

          <a href={`${import.meta.env.BASE_URL}/kwai-narrastars/monetizacao`} class="ns-nav-card c-green">
            <div class="ns-nav-icon"><i class="ri-money-dollar-circle-line"></i></div>
            <div class="ns-nav-tag">Como ganhar</div>
            <h3 class="ns-nav-title">Monetização & RPM</h3>
            <p class="ns-nav-desc">Entenda o sistema de RPM, as metas de views e como maximizar seus ganhos mensais com o canal Narrastars.</p>
            <div class="ns-nav-arrow"><i class="ri-arrow-right-line"></i> Ver Monetização</div>
          </a>

          <a href={`${import.meta.env.BASE_URL}/kwai-narrastars/cut-motions`} class="ns-nav-card c-blue">
            <div class="ns-nav-icon"><i class="ri-magic-line"></i></div>
            <div class="ns-nav-tag">Recursos visuais</div>
            <h3 class="ns-nav-title">NARRA Motions</h3>
            <p class="ns-nav-desc">Acesse o pacote de motions, templates e efeitos no padrão Narrastars para deixar seus vídeos profissionais.</p>
            <div class="ns-nav-arrow"><i class="ri-arrow-right-line"></i> Ver NARRA Motions</div>
          </a>

          <a href={`${import.meta.env.BASE_URL}/kwai-narrastars/inscricao`} class="ns-nav-card c-orange">
            <div class="ns-nav-icon"><i class="ri-quill-pen-line"></i></div>
            <div class="ns-nav-tag">Faça parte</div>
            <h3 class="ns-nav-title">Inscrição</h3>
            <p class="ns-nav-desc">Preencha o formulário de inscrição e aguarde a avaliação. Vagas abertas por categoria de conteúdo.</p>
            <div class="ns-nav-arrow"><i class="ri-arrow-right-line"></i> Inscrever-se</div>
          </a>

          <a href={`${import.meta.env.BASE_URL}/kwai-narrastars/regras`} class="ns-nav-card c-red">
            <div class="ns-nav-icon"><i class="ri-file-list-3-line"></i></div>
            <div class="ns-nav-tag">Leia antes</div>
            <h3 class="ns-nav-title">Regras do Programa</h3>
            <p class="ns-nav-desc">Conheça as diretrizes, critérios de qualidade de narração e os requisitos para se manter no programa.</p>
            <div class="ns-nav-arrow"><i class="ri-arrow-right-line"></i> Ler Regras</div>
          </a>

          <a href={`${import.meta.env.BASE_URL}/busca`} class="ns-nav-card c-purple">
            <div class="ns-nav-icon"><i class="ri-search-eye-line"></i></div>
            <div class="ns-nav-tag">Já é membro</div>
            <h3 class="ns-nav-title">Consultar Status</h3>
            <p class="ns-nav-desc">Verifique seu status de aprovação, relatórios mensais e histórico de tarefas pagas concluídas.</p>
            <div class="ns-nav-arrow"><i class="ri-arrow-right-line"></i> Área do Criador</div>
          </a>
        </div>
      </div>

      <div class="ns-section">
        <div class="ns-section-label">
          <span class="ns-section-label-text">CUT vs Narrastars</span>
          <div class="ns-section-label-line"></div>
        </div>

        <div class="ns-compare">
          <div class="ns-compare-head">
            <div class="ns-compare-head-cell">Recurso</div>
            <div class="ns-compare-head-cell"><i class="ri-scissors-cut-line"></i> CUT</div>
            <div class="ns-compare-head-cell"><i class="ri-star-line"></i> Narrastars</div>
          </div>
          <div class="ns-compare-row">
            <div class="ns-compare-cell">Edição de Vídeos</div>
            <div class="ns-compare-cell"><i class="ri-check-line"></i></div>
            <div class="ns-compare-cell"><i class="ri-check-line"></i></div>
          </div>
          <div class="ns-compare-row">
            <div class="ns-compare-cell">Narração própria</div>
            <div class="ns-compare-cell"><i class="ri-close-line"></i></div>
            <div class="ns-compare-cell"><i class="ri-check-line"></i></div>
          </div>
          <div class="ns-compare-row">
            <div class="ns-compare-cell">Monetização RPM</div>
            <div class="ns-compare-cell"><i class="ri-check-line"></i></div>
            <div class="ns-compare-cell"><i class="ri-check-line"></i></div>
          </div>
          <div class="ns-compare-row highlight">
            <div class="ns-compare-cell">Tarefas Pagas (bônus)</div>
            <div class="ns-compare-cell"><i class="ri-close-line"></i></div>
            <div class="ns-compare-cell"><i class="ri-check-line"></i></div>
          </div>
          <div class="ns-compare-row">
            <div class="ns-compare-cell">Motions & Templates</div>
            <div class="ns-compare-cell"><i class="ri-check-line"></i></div>
            <div class="ns-compare-cell"><i class="ri-check-line"></i></div>
          </div>
          <div class="ns-compare-row">
            <div class="ns-compare-cell">Pagamento em Dólar</div>
            <div class="ns-compare-cell"><i class="ri-check-line"></i></div>
            <div class="ns-compare-cell"><i class="ri-check-line"></i></div>
          </div>
        </div>
      </div>

      <div class="ns-section">
        <div class="ns-section-label">
          <span class="ns-section-label-text">Já faz parte do programa?</span>
          <div class="ns-section-label-line"></div>
        </div>

        <a href={`${import.meta.env.BASE_URL}/area-do-criador`} class="ns-featured-card">
          <div class="ns-featured-icon"><i class="ri-user-star-line"></i></div>
          <div class="ns-featured-body">
            <div class="ns-featured-tag"><i class="ri-circle-fill" style="font-size:.5rem;vertical-align:middle"></i> Acesso Exclusivo</div>
            <div class="ns-featured-title">Área do Criador</div>
            <div class="ns-featured-desc">Consulte relatórios mensais, status de aprovação, histórico de tarefas pagas e acompanhe sua evolução dentro do programa Narrastars.</div>
          </div>
          <span class="ns-featured-cta">
            <i class="ri-arrow-right-line"></i> Acessar Agora
          </span>
        </a>
      </div>
    </main>

    <Footer />
  </div>
</Layout>

<style>
  .ns {
    /* Variáveis locais do Narrastars herdam as globais do Layout */
    --bg-card:      var(--bg-2);
    --bg-input:     #1e2332;
    --border:       #2a3048;
    --border-h:     #4d3d7a;
    --text-faint:   #1e2332;
    --mono:         'JetBrains Mono', monospace;
    --r:            14px;
    --rl:           20px;
    --ns:           #a855f7;
    --ns2:          #c084fc;
    --ns3:          #7c3aed;
    --ns-dim:       #a855f718;
    --ns-glow:      rgba(168,85,247,.22);
    --gold:         #f59e0b;
    --gold-dim:     #f59e0b18;
    --green:        #22c55e;
    --green-dim:    #22c55e18;
    --blue:         #3b82f6;
    --blue-dim:     #3b82f618;
    --red:          #ef4444;
    --red-dim:      #ef444418;

    /* Base da página */
    font-family: 'Sora', sans-serif;
    background: transparent;
    color: var(--text);
    overflow-x: hidden;
    padding-bottom: 72px;
    position: relative;
  }

  .ns-hero { position: relative; padding: 56px 20px 52px; text-align: center; overflow: hidden; }
  .ns-hero::before { content: ''; position: absolute; top: -60px; left: 50%; transform: translateX(-50%); width: 720px; height: 400px; background: radial-gradient(ellipse, rgba(168,85,247,.15) 0%, transparent 65%); pointer-events: none; }
  .ns-hero::after { content: ''; position: absolute; inset: 0; background-image: linear-gradient(rgba(168,85,247,.05) 1px, transparent 1px), linear-gradient(90deg, rgba(168,85,247,.05) 1px, transparent 1px); background-size: 40px 40px; pointer-events: none; -webkit-mask-image: radial-gradient(ellipse 80% 60% at 50% 0%, black 30%, transparent 100%); mask-image: radial-gradient(ellipse 80% 60% at 50% 0%, black 30%, transparent 100%); }
  .ns-hero-inner { position: relative; z-index: 1; }

  .ns-badge { display: inline-flex; align-items: center; gap: 8px; font-family: var(--mono); font-size: .7rem; color: var(--ns); letter-spacing: .1em; text-transform: uppercase; background: var(--ns-dim); padding: 5px 15px; border-radius: 99px; border: 1px solid rgba(168,85,247,.3); margin-bottom: 22px; }
  .ns-badge-star { font-size: .85rem; color: var(--ns); animation: ns-spin 6s linear infinite; }
  @keyframes ns-spin { to { transform: rotate(360deg); } }

  .ns-hero-kicker { font-family: var(--mono); font-size: .78rem; color: var(--muted); letter-spacing: .12em; text-transform: uppercase; margin-bottom: 12px; }
  .ns-hero-title { font-size: clamp(2rem, 6vw, 3.4rem); font-weight: 900; line-height: 1.0; letter-spacing: -.035em; margin-bottom: 6px; }
  .ns-hero-title .kwai { background: linear-gradient(135deg, #a855f7, #c084fc); -webkit-background-clip: text; background-clip: text; color: transparent; }
  .ns-hero-title .narra { background: linear-gradient(135deg, #c084fc, #e879f9); -webkit-background-clip: text; background-clip: text; color: transparent; }

  .ns-hero-sub { font-size: 1rem; color: var(--muted); max-width: 500px; margin: 16px auto 32px; line-height: 1.65; }
  .ns-exclusive-pill { display: inline-flex; align-items: center; gap: 8px; background: linear-gradient(135deg, rgba(245,158,11,.12), rgba(245,158,11,.06)); border: 1px solid rgba(245,158,11,.35); color: var(--gold); padding: 8px 18px; border-radius: 99px; font-size: .8rem; font-weight: 600; margin-bottom: 28px; }
  .ns-exclusive-pill i { font-size: .95rem; }

  .ns-hero-actions { display: flex; flex-wrap: wrap; gap: 12px; justify-content: center; }
  .ns-btn-primary { display: inline-flex; align-items: center; gap: 9px; background: linear-gradient(135deg, var(--ns3), var(--ns)); color: #fff; font-family: 'Sora', sans-serif; font-weight: 700; font-size: .92rem; padding: 14px 28px; border-radius: 99px; text-decoration: none; box-shadow: 0 6px 24px var(--ns-glow); transition: transform .18s, box-shadow .18s; }
  .ns-btn-primary:hover { transform: translateY(-3px); box-shadow: 0 10px 32px var(--ns-glow); color: #fff; }
  .ns-btn-secondary { display: inline-flex; align-items: center; gap: 9px; background: var(--bg-card); color: var(--text); font-family: 'Sora', sans-serif; font-weight: 600; font-size: .92rem; padding: 14px 28px; border-radius: 99px; text-decoration: none; border: 1px solid var(--border); transition: border-color .18s, transform .18s; }
  .ns-btn-secondary:hover { border-color: var(--border-h); transform: translateY(-2px); color: var(--text); }

  .ns-stats { display: flex; flex-wrap: wrap; justify-content: center; gap: 10px; padding: 0 20px; margin: 0 auto 48px; max-width: 820px; position: relative; z-index: 1; }
  .ns-stat { display: flex; align-items: center; gap: 10px; background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--r); padding: 14px 20px; flex: 1 1 160px; transition: border-color .2s; }
  .ns-stat:hover { border-color: var(--border-h); }
  .ns-stat-icon { width: 38px; height: 38px; border-radius: 9px; background: var(--ns-dim); display: flex; align-items: center; justify-content: center; color: var(--ns); font-size: 1.15rem; flex-shrink: 0; }
  .ns-stat-val { font-size: 1.15rem; font-weight: 800; color: var(--text); line-height: 1; }
  .ns-stat-lbl { font-size: .72rem; color: var(--muted); font-family: var(--mono); margin-top: 3px; }

  .ns-marquee-wrap { overflow: hidden; border-top: 1px solid rgba(255,255,255,.06); border-bottom: 1px solid rgba(255,255,255,.06); margin-bottom: 52px; }
  .ns-marquee-band { padding: 16px 0; display: flex; overflow: hidden; -webkit-mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent); mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent); }
  .ns-marquee-track { display: flex; width: max-content; animation: ns-marquee 28s linear infinite; will-change: transform; }
  .ns-marquee-track:hover { animation-play-state: paused; }
  .ns-marquee-group { display: flex; gap: 10px; padding-right: 10px; }
  .ns-chip { min-height: 38px; padding: 0 18px; border-radius: 99px; display: inline-flex; align-items: center; gap: 7px; border: 1px solid rgba(255,255,255,.08); background: rgba(255,255,255,.03); color: var(--muted); font-size: .8rem; font-weight: 500; white-space: nowrap; backdrop-filter: blur(4px); }
  .ns-chip i { background: linear-gradient(135deg, var(--ns), var(--ns2)); -webkit-background-clip: text; background-clip: text; color: transparent; font-size: .95rem; }
  @keyframes ns-marquee { from { transform: translateX(0); } to { transform: translateX(-50%); } }

  .ns-section { padding: 0 20px; max-width: 960px; margin: 0 auto 52px; }
  .ns-section-label { display: flex; align-items: center; gap: 12px; margin-bottom: 24px; }
  .ns-section-label-text { font-family: var(--mono); font-size: .7rem; color: var(--muted); text-transform: uppercase; letter-spacing: .12em; white-space: nowrap; }
  .ns-section-label-line { flex: 1; height: 1px; background: var(--border); }

  .ns-tasks-card { background: linear-gradient(135deg, rgba(245,158,11,.1), rgba(245,158,11,.04)); border: 1px solid rgba(245,158,11,.3); border-radius: var(--rl); padding: 30px 28px; display: grid; grid-template-columns: auto 1fr auto; align-items: center; gap: 24px; text-decoration: none; position: relative; overflow: hidden; transition: transform .22s, box-shadow .22s, border-color .22s; margin-bottom: 14px; }
  .ns-tasks-card::before { content: ''; position: absolute; top: -50px; right: -50px; width: 180px; height: 180px; background: radial-gradient(circle, rgba(245,158,11,.1) 0%, transparent 70%); pointer-events: none; }
  .ns-tasks-card:hover { transform: translateY(-4px); border-color: rgba(245,158,11,.55); box-shadow: 0 20px 48px rgba(245,158,11,.12); color: var(--text); }
  .ns-tasks-icon { width: 56px; height: 56px; border-radius: 14px; background: linear-gradient(135deg, rgba(245,158,11,.25), rgba(245,158,11,.1)); border: 1px solid rgba(245,158,11,.3); display: flex; align-items: center; justify-content: center; font-size: 1.6rem; color: var(--gold); flex-shrink: 0; }
  .ns-tasks-body { min-width: 0; }
  .ns-tasks-tag { font-family: var(--mono); font-size: .66rem; color: var(--gold); text-transform: uppercase; letter-spacing: .1em; margin-bottom: 5px; }
  .ns-tasks-title { font-size: 1.1rem; font-weight: 800; color: var(--text); margin-bottom: 6px; line-height: 1.2; }
  .ns-tasks-desc { font-size: .82rem; color: var(--muted); line-height: 1.55; }
  .ns-tasks-cta { display: flex; align-items: center; gap: 8px; background: var(--gold); color: #0f1117; padding: 11px 22px; border-radius: 99px; font-weight: 700; font-size: .84rem; flex-shrink: 0; text-decoration: none; transition: transform .18s, box-shadow .18s; box-shadow: 0 4px 14px rgba(245,158,11,.3); }
  .ns-tasks-card:hover .ns-tasks-cta { transform: translateY(-2px); box-shadow: 0 8px 22px rgba(245,158,11,.4); }
  @media (max-width: 600px) { .ns-tasks-card { grid-template-columns: auto 1fr; } .ns-tasks-cta { grid-column: 1 / -1; justify-content: center; } }

  .ns-nav-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 14px; }
  .ns-nav-card { background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--rl); padding: 24px; text-decoration: none; display: flex; flex-direction: column; position: relative; overflow: hidden; transition: border-color .22s, transform .22s, box-shadow .22s; }
  .ns-nav-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px; transform: scaleX(0); transform-origin: left; transition: transform .28s ease; }
  .ns-nav-card:hover { border-color: var(--border-h); transform: translateY(-5px); box-shadow: 0 20px 48px rgba(0,0,0,.35); }
  .ns-nav-card:hover::before { transform: scaleX(1); }

  .ns-nav-card.c-purple .ns-nav-icon { background: var(--ns-dim); color: var(--ns); }
  .ns-nav-card.c-purple::before { background: linear-gradient(90deg, var(--ns3), var(--ns2)); }
  .ns-nav-card.c-green .ns-nav-icon { background: var(--green-dim); color: var(--green); }
  .ns-nav-card.c-green::before { background: linear-gradient(90deg, var(--green), #4ade80); }
