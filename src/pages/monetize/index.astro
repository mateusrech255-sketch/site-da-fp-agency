---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<Layout>
  <link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/remixicon@3.5.0/fonts/remixicon.css" rel="stylesheet">

  <div class="fp-agency-wrapper">
    <Header />

    <main class="pm">
      <div id="pm-exit-layer" class="pm-exit-layer" role="dialog" aria-modal="true" aria-label="Abrir link externo">
        <div class="pm-exit-icon"><i class="ri-external-link-line"></i></div>
        <div class="pm-exit-title">Abrir no Navegador</div>
        <p class="pm-exit-sub">
          Este link precisa ser aberto no <strong>navegador do seu celular</strong>
          para funcionar corretamente.
        </p>
        <div class="pm-exit-url" id="pm-exit-url-display"></div>
        
        <button class="pm-exit-btn" onclick="pmForceExternal()">
          <i class="ri-compass-3-line"></i> Abrir no Navegador
        </button>
        
        <button class="pm-exit-copy" id="pm-exit-copy-btn" onclick="pmCopyUrl()">
          <i class="ri-clipboard-line"></i> Copiar Link
        </button>

        <button class="pm-exit-try" onclick="pmTryHere()">
          <i class="ri-links-line"></i> Tentar abrir por aqui
        </button>
        
        <button class="pm-exit-back" onclick="pmExitClose()">
          ← Voltar
        </button>
      </div>

      <div class="pm-hero">
        <div class="pm-hero-inner">
          <div class="pm-badge">
            <span class="pm-badge-dot"></span>
            Vagas Abertas em Todos os Programas
          </div>
          <h1 class="pm-hero-title">
            Programas de<br><span>Monetização</span>
          </h1>
          <p class="pm-hero-sub">
            Descubra formas de gerar renda com conteúdo, narração, lives e indicações.
            Escolha o programa ideal para o seu perfil e comece hoje.
          </p>
        </div>
      </div>

      <div class="pm-marquee-wrap" aria-hidden="true">
        <div class="pm-marquee-band">
          <div class="pm-marquee-track">
            <div class="pm-marquee-group">
              <span class="pm-chip"><i class="ri-scissors-cut-line"></i> Kwai Cut</span>
              <span class="pm-chip"><i class="ri-mic-line"></i> Kwai Narrastars</span>
              <span class="pm-chip"><i class="ri-broadcast-line"></i> Kako Live</span>
              <span class="pm-chip"><i class="ri-vip-crown-2-line"></i> Fantazy</span>
              <span class="pm-chip"><i class="ri-team-line"></i> Recrutador FP</span>
              <span class="pm-chip"><i class="ri-global-line"></i> Pagamento em Dólar</span>
              <span class="pm-chip"><i class="ri-money-dollar-circle-line"></i> Renda Recorrente</span>
              <span class="pm-chip"><i class="ri-shield-check-line"></i> Suporte FP Agency</span>
            </div>
            <div class="pm-marquee-group" aria-hidden="true">
              <span class="pm-chip"><i class="ri-scissors-cut-line"></i> Kwai Cut</span>
              <span class="pm-chip"><i class="ri-mic-line"></i> Kwai Narrastars</span>
              <span class="pm-chip"><i class="ri-broadcast-line"></i> Kako Live</span>
              <span class="pm-chip"><i class="ri-vip-crown-2-line"></i> Fantazy</span>
              <span class="pm-chip"><i class="ri-team-line"></i> Recrutador FP</span>
              <span class="pm-chip"><i class="ri-global-line"></i> Pagamento em Dólar</span>
              <span class="pm-chip"><i class="ri-money-dollar-circle-line"></i> Renda Recorrente</span>
              <span class="pm-chip"><i class="ri-shield-check-line"></i> Suporte FP Agency</span>
            </div>
          </div>
        </div>
      </div>

      <div class="pm-section">
        <div class="pm-section-label">
          <span class="pm-section-label-text">Escolha seu programa</span>
          <div class="pm-section-label-line"></div>
        </div>

        <div class="pm-grid">
          <div class="pm-card c-orange">
            <div class="pm-card-icon"><i class="ri-scissors-cut-fill"></i></div>
            <div class="pm-card-tag">Edição de Vídeos</div>
            <h3 class="pm-card-title">Kwai Cut</h3>
            <p class="pm-card-desc">Edite cortes rápidos e dinâmicos para vídeos do Kwai. Seja remunerado por visualizações com pagamento em dólar.</p>
            <div class="pm-card-attrs">
              <span class="pm-attr"><i class="ri-check-line"></i> Sem experiência prévia</span>
              <span class="pm-attr"><i class="ri-check-line"></i> Pagamento em dólar</span>
              <span class="pm-attr"><i class="ri-check-line"></i> Treinamento incluso</span>
            </div>
            <a href={`${import.meta.env.BASE_URL}/kwai-cut/inscricao`}
               onclick="pmOpenLink(event,this.href)"
               rel="noopener noreferrer external"
               class="pm-btn pm-btn-orange">
              <i class="ri-quill-pen-line"></i> Inscrever-se
            </a>
          </div>

          <div class="pm-card c-purple">
            <div class="pm-card-icon"><i class="ri-mic-fill"></i></div>
            <div class="pm-card-tag">Narração + Tarefas Pagas</div>
            <h3 class="pm-card-title">Kwai Narrastars</h3>
            <p class="pm-card-desc">Narre vídeos e ganhe por visualizações e por tarefas especiais remuneradas. Duas fontes de renda num só programa.</p>
            <div class="pm-card-attrs">
              <span class="pm-attr"><i class="ri-check-line"></i> RPM + Tarefas Pagas</span>
              <span class="pm-attr"><i class="ri-check-line"></i> Pagamento em dólar</span>
              <span class="pm-attr"><i class="ri-check-line"></i> NARRA Motions</span>
            </div>
            <a href={`${import.meta.env.BASE_URL}/kwai-narrastars/inscricao`}
               onclick="pmOpenLink(event,this.href)"
               rel="noopener noreferrer external"
               class="pm-btn pm-btn-purple">
              <i class="ri-quill-pen-line"></i> Inscrever-se
            </a>
          </div>

          <div class="pm-card c-blue">
            <div class="pm-card-icon"><i class="ri-broadcast-fill"></i></div>
            <div class="pm-card-tag">Lives & Streaming</div>
            <h3 class="pm-card-title">Kako Live</h3>
            <p class="pm-card-desc">Faça lives ao vivo e monetize sua audiência. Suporte estratégico, metas alcançáveis e ambiente seguro para streamers.</p>
            <div class="pm-card-attrs">
              <span class="pm-attr"><i class="ri-check-line"></i> Monetização por live</span>
              <span class="pm-attr"><i class="ri-check-line"></i> Suporte estratégico</span>
              <span class="pm-attr"><i class="ri-check-line"></i> Android & iOS</span>
            </div>
            <button class="pm-btn pm-btn-blue" onclick="pmOpenModal('modal-kako')">
              <i class="ri-arrow-right-line"></i> Ver Instruções
            </button>
          </div>

          <div class="pm-card c-gold">
            <div class="pm-card-icon"><i class="ri-vip-crown-2-fill"></i></div>
            <div class="pm-card-tag">Conteúdo Premium</div>
            <h3 class="pm-card-title">Fantazy</h3>
            <p class="pm-card-desc">Monetize conteúdos exclusivos e vídeos pagos. Venda acesso premium à sua audiência e tenha renda direta.</p>
            <div class="pm-card-attrs">
              <span class="pm-attr"><i class="ri-check-line"></i> Venda direta</span>
              <span class="pm-attr"><i class="ri-check-line"></i> Conteúdo exclusivo</span>
              <span class="pm-attr"><i class="ri-check-line"></i> Link de indicação oficial</span>
            </div>
            <button class="pm-btn pm-btn-gold" onclick="pmOpenModal('modal-fantazy')">
              <i class="ri-arrow-right-line"></i> Ver Cadastro
            </button>
          </div>

          <div class="pm-card c-recruiter" style="grid-column: 1 / -1; flex-direction: row; flex-wrap: wrap; align-items: center; gap: 20px;">
            <div class="pm-card-icon" style="margin-bottom:0; width:56px; height:56px; border-radius:14px; font-size:1.6rem; flex-shrink:0;">
              <i class="ri-team-fill"></i>
            </div>
            <div style="flex:1; min-width:220px;">
              <div class="pm-card-tag">Ganhos Recorrentes</div>
              <h3 class="pm-card-title" style="margin-bottom:8px;">Recrutador FP Agency</h3>
              <p class="pm-card-desc" style="margin-bottom:0;">Indique talentos para nossos programas e receba uma porcentagem recorrente sobre os ganhos deles. Quanto mais você recruta, mais você ganha — sem limite de renda.</p>
            </div>
            <div class="pm-card-attrs" style="flex-basis:100%; margin-bottom:0;">
              <span class="pm-attr"><i class="ri-check-line"></i> Comissão recorrente</span>
              <span class="pm-attr"><i class="ri-check-line"></i> Sem limite de indicações</span>
              <span class="pm-attr"><i class="ri-check-line"></i> Painel de acompanhamento</span>
            </div>
            <a href={`${import.meta.env.BASE_URL}/recrutador`}
               onclick="pmOpenLink(event,this.href)"
               rel="noopener noreferrer external"
               class="pm-btn pm-btn-recruiter" style="width:auto; min-width:200px; flex-shrink:0; margin-top:0;">
              <i class="ri-user-add-line"></i> Quero Recrutar
            </a>
          </div>

        </div>
      </div>

      <div id="modal-kako" class="pm-modal-overlay" role="dialog" aria-modal="true">
        <div class="pm-modal">
          <button class="pm-modal-close" onclick="pmCloseModal('modal-kako')" aria-label="Fechar">
            <i class="ri-close-line"></i>
          </button>
          <div class="pm-modal-title">Kako Live</div>
          <p class="pm-modal-sub">Siga os passos abaixo para se inscrever corretamente.</p>

          <div class="pm-step">
            <div class="pm-step-num">Passo 01 — Instalar o app</div>
            <p class="pm-step-text">Baixe o aplicativo <strong>Kako Live</strong> no seu dispositivo:</p>
            <a href="https://play.google.com/store/apps/details?id=live.kako.global"
               onclick="pmOpenLink(event,this.href)"
               rel="noopener noreferrer external"
               class="pm-modal-btn android" style="margin-top:12px;">
              <i class="ri-android-fill"></i> Android — Google Play
            </a>
            <a href="https://apps.apple.com/br/app/kako-live-v%C3%ADdeo-chat/id6730126445"
               onclick="pmOpenLink(event,this.href)"
               rel="noopener noreferrer external"
               class="pm-modal-btn ios" style="margin-top:8px;">
              <i class="ri-apple-fill"></i> iPhone — App Store
            </a>
          </div>

          <div class="pm-step">
            <div class="pm-step-num">Passo 02 — Vincular à FP Agency</div>
            <p class="pm-step-text">Acesse seu <strong>Perfil → Centro do Host → Minha Agência</strong> e insira o ID da FP Agency: <strong style="color:var(--orange); font-family:var(--mono);">159444</strong></p>
          </div>

          <div class="pm-step">
            <div class="pm-step-num">Passo 03 — Aguardar contato</div>
            <p class="pm-step-text">Após se inscrever, aguarde o contato via WhatsApp pelo número <strong>(54) 9677-8933</strong> ou clique abaixo:</p>
            <a href="https://wa.me/555496778933"
               onclick="pmOpenLink(event,this.href)"
               rel="noopener noreferrer external"
               class="pm-modal-btn wpp" style="margin-top:12px;">
              <i class="ri-whatsapp-line"></i> Chamar no WhatsApp
            </a>
          </div>
        </div>
      </div>

      <div id="modal-fantazy" class="pm-modal-overlay" role="dialog" aria-modal="true">
        <div class="pm-modal">
          <button class="pm-modal-close" onclick="pmCloseModal('modal-fantazy')" aria-label="Fechar">
            <i class="ri-close-line"></i>
          </button>
          <div class="pm-modal-title">Fantazy</div>
          <p class="pm-modal-sub">Use o link oficial para ativar sua monetização corretamente.</p>

          <div class="pm-step">
            <div class="pm-step-num">Cadastro Oficial</div>
            <p class="pm-step-text" style="margin-bottom:12px;">Para que sua conta seja vinculada à <strong>FP Agency</strong> e a monetização seja ativada corretamente, utilize obrigatoriamente o link abaixo:</p>
            <a href="https://www.fantazy.com.br/register?ref=MXGTQ9KC"
               onclick="pmOpenLink(event,this.href)"
               rel="noopener noreferrer external"
               class="pm-modal-btn primary">
              <i class="ri-external-link-line"></i> Acessar Cadastro Oficial
            </a>
            <p style="font-family:var(--mono); font-size:.68rem; color:var(--muted); margin-top:10px; text-align:center;">
              Código de indicação: <strong style="color:var(--orange);">MXGTQ9KC</strong>
            </p>
          </div>
        </div>
      </div>

    </main>

    <Footer />
  </div>
</Layout>

<script>
  declare global {
    interface Window {
      __pm_target_url: string | null;
      pmOpenLink: (e: Event | null, url: string) => void;
      pmOpenModal: (id: string) => void;
      pmCloseModal: (id: string) => void;
      pmForceExternal: () => void;
      pmCopyUrl: () => void;
      pmTryHere: () => void;
      pmExitClose: () => void;
    }
  }

  (function () {
    'use strict';

    function isLockedWebView(): boolean {
      const ua = navigator.userAgent || '';
      return /(Kwai|Instagram|FBAN|FBAV|TikTok|Line\/|MicroMessenger|Snapchat|wv\b|WebView)/i.test(ua);
    }

    function isAndroid(): boolean { return /Android/i.test(navigator.userAgent); }
    function isIOS(): boolean     { return /iPhone|iPad|iPod/i.test(navigator.userAgent); }

    function pmShowExit(url: string) {
      window.__pm_target_url = url;
      const display = document.getElementById('pm-exit-url-display');
      if (display) display.textContent = url.replace(/^https?:\/\//, '');

      const copyBtn = document.getElementById('pm-exit-copy-btn');
      if (copyBtn) {
        copyBtn.classList.remove('copied');
        copyBtn.innerHTML = '<i class="ri-clipboard-line"></i> Copiar Link';
      }

      document.getElementById('pm-exit-layer')?.classList.add('show');
      document.body.style.overflow = 'hidden';
    }

    function pmExitClose() {
      document.getElementById('pm-exit-layer')?.classList.remove('show');
      document.body.style.overflow = '';
      window.__pm_target_url = null;
    }

    function pmForceExternal() {
      const url = window.__pm_target_url;
      if (!url) return;

      if (isAndroid()) {
        const intentUrl = 'intent://' + url.replace(/^https?:\/\//, '') + '#Intent;scheme=https;action=android.intent.action.VIEW;end';
        window.open(intentUrl, '_top');
        return;
      }
      window.open(url, '_top');
    }

    function pmCopyUrl() {
      const url = window.__pm_target_url;
      if (!url) return;

      const btn = document.getElementById('pm-exit-copy-btn');
      if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(url).then(() => {
          if (btn) {
            btn.classList.add('copied');
            btn.innerHTML = '<i class="ri-check-line"></i> Copiado! Cole no navegador';
          }
        }).catch(() => pmFallbackCopy(url, btn));
        return;
      }
      pmFallbackCopy(url, btn);
    }

    function pmFallbackCopy(url: string, btn: HTMLElement | null) {
      try {
        const ta = document.createElement('textarea');
        ta.value = url;
        ta.style.cssText = 'position:fixed;opacity:0;top:0;left:0;';
        document.body.appendChild(ta);
        ta.focus(); ta.select();
        document.execCommand('copy');
        document.body.removeChild(ta);
        if (btn) {
          btn.classList.add('copied');
          btn.innerHTML = '<i class="ri-check-line"></i> Copiado! Cole no navegador';
        }
      } catch (_) {
        if (btn) btn.innerHTML = '<i class="ri-close-line"></i> Não foi possível copiar';
      }
    }

    function pmTryHere() {
      const url = window.__pm_target_url;
      if (!url) return;
      
      const googleRedirectUrl = 'https://www.google.com/url?q=' + encodeURIComponent(url);
      window.open(googleRedirectUrl, '_top');
    }

    function pmOpenLink(e: Event | null, url: string) {
      if (e) e.preventDefault();
      if (!url) return;

      if (isLockedWebView()) {
        pmShowExit(url);
        return;
      }

      const win = window.open(url, '_blank', 'noopener,noreferrer');
      if (!win || win.closed || typeof win.closed === 'undefined') {
        window.open(url, '_top');
      }
    }

    function patchExternalLinks() {
      document.querySelectorAll<HTMLAnchorElement>('a[href^="http"]').forEach(link => {
        if (link.dataset.pmPatched) return;
        link.removeAttribute('target');
        link.setAttribute('rel', 'noopener noreferrer external');
        
        link.addEventListener('click', (e) => pmOpenLink(e, link.href));
        link.dataset.pmPatched = '1';
      });
    }

    function pmOpenModal(id: string) {
      const el = document.getElementById(id);
      if (!el) return;
      el.style.display = 'flex';
      requestAnimationFrame(() => requestAnimationFrame(() => el.classList.add('visible')));
      document.body.style.overflow = 'hidden';
    }

    function pmCloseModal(id: string) {
      const el = document.getElementById(id);
      if (!el) return;
      el.classList.remove('visible');
      el.addEventListener('transitionend', () => {
        el.style.display = 'none';
        document.body.style.overflow = '';
      }, { once: true });
    }

    document.querySelectorAll<HTMLElement>('.pm-modal-overlay').forEach(overlay => {
      overlay.addEventListener('click', e => {
        if (e.target === overlay) pmCloseModal(overlay.id);
      });
    });

    document.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Escape') {
        document.querySelectorAll<HTMLElement>('.pm-modal-overlay.visible').forEach(el => pmCloseModal(el.id));
        pmExitClose();
      }
    });

    document.addEventListener('contextmenu', e => e.preventDefault());
    document.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'F12') { e.preventDefault(); return; }
      if ((e.ctrlKey || e.metaKey) && e.shiftKey && ['I','J','C'].includes(e.key.toUpperCase())) {
        e.preventDefault();
      }
      if ((e.ctrlKey || e.metaKey) && e.key.toUpperCase() === 'U') e.preventDefault();
    });

    window.pmOpenLink      = pmOpenLink;
    window.pmOpenModal     = pmOpenModal;
    window.pmCloseModal    = pmCloseModal;
    window.pmForceExternal = pmForceExternal;
    window.pmCopyUrl       = pmCopyUrl;
    window.pmTryHere       = pmTryHere;
    window.pmExitClose     = pmExitClose;

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', patchExternalLinks);
    } else {
      patchExternalLinks();
    }
  })();
</script>

<style>
  .pm {
    --bg-card:     var(--bg-2);
    --bg-input:    #1e2332;
    --border:      #2a3048;
    --border-h:    #3d4d7a;
    --orange-dim:  #ff6b2b18;
    --orange-glow: rgba(255,107,43,.22);
    --ns:          #a855f7;
    --ns-dim:      #a855f718;
    --green:       #22c55e;
    --green-dim:   #22c55e18;
    --blue:        #3b82f6;
    --blue-dim:    #3b82f618;
    --gold:        #f59e0b;
    --gold-dim:    #f59e0b18;
    --red:         #ef4444;
    --text-faint:  #1e2332;
    --mono:        'JetBrains Mono', monospace;
    --r:           14px;
    --rl:          20px;

    font-family: 'Sora', sans-serif;
    background: transparent;
    color: var(--text);
    overflow-x: hidden;
    position: relative;
    padding-bottom: 80px;
    min-height: 100dvh;
  }

  .pm-hero { position: relative; padding: 52px 20px 44px; text-align: center; overflow: hidden; }
  .pm-hero::before { content: ''; position: absolute; top: -60px; left: 50%; transform: translateX(-50%); width: 700px; height: 380px; background: radial-gradient(ellipse, rgba(255,107,43,.13) 0%, transparent 65%); pointer-events: none; }
  .pm-hero::after { content: ''; position: absolute; inset: 0; background-image: linear-gradient(rgba(255,107,43,.04) 1px, transparent 1px), linear-gradient(90deg, rgba(255,107,43,.04) 1px, transparent 1px); background-size: 44px 44px; pointer-events: none; -webkit-mask-image: radial-gradient(ellipse 80% 60% at 50% 0%, black 25%, transparent 100%); mask-image: radial-gradient(ellipse 80% 60% at 50% 0%, black 25%, transparent 100%); }
  .pm-hero-inner { position: relative; z-index: 1; }

  .pm-badge { display: inline-flex; align-items: center; gap: 8px; font-family: var(--mono); font-size: .7rem; color: var(--orange); letter-spacing: .1em; text-transform: uppercase; background: var(--orange-dim); padding: 5px 15px; border-radius: 99px; border: 1px solid rgba(255,107,43,.3); margin-bottom: 20px; }
  .pm-badge-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--orange); box-shadow: 0 0 8px var(--orange); animation: pm-pulse 2s ease-in-out infinite; }
  @keyframes pm-pulse { 0%,100%{opacity:1} 50%{opacity:.3} }

  .pm-hero-title { font-size: clamp(1.9rem, 5.5vw, 3.2rem); font-weight: 900; line-height: 1.05; letter-spacing: -.03em; margin-bottom: 14px; }
  .pm-hero-title span { background: linear-gradient(135deg, var(--orange), var(--orange2)); -webkit-background-clip: text; background-clip: text; color: transparent; }
  .pm-hero-sub { font-size: .98rem; color: var(--muted); max-width: 480px; margin: 0 auto; line-height: 1.65; }

  .pm-marquee-wrap { overflow: hidden; border-top: 1px solid rgba(255,255,255,.06); border-bottom: 1px solid rgba(255,255,255,.06); margin: 36px 0 52px; }
  .pm-marquee-band { padding: 14px 0; display: flex; overflow: hidden; -webkit-mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent); mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent); }
  .pm-marquee-track { display: flex; width: max-content; animation: pm-marquee 30s linear infinite; will-change: transform; }
  .pm-marquee-track:hover { animation-play-state: paused; }
  .pm-marquee-group { display: flex; gap: 10px; padding-right: 10px; }
  .pm-chip { min-height: 36px; padding: 0 16px; border-radius: 99px; display: inline-flex; align-items: center; gap: 7px; border: 1px solid rgba(255,255,255,.08); background: rgba(255,255,255,.03); color: var(--muted); font-size: .78rem; white-space: nowrap; backdrop-filter: blur(4px); }
  .pm-chip i { background: linear-gradient(135deg, var(--orange), var(--orange2)); -webkit-background-clip: text; background-clip: text; color: transparent; font-size: .9rem; }
  @keyframes pm-marquee { from { transform: translateX(0); } to { transform: translateX(-50%); } }

  .pm-section { padding: 0 20px; max-width: 1020px; margin: 0 auto 52px; }
  .pm-section-label { display: flex; align-items: center; gap: 12px; margin-bottom: 24px; }
  .pm-section-label-text { font-family: var(--mono); font-size: .7rem; color: var(--muted); text-transform: uppercase; letter-spacing: .12em; white-space: nowrap; }
  .pm-section-label-line { flex: 1; height: 1px; background: var(--border); }

  .pm-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(290px, 1fr)); gap: 16px; }
