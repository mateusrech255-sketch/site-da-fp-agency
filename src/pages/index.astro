---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import logo from '../assets/fpagency.svg';
---

<Layout>
<div class="fp-agency-wrapper">
  <header class="site-header">
    <div class="container nav">
      <a href="#inicio" class="brand" aria-label="FP Agency">
        <!-- Logo adicionado aqui -->
        <Image src={logo} alt="FP Agency Logo" class="brand-logo" />
        <span>FP Agency</span>
      </a>

      <nav class="nav-links" id="navLinks">
        <a href="#jornadas">Jornadas</a>
        <a href="#programas">Programas</a>
        <a href="#estrutura">Estrutura</a>
        <a href="#resultados">Resultados</a>
        <a href="#faq">FAQ</a>
        <a href="#contato">Contato</a>
      </nav>

      <a href="#contato" class="btn btn-secondary">Falar com a FP</a>
      <button class="menu-toggle" id="menuToggle" aria-label="Abrir menu">☰</button>
    </div>
  </header>

  <main>
    <section class="hero" id="inicio">
      <div class="container hero-grid">
        <div class="hero-copy reveal show">
          <div class="eyebrow">Monetização, creators e parcerias</div>
          <h1>Transforme influência em operação profissional e receita.</h1>
          <p class="lead">
            A FP Agency conecta criadores, recrutadores e marcas com uma estrutura premium de monetização, operação e crescimento. Entenda exatamente onde você entra e qual é o seu próximo passo para escalar nas plataformas.
          </p>

          <div class="btn-row">
            <a href="#jornadas" class="btn btn-primary">Quero entrar na minha jornada</a>
            <a href="#programas" class="btn btn-secondary">Ver programas em destaque</a>
          </div>

          <div class="hero-kpis">
            <span class="badge">Estrutura premium</span>
            <span class="badge">Otimização de RPM</span>
            <span class="badge">Escala de Audiência</span>
            <span class="badge">Gestão Técnica</span>
          </div>
        </div>

        <aside class="hero-panel reveal show" aria-label="Painel visual da FP Agency">
          <div class="panel-top">
            <div class="panel-title">Foco de Atuação</div>
            <div class="status-pill"><span class="status-dot"></span> Operação Ativa</div>
          </div>

          <div class="dashboard">
            <div class="metric-card">
              <div>
                <strong>NarraStars</strong>
                <small>Treinamento e monetização para editores.</small>
              </div>
              <div class="metric-tag">Destaque</div>
            </div>

            <div class="metric-card">
              <div>
                <strong>Três jornadas</strong>
                <small>Criadores, recrutadores e marcas.</small>
              </div>
              <div class="metric-tag">Arquitetura</div>
            </div>

            <div class="metric-card">
              <div>
                <strong>Crescimento Real</strong>
                <small>Estratégia baseada em retenção visual e engajamento.</small>
              </div>
              <div class="metric-tag">Confiança</div>
            </div>
          </div>

          <div class="talents-strip">
            <div class="talent-card">
              <div class="talent-avatar">C</div>
              <strong>Criadores</strong>
              <div class="talent-role">Monetização e aceleração</div>
            </div>
            <div class="talent-card">
              <div class="talent-avatar">R</div>
              <strong>Recrutadores</strong>
              <div class="talent-role">Captação e escala</div>
            </div>
            <div class="talent-card">
              <div class="talent-avatar">M</div>
              <strong>Marcas</strong>
              <div class="talent-role">Ações e parcerias</div>
            </div>
          </div>
        </aside>
      </div>

      <div class="container">
        <div class="proof-band reveal">
          <div class="proof-track">
            <span class="proof-chip"><b>Mais de 130 mil</b> seguidores gerenciados</span>
            <span class="proof-chip"><b>Canais com mais de 120M</b> de alcance</span>
            <span class="proof-chip"><b>Foco em</b> SEO e Retenção Visual</span>
            <span class="proof-chip"><b>Gestão</b> Mateus (CEO)</span>
            <span class="proof-chip"><b>Mais de 130 mil</b> seguidores gerenciados</span>
            <span class="proof-chip"><b>Canais com mais de 120M</b> de alcance</span>
            <span class="proof-chip"><b>Foco em</b> SEO e Retenção Visual</span>
            <span class="proof-chip"><b>Gestão</b> Mateus (CEO)</span>
          </div>
        </div>
      </div>
    </section>

    <section class="section compact" id="jornadas">
      <div class="container">
        <div class="section-head reveal">
          <div class="eyebrow">Jornadas principais</div>
          <h2>Nossa estrutura separa públicos para acelerar resultados.</h2>
          <p class="lead muted">
            A experiência da FP Agency foi desenhada para que você encontre rapidamente o caminho ideal para o seu perfil profissional.
          </p>
        </div>

        <div class="grid-3">
          <article class="audience-card reveal">
            <div class="icon-box">🎬</div>
            <h3>Para Criadores</h3>
            <p class="muted">
              Estrutura focada em quem quer monetizar conteúdo, participar de programas oficiais e crescer com segurança operacional e ganchos de alta conversão.
            </p>
            <ul class="list">
              <li>Treinamento em retenção</li>
              <li>Entrada orientada por programa</li>
              <li>Suporte focado em RPM</li>
            </ul>
            <a href="#contato" class="inline-link">Começar como criador →</a>
          </article>

          <article class="audience-card reveal">
            <div class="icon-box">🤝</div>
            <h3>Para Recrutadores</h3>
            <p class="muted">
              Trilha própria para quem quer captar perfis, receber diretrizes claras e operar a captação de talentos de forma profissional e escalável.
            </p>
            <ul class="list">
              <li>Fluxo de adesão objetivo</li>
              <li>Acesso a regras e materiais</li>
              <li>Base sólida para escalar</li>
            </ul>
            <a href="#contato" class="inline-link">Entrar como recrutador →</a>
          </article>

          <article class="audience-card reveal">
            <div class="icon-box">📈</div>
            <h3>Para Marcas e Parceiros</h3>
            <p class="muted">
              Camada institucional voltada para desenvolvimento de parcerias, ativações com nossa rede de creators e crescimento de presença digital.
            </p>
            <ul class="list">
              <li>Acesso a canais validados</li>
              <li>Estratégia de conteúdo viral</li>
              <li>Canal direto para negócios</li>
            </ul>
            <a href="#contato" class="inline-link">Conversar sobre parceria →</a>
          </article>
        </div>
      </div>
    </section>

    <section class="section" id="programas">
      <div class="container split-panel">
        <div class="glass-card reveal">
          <div class="eyebrow">Programas em destaque</div>
          <h2>Produtos focados em rentabilidade e influência.</h2>
          <p class="lead muted">
            Apresentamos nossos programas como estruturas completas de capacitação e monetização de vídeos nas principais plataformas sociais.
          </p>

          <div class="board">
            <div class="board-card">
              <strong>NarraStars</strong>
              <span>Programa de monetização e treinamento intensivo para editores e criadores. Foco em dominar o algoritmo e escalar o RPM.</span>
            </div>
            <div class="board-card">
              <strong>Kwai Cut</strong>
              <span>Editoriais, cortes, categorias e formatos curtos com requisitos próprios e alto potencial de viralização.</span>
            </div>
            <div class="board-card">
              <strong>Lives & Presença</strong>
              <span>Trilha dedicada para creators com foco em construir comunidade, aumentar a retenção e gerar recorrência diária.</span>
            </div>
            <div class="board-card">
              <strong>Projetos Especiais</strong>
              <span>Espaço reservado para campanhas sazonais e parcerias estratégicas com marcas.</span>
            </div>
          </div>
        </div>

        <div class="pillars reveal" id="estrutura">
          <article class="pillar">
            <small>01. Treinamento</small>
            <h3>Foco em Retenção Visual</h3>
            <p class="muted">
              Ensinamos a criar descrições estratégicas e ganchos de alta conversão para maximizar o alcance dos seus vídeos.
            </p>
          </article>

          <article class="pillar">
            <small>02. Gestão Técnica</small>
            <h3>Infraestrutura Sólida</h3>
            <p class="muted">
              Operamos com sistemas web dedicados para garantir que sua jornada de monetização seja rastreável e organizada.
            </p>
          </article>

          <article class="pillar">
            <small>03. Escala</small>
            <h3>Otimização Constante</h3>
            <p class="muted">
              Acompanhamento de métricas, compreensão das regras de RPM e ajustes práticos para garantir que você não deixe dinheiro na mesa.
            </p>
          </article>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="section-head reveal">
          <div class="eyebrow">Detalhes dos programas</div>
          <h2>Conheça nossas frentes de atuação.</h2>
        </div>

        <div class="grid-3">
          <article class="program-card reveal">
            <span class="program-tag">Treinamento & Escala</span>
            <h3>NarraStars</h3>
            <p class="muted">
              Nosso programa premium. Inclui documentação completa, entendimento das regras de plataforma e os passos exatos para treinar editores de vídeo para o sucesso.
            </p>
            <ul class="list">
              <li>Modelos de Monetização (RPM)</li>
              <li>Regras de engajamento</li>
              <li>Treinamento passo a passo</li>
            </ul>
            <div class="program-foot">
              <span>Vagas qualificadas</span>
              <a href="#contato" class="inline-link" style="margin-top: 0;">Ver detalhes</a>
            </div>
          </article>

          <article class="program-card reveal">
            <span class="program-tag">Creator Economy</span>
            <h3>Kwai Cut</h3>
            <p class="muted">
              Programa focado em edição de formatos curtos. Ideal para quem domina categorias específicas e busca alavancar visualizações rápidas.
            </p>
            <ul class="list">
              <li>Exploração de nichos</li>
              <li>Critérios de viralização</li>
              <li>Orientação de cortes</li>
            </ul>
            <div class="program-foot">
              <span>Entrada guiada</span>
              <a href="#contato" class="inline-link" style="margin-top: 0;">Saiba mais</a>
            </div>
          </article>

          <article class="program-card reveal">
            <span class="program-tag">Partners & Brands</span>
            <h3>Ações Institucionais</h3>
            <p class="muted">
              Conectando o alcance massivo da nossa rede de contas com o seu objetivo de negócio, gerando conversão e autoridade de marca.
            </p>
            <ul class="list">
              <li>Parcerias e ativações</li>
              <li>Match estratégico</li>
              <li>Relatórios de alcance</li>
            </ul>
            <div class="program-foot">
              <span>Modelo consultivo</span>
              <a href="#contato" class="inline-link" style="margin-top: 0;">Conversar</a>
            </div>
          </article>
        </div>
      </div>
    </section>

    <section class="section" id="resultados">
      <div class="container results-strip">
        <div class="reveal">
          <div class="section-head" style="margin-bottom: 26px;">
            <div class="eyebrow">Resultados e prova</div>
            <h2>Nossos números refletem nosso método.</h2>
            <p class="lead muted">
              A FP Agency gerencia uma audiência massiva através de processos bem estruturados de atração e engajamento.
            </p>
          </div>

          <div class="stats-grid">
            <article class="result-card">
              <strong>+130k</strong>
              <p>Seguidores totais gerenciados</p>
            </article>
            <article class="result-card">
              <strong>+120M</strong>
              <p>Views no canal de maior alcance</p>
            </article>
            <article class="result-card">
              <strong>+14M</strong>
              <p>Alcance em canais secundários</p>
            </article>
            <article class="result-card">
              <strong>100%</strong>
              <p>Foco na otimização de RPM</p>
            </article>
          </div>
        </div>

        <div class="quote-stack reveal">
          <article class="quote-card">
            <p>
              "Entender as métricas de RPM e os ganchos de retenção que a FP Agency ensina mudou a forma como nossos vídeos performam nas plataformas."
            </p>
            <div class="person">
              <div class="avatar">C</div>
              <div>
                <strong>Creator do NarraStars</strong>
                <div class="subtle">Programa de Monetização</div>
              </div>
            </div>
          </article>

          <article class="quote-card">
            <p>
              "A agência fornece a infraestrutura técnica e o treinamento necessário para que os recrutadores foquem apenas em trazer os melhores talentos."
            </p>
            <div class="person">
              <div class="avatar">R</div>
              <div>
                <strong>Equipe de Captação</strong>
                <div class="subtle">Operação Interna</div>
              </div>
            </div>
          </article>
        </div>
      </div>
    </section>

    <section class="section" id="faq">
      <div class="container">
        <div class="section-head reveal">
          <div class="eyebrow">Dúvidas Frequentes</div>
          <h2>Transparência desde o primeiro contato.</h2>
        </div>

        <div class="faq-wrap reveal">
          <div class="faq-item active">
            <button class="faq-question" type="button">
              <span>Como funciona o programa NarraStars?</span>
              <span>+</span>
            </button>
            <div class="faq-answer" style="max-height: 180px;">
              <div class="faq-answer-inner">
                O NarraStars é o nosso programa de treinamento e monetização voltado para editores e criadores de vídeo. Ele oferece documentação detalhada sobre regras, foco na otimização do RPM e metodologias para alavancar a audiência nas redes.
              </div>
            </div>
          </div>

          <div class="faq-item">
            <button class="faq-question" type="button">
              <span>Qualquer pessoa pode entrar nos programas da FP Agency?</span>
              <span>+</span>
            </button>
            <div class="faq-answer">
              <div class="faq-answer-inner">
                Cada programa possui requisitos específicos de qualidade, nicho e formato de conteúdo (como o Kwai Cut). Após o primeiro contato, direcionamos você para o onboarding do programa que melhor se alinha ao seu perfil.
              </div>
            </div>
          </div>

          <div class="faq-item">
            <button class="faq-question" type="button">
              <span>Como a FP Agency ajuda os recrutadores?</span>
              <span>+</span>
            </button>
            <div class="faq-answer">
              <div class="faq-answer-inner">
                Fornecemos as regras de recrutamento claras e a infraestrutura necessária (painéis e documentação) para que você possa captar e gerenciar novos talentos com eficiência e suporte constante.
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="section" id="contato">
      <div class="container">
        <div class="cta-panel reveal">
          <div class="eyebrow">Dê o próximo passo</div>
          <h2>Faça parte do ecossistema da FP Agency.</h2>
          <p class="lead">
            Pronto para transformar sua influência em uma operação profissional de alta performance? Escolha seu canal de atendimento e fale diretamente com nossa equipe gerencial.
          </p>
          <div class="btn-row">
            <a href="mailto:contato@fpagency.com.br" class="btn btn-primary">Enviar E-mail</a>
            <a href="https://wa.me/message/3YJWHJM7UOR6C1" class="btn btn-secondary">Falar no WhatsApp</a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <footer>
    <div class="container footer-grid">
      <div>
        <div class="brand" style="margin-bottom: 14px;">
          <!-- Logo adicionado aqui no Footer -->
          <Image src={logo} alt="FP Agency Logo" class="brand-logo" />
          <span>FP Agency</span>
        </div>
        <p class="subtle">
          Conectando criadores, recrutadores e marcas com tecnologia, treinamento e foco em resultados massivos. Direcionamento estratégico liderado por Mateus.
        </p>
      </div>

      <div>
        <h3>Navegação</h3>
        <div class="footer-links">
          <a href="#jornadas">Jornadas</a>
          <a href="#programas">Programas</a>
          <a href="#estrutura">Estrutura</a>
          <a href="#resultados">Resultados</a>
          <a href="#faq">FAQ</a>
        </div>
      </div>

      <div>
        <h3>Institucional</h3>
        <div class="footer-links">
          <a href="/politica-de-privacidade">Política de Privacidade</a>
          <a href="/termos-de-servico">Termos de Serviço</a>
          <a href="/aviso-legal">Aviso Legal</a>
        </div>
      </div>
    </div>
  </footer>
</div>

<script>
  const menuToggle = document.getElementById("menuToggle");
  const navLinks = document.getElementById("navLinks");

  if (menuToggle && navLinks) {
    menuToggle.addEventListener("click", () => {
      navLinks.classList.toggle("open");
    });
  }

  document.querySelectorAll(".faq-item").forEach((item) => {
    // Adicionamos "as HTMLElement" para confirmar que o elemento possui a propriedade "style"
    const button = item.querySelector(".faq-question") as HTMLElement;
    const answer = item.querySelector(".faq-answer") as HTMLElement;

    // A verificação "if" acalma o Astro, garantindo que não são nulos
    if (button && answer) {
      button.addEventListener("click", () => {
        const isActive = item.classList.contains("active");

        document.querySelectorAll(".faq-item").forEach((other) => {
          other.classList.remove("active");
          const otherAnswer = other.querySelector(".faq-answer") as HTMLElement;
          if (otherAnswer) otherAnswer.style.removeProperty("maxHeight");
        });

        if (!isActive) {
          item.classList.add("active");
          answer.style.maxHeight = answer.scrollHeight + "px";
        }
      });
    }
  });

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("show");
        }
      });
    },
    { threshold: 0.12 }
  );

  document.querySelectorAll(".reveal").forEach((el) => observer.observe(el));
</script>

<style>
  :root {
    --bg: #0f1117;
    --bg-2: #181c27;
    --surface: rgba(255, 255, 255, 0.03);
    --surface-2: rgba(255, 255, 255, 0.06);
    --line: #2a3048;
    --text: #e2e8f0;
    --muted: #64748b;
    --orange: #ff6b2b;
    --orange2: #ff9a5c;
    --gold: #f59e0b;
    --shadow: 0 30px 80px rgba(0, 0, 0, 0.35);
    --radius-xl: 34px;
    --radius-lg: 26px;
    --radius-md: 20px;
    --container: 1220px;
  }

  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  .fp-agency-wrapper {
    font-family: "Inter", system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    background:
      radial-gradient(circle at top left, rgba(255, 107, 43, 0.16), transparent 28%),
      radial-gradient(circle at 85% 10%, rgba(255, 154, 92, 0.1), transparent 22%),
      linear-gradient(180deg, #0f1117 0%, #13161e 40%, #181c27 100%);
    color: var(--text);
    overflow-x: hidden;
    line-height: 1.6;
    min-height: 100vh;
    position: relative;
    scroll-behavior: smooth;
  }

  .fp-agency-wrapper::before,
  .fp-agency-wrapper::after {
    content: "";
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: -1;
  }

  .fp-agency-wrapper::before {
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.02) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.02) 1px, transparent 1px);
    background-size: 42px 42px;
    mask-image: linear-gradient(to bottom, rgba(0, 0, 0, 0.45), transparent 85%);
    -webkit-mask-image: linear-gradient(to bottom, rgba(0, 0, 0, 0.45), transparent 85%);
  }

  .fp-agency-wrapper::after {
    background: radial-gradient(circle at center, transparent 45%, rgba(0, 0, 0, 0.28) 100%);
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  img {
    max-width: 100%;
    display: block;
  }

  .container {
    width: min(calc(100% - 32px), var(--container));
    margin: 0 auto;
  }

  .section {
    padding: 104px 0;
    position: relative;
  }

  .section.compact {
    padding-top: 80px;
    padding-bottom: 80px;
  }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 18px;
    color: var(--orange2);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 0.82rem;
    font-weight: 800;
  }

  .eyebrow::before {
    content: "";
    width: 26px;
    height: 1px;
    background: linear-gradient(90deg, var(--orange), transparent);
  }

  h1, h2, h3, h4 {
    line-height: 1.05;
    letter-spacing: -0.03em;
  }

  h1 {
    font-size: clamp(3rem, 7vw, 6.2rem);
    font-weight: 900;
  }

  h2 {
    font-size: clamp(2rem, 4vw, 3.5rem);
    font-weight: 900;
    margin-bottom: 14px;
  }

  h3 {
    font-size: 1.28rem;
    font-weight: 800;
    margin-bottom: 10px;
  }

  .lead {
    font-size: clamp(1.04rem, 1.9vw, 1.18rem);
    color: #d7e3ec;
    max-width: 780px;
  }

  .muted {
    color: var(--muted);
  }

  .section-head {
    max-width: 780px;
    margin-bottom: 44px;
  }

  .btn-row {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-top: 30px;
  }

  .btn {
    min-height: 56px;
    padding: 0 22px;
    border-radius: 999px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    font-weight: 800;
    border: 1px solid transparent;
    transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease, background 0.18s ease;
    cursor: pointer;
  }

  .btn:hover {
    transform: translateY(-2px);
  }

  .btn-primary {
    background: linear-gradient(135deg, var(--orange), var(--orange2));
    color: #fff;
    box-shadow: 0 18px 40px rgba(255, 107, 43, 0.25);
  }

  .btn-secondary {
    background: rgba(255, 255, 255, 0.045);
    color: var(--text);
    border-color: rgba(255, 255, 255, 0.12);
    backdrop-filter: blur(12px);
  }

  .btn-ghost {
    background: rgba(255, 154, 92, 0.05);
    color: var(--orange2);
    border-color: rgba(255, 154, 92, 0.18);
  }

  .badge {
    display: inline-flex;
    align-items: center;
